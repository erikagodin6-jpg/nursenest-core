    "import:audit-content": "tsx scripts/audit-content-json-import.ts",
    "import:career-questions": "tsx scripts/import-career-questions-json.ts",
    "copy:career-questions-from-downloads": "tsx scripts/copy-career-questions-from-downloads.ts",
    "import:nursing-ai-cache": "tsx scripts/import-nursing-ai-cache.ts",
    "replit:spaces-pipeline": "node scripts/replit-export-spaces-pipeline.mjs",
    "import:replit-questions": "tsx scripts/import-replit-question-bank.ts",
    "ops:np-recovery": "tsx scripts/np-recovery-audit-and-import.ts",
    "ops:recover-rn-rpn-historical": "tsx scripts/recover-rn-rpn-historical-lessons.ts",
    "ops:reconcile-rn-rpn-inventory": "tsx scripts/reconcile-rn-rpn-inventory-reports.ts",
    "ops:recover-np-historical": "tsx scripts/recover-np-historical-lessons.ts"
  },
  "dependencies": {
    "@auth/core": "0.37.2",
    "@aws-sdk/client-s3": "^3.1019.0",
    "@prisma/client": "^6.7.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@sentry/nextjs": "^10.46.0",
    "bcryptjs": "^2.4.3",
    "lucide-react": "^0.562.0",
    "next": "16.2.1",
    "next-auth": "^5.0.0-beta.25",
    "next-themes": "^0.4.6",
    "posthog-js": "^1.364.1",
    "posthog-node": "^5.28.8",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "sharp": "^0.34.1",
    "stripe": "^18.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "google-translate-api-x": "^10.7.2",
    "mime-types": "^2.1.35",
    "pg": "^8.20.0",
    "png-to-ico": "^3.0.1",
    "prisma": "^6.7.0",
    "tailwindcss": "^4",
