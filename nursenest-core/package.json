{
  "name": "rest-express",
  "version": "1.0.0",
  "packageManager": "npm@10.9.7",
  "license": "MIT",
  "cacheDirectories": [
    "node_modules"
  ],
  "scripts": {
    "dev:client": "vite dev --port 5000",
    "dev:next": "node scripts/assert-local-auth-secret.mjs && node scripts/ensure-node-memory.mjs && . ./scripts/.node-memory-exports.sh && npx next dev",
    "dev:next:3000": "node scripts/dev/start-next-dev-3000.mjs",
    "wait:app:ready": "node scripts/qa/wait-for-app-ready.mjs",
    "qa:wait:app-ready": "node scripts/qa/wait-for-app-ready.mjs",
    "runtime:env:validate": "node scripts/runtime/validate-local-env.mjs",
    "runtime:standalone:build": "node scripts/runtime/build-standalone.mjs",
    "runtime:standalone:start": "node scripts/runtime/start-standalone.mjs",
    "qa:local:standalone:validate-env": "npm run runtime:env:validate",
    "qa:local:standalone:node": "npm run runtime:standalone:start",
    "capture:marketing-screenshots:qa": "node scripts/wait-for-app-ready.mjs && node scripts/capture-marketing-screenshots.mjs",
    "dev": "node scripts/ensure-node-memory.mjs && . ./scripts/.node-memory-exports.sh && NODE_ENV=development tsx server/index.ts",
    "postinstall": "node scripts/prisma-safe.mjs generate",
    "db:generate": "node scripts/prisma-safe.mjs generate",
    "db:status": "node scripts/prisma-safe.mjs status",
    "report:rt-tier-phase-2": "npx tsx scripts/rt-tier-phase-2-inventory.mts",
    "report:mlt-tier-readiness": "npx tsx scripts/mlt-tier-readiness-inventory.mts",
    "readiness:emit-snapshot": "npx tsx scripts/readiness/emit-pathway-readiness-snapshot.mts",
    "readiness:verify": "node --import tsx --test src/lib/exam-pathways/cnple-hub-readiness.contract.test.ts src/lib/exam-pathways/cnple-product-readiness.contract.test.ts",
    "audit:exam-bank": "npx tsx scripts/audit-exam-question-bank.ts",
    "audit:exam-remediation-queue": "npx tsx scripts/build-clinical-question-remediation-queue.ts",
    "audit:flashcard-pools": "npx tsx scripts/audit-flashcard-pools.ts",
    "audit:practice-hub:us-rn": "npx tsx scripts/audit-us-rn-nclex-rn-practice-hub-counts.mts",
    "audit:practice-hub:ca-rn": "npx tsx scripts/audit-ca-rn-nclex-rn-practice-hub-counts.mts",
    "content:ensure:exam-bank": "npx tsx scripts/ensure-exam-question-bank.ts",
    "content:populate:exam-bank": "npx tsx scripts/populate-exam-question-bank.ts",
    "content:normalize:exam-values": "npx tsx scripts/normalize-exam-question-exam-values.ts",
    "content:audit:exam-keys": "npx tsx scripts/audit-exam-question-exam-keys.ts",
    "content:repair:exam-keys": "npx tsx scripts/repair-exam-question-exam-keys.ts",
    "env:check": "node ../scripts/check-required-env.mjs",
    "prebuild": "node ../scripts/ensure-build-toolchain.mjs && npm run guard:build-scripts && npm run build:prepare-content",
    "build": "node scripts/run-buildpack-build.mjs && node ../scripts/verify-dist-artifacts.mjs",
    "build:prepare-content": "node scripts/run-build-prepare-content.mjs",
    "build:next": "node scripts/run-next-prod-build.mjs",
    "build:production": "node scripts/run-build-production.mjs",
    "build:verify-turbopack-safety": "node scripts/verify-turbopack-build-safety.mjs",
    "build:server": "node scripts/ensure-node-memory.mjs && . ./scripts/.node-memory-exports.sh && BUILD_TARGET=server npx tsx ../script/build.ts && node ../scripts/verify-dist-artifacts.mjs",
    "build:client": "node scripts/ensure-node-memory.mjs && . ./scripts/.node-memory-exports.sh && BUILD_TARGET=client npx tsx ../script/build.ts && node ../scripts/verify-dist-artifacts.mjs",
    "build:heavy": "node scripts/ensure-node-memory.mjs && . ./scripts/.node-memory-exports.sh && BUILD_TARGET=heavy RUN_HEAVY_BUILD_TASKS=1 npx tsx ../script/build.ts && node ../scripts/verify-dist-artifacts.mjs",
    "content:export:question-banks": "tsx ../scripts/export-question-bank-json.ts",
    "start": "node scripts/ensure-node-memory.mjs && . ./scripts/.node-memory-exports.sh && node scripts/start-standalone.mjs"
  }
}
