    "ops:question-bank-diagnostics": "tsx scripts/report-question-bank-diagnostics.ts",
    "ops:question-bank-coverage": "tsx scripts/report-question-bank-coverage.ts",
    "ops:exam-blueprint-coverage": "tsx scripts/report-exam-blueprint-coverage.ts",
    "ops:exam-coverage-audit": "tsx scripts/run-exam-coverage-audit.ts",
    "ops:app-visible-counts": "tsx scripts/report-app-visible-content-counts.ts",
    "ops:admin-dashboard": "tsx scripts/report-admin-operations-dashboard.ts",
    "ops:learning-loop-audit": "tsx scripts/audit-learning-loop-sample.ts",
    "db:ensure-admin": "tsx scripts/ensure-admin-user.ts",
    "db:bootstrap-if-empty": "tsx scripts/bootstrap-admin-if-empty.ts",
