    "content:validate-topic-map": "node scripts/validate-master-topic-map.mjs",
    "content:blog-bulk-schedule": "node scripts/blog-bulk-schedule.mjs",
    "content:audit": "tsx scripts/content-audit-authoritative.ts",
    "import:blog": "tsx scripts/import-blog.ts",
    "import:content-items": "tsx scripts/import-content-items-json.ts",
    "import:replit-data": "tsx scripts/import-replit-data.ts",
