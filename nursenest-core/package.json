{
  "name": "nursenest-core",
  "version": "0.1.0",
  "private": true,
  "overrides": {
    "next-auth": {
      "@auth/core": "0.37.2"
    }
  },
  "scripts": {
    "dev": "TMPDIR=${TMPDIR:-/tmp} next dev",
    "build": "node scripts/check-disk-before-build.mjs && prisma generate && TMPDIR=${TMPDIR:-/tmp} next build",
    "build:deploy": "node scripts/check-disk-before-build.mjs && prisma generate && TMPDIR=${TMPDIR:-/tmp} next build && node scripts/post-build-prune.mjs",
    "start": "NODE_ENV=production next start -H 0.0.0.0 -p ${PORT:-3000}",
    "lint": "eslint",
    "generate:marketing-assets": "node scripts/generate-marketing-assets.mjs",
    "generate:brand-logos": "node scripts/build-transparent-theme-logos.mjs",
    "generate:theme-logos": "npx tsx scripts/generate-theme-logos-from-registry.ts",
    "generate:favicon": "node scripts/build-favicon-from-leaf.mjs",
    "generate:education-inventory": "node scripts/build-education-image-inventory.mjs",
    "i18n:generate-from-en": "node scripts/generate-locales-from-en.mjs",
    "i18n:merge-locale-ts-extras": "node scripts/generate-locales-from-en.mjs --merge-ts-only",
    "i18n:nav-parity-audit": "node scripts/nav-i18n-parity.mjs audit",
    "i18n:nav-parity-fill": "node scripts/nav-i18n-parity.mjs fill",
    "i18n:nav-parity-verify": "node scripts/nav-i18n-parity.mjs verify",
    "i18n:validate-nav": "node scripts/validate-nav-i18n.mjs",
