    "test:breadcrumbs": "tsx --test src/lib/seo/pathway-breadcrumbs.test.ts src/lib/seo/pathway-programmatic-seo.test.ts src/lib/exam-pathways/programmatic-slug-redirects.test.ts",
    "test:content-quality": "tsx --test src/lib/content-quality/plain-text.test.ts",
    "test:question-bank": "tsx --test src/lib/questions/question-bank-taxonomy.test.ts src/lib/questions/adaptive-question-selection.test.ts",
    "test:middleware": "tsx --test src/middleware.test.ts",
    "test:server-features": "tsx --test src/lib/observability/server-feature-tags.test.ts",
    "test:cat-blueprint": "tsx --test src/lib/practice-tests/cat-practice-post-helpers.test.ts src/lib/exams/cat-blueprint-mapping-quality.test.ts src/lib/exams/cat-blueprint-thresholds.test.ts src/lib/exams/cat-engine-blueprint.test.ts src/lib/exams/cat-exam-simulation-flags.test.ts",
    "clean:next": "rm -rf .next",
    "clean:build": "rm -rf .next dist build out",
    "verify:auth-db": "tsx scripts/verify-auth-db.ts",
    "disk:audit": "node scripts/disk-audit.mjs",
    "build:risk-audit": "tsx scripts/build-risk-audit.ts",
    "storage:check": "node scripts/storage-guardrails.mjs",
    "verify:theme-logos": "node scripts/verify-theme-logos.mjs",
    "storage:check:strict": "node scripts/storage-guardrails.mjs --strict",
    "ops:storage-report": "tsx scripts/storage-report.ts",
    "ops:cleanup-spaces-orphans": "tsx scripts/cleanup-spaces-orphans.ts",
