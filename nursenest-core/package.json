{
  "name": "nursenest-core",
  "version": "0.1.0",
  "private": true,
  "overrides": {
    "next-auth": {
      "@auth/core": "0.37.2"
    }
  },
  "scripts": {
    "dev": "TMPDIR=${TMPDIR:-/tmp} next dev",
    "build": "node scripts/check-disk-before-build.mjs && prisma generate && TMPDIR=${TMPDIR:-/tmp} next build",
    "build:deploy": "node scripts/check-disk-before-build.mjs && prisma generate && TMPDIR=${TMPDIR:-/tmp} next build && node scripts/post-build-prune.mjs",
    "start": "NODE_ENV=production next start -H 0.0.0.0 -p ${PORT:-3000}",
    "lint": "eslint",
    "generate:marketing-assets": "node scripts/generate-marketing-assets.mjs",
    "db:generate": "prisma generate",
    "db:deploy": "prisma migrate deploy",
    "db:validate": "prisma validate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed-pathway-lessons": "tsx scripts/seed-pathway-lessons-from-catalog.ts",
    "ops:pathway-lesson-sources": "tsx scripts/report-pathway-lesson-sources.ts",
    "ops:pathway-lesson-translations": "tsx scripts/report-pathway-lesson-translations.ts",
    "ops:question-bank-diagnostics": "tsx scripts/report-question-bank-diagnostics.ts",
    "ops:admin-dashboard": "tsx scripts/report-admin-operations-dashboard.ts",
    "db:ensure-admin": "tsx scripts/ensure-admin-user.ts",
    "db:bootstrap-if-empty": "tsx scripts/bootstrap-admin-if-empty.ts",
    "db:sanity": "tsx scripts/db-sanity-check.ts",
    "db:verify-indexes": "tsx scripts/verify-required-db-indexes.ts",
    "admin:promote": "tsx scripts/ensure-admin-user.ts",
    "create-admin": "tsx scripts/create-admin.ts",
    "content:inventory": "tsx scripts/content-inventory.ts",
    "content:audit": "tsx scripts/content-audit-authoritative.ts",
    "import:blog": "tsx scripts/import-blog.ts",
    "export:blog-json": "tsx scripts/export-monolith-blog-to-json.ts",
    "db:rewrite-lesson-screenshots": "tsx scripts/rewrite-lesson-screenshot-urls.ts",
    "test:entitlements": "tsx --test src/lib/entitlements/*.test.ts",
    "test:pathway-lessons": "tsx --test src/lib/entitlements/country-code.test.ts src/lib/entitlements/subscription-plan.test.ts src/lib/exam-pathways/pathway-entitlements.test.ts src/lib/lessons/pathway-lesson-access.test.ts src/lib/lessons/pathway-lesson-loader.test.ts src/lib/lessons/pathway-lesson-preview-kind.test.ts",
    "test:breadcrumbs": "tsx --test src/lib/seo/pathway-breadcrumbs.test.ts src/lib/seo/pathway-programmatic-seo.test.ts src/lib/exam-pathways/programmatic-slug-redirects.test.ts",
    "test:middleware": "tsx --test src/middleware.test.ts",
    "clean:next": "rm -rf .next",
    "clean:build": "rm -rf .next dist build out",
    "verify:auth-db": "tsx scripts/verify-auth-db.ts",
    "disk:audit": "node scripts/disk-audit.mjs",
    "build:risk-audit": "tsx scripts/build-risk-audit.ts",
    "storage:check": "node scripts/storage-guardrails.mjs",
    "storage:check:strict": "node scripts/storage-guardrails.mjs --strict",
    "ops:storage-report": "tsx scripts/storage-report.ts",
    "ops:cleanup-spaces-orphans": "tsx scripts/cleanup-spaces-orphans.ts",
    "import:audit-nursing": "tsx scripts/audit-nursing-ai-cache.ts",
    "import:nursing-ai-cache": "tsx scripts/import-nursing-ai-cache.ts",
    "replit:spaces-pipeline": "node scripts/replit-export-spaces-pipeline.mjs",
    "import:replit-questions": "tsx scripts/import-replit-question-bank.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@auth/core": "0.37.2",
    "@prisma/client": "^6.7.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@sentry/nextjs": "^10.46.0",
    "bcryptjs": "^2.4.3",
    "lucide-react": "^0.562.0",
    "next": "16.2.1",
    "next-auth": "^5.0.0-beta.25",
    "next-themes": "^0.4.6",
    "posthog-js": "^1.364.1",
    "posthog-node": "^5.28.8",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "sharp": "^0.34.1",
    "stripe": "^18.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "mime-types": "^2.1.35",
    "pg": "^8.20.0",
    "prisma": "^6.7.0",
    "tailwindcss": "^4",
    "tsx": "^4.19.4",
    "typescript": "^5"
  }
}
