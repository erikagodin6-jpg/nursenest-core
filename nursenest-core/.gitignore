# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# -----------------------------------------------------------------------------
# Canonical patterns (deploy hygiene — keep repo root .gitignore aligned)
# -----------------------------------------------------------------------------
node_modules/
.next/
.next/cache/
.env
.env.local
.env.*.local
*.log
external/
*.zip
*.tgz
*.tar
*.gz
.DS_Store
# -----------------------------------------------------------------------------
# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/
/playwright-report/
/blob-report/
# Playwright saved sessions (cookies); regenerated by setup projects
tests/e2e/.auth/

# next.js
/.next/
/out/

# production
/build

# misc
.cache/
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
.env.playwright.local
# Safe templates (placeholders only) — must never contain real secrets
!.env.example
!.env.playwright.example
!.env*.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local import pipeline output (do not commit)
nursing-import-quarantine.jsonl
/data/import-checkpoints/
/data/import-checkpoints/nurse-nest-legacy.json
/data/import-quarantine/nurse-nest/

# NP spine↔DB alignment dry-run output (large; use --out to override)
/data/reports/pathway-lessons/np-db-alignment-report.dry-run.json

# Replit → Spaces pipeline (extract + upload manifests)
.replit-export-staging/
.replit-spaces-upload-manifest.json
.replit-spaces-pipeline-report.json

# Local exports / downloads / DB scratch
admin-export/
downloads/
local-export/
*.sqlite
*.sqlite3

# Cursor local state (keep rules in repo; ignore machine-specific if present)
.cursor/*.log

# Storybook / Vite caches (if used locally)
storybook-static/
dist/

# Sentry / build telemetry dumps
.sentry-native/
