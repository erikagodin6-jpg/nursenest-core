model Flashcard {
  id              String              @id @default(cuid())
  front           String
  back            String
  country         CountryCode
  tier            TierCode
  status          ContentStatus       @default(DRAFT)
  examFamily      ExamFamily          @default(GENERIC)
  categoryId      String
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  lessonId        String?
  deckId          String?             @map("deck_id")
  positionInDeck  Int                 @default(0) @map("position_in_deck")
  /// *
  /// * Stable deduplication key for pipeline-generated cards.
  /// * Format: "{sourceType}:{sourceId}" — e.g. "exam_q:abc123", "lesson:cardio-basics:intro:0"
  /// * Null for manually authored cards. Unique so sync scripts can upsert without duplicating.
  sourceKey       String?             @unique(map: "flashcards_source_key_key") @map("source_key")
  category        Category            @relation(fields: [categoryId], references: [id])
  deck            FlashcardDeck?      @relation(fields: [deckId], references: [id])
