  lessonId        String?
  deckId          String?             @map("deck_id")
  positionInDeck  Int                 @default(0) @map("position_in_deck")
  /// *
  /// * Stable deduplication key for pipeline-generated cards.
  /// * Format: "{sourceType}:{sourceId}" — e.g. "exam_q:abc123", "lesson:cardio-basics:intro:0"
  /// * Null for manually authored cards. Unique so sync scripts can upsert without duplicating.
  sourceKey       String?             @unique(map: "flashcards_source_key_key") @map("source_key")
  /// * Optional link to canonical `ExamQuestion` (question-bank consolidation). When set, prefer bank fetch + unified grading.
  examQuestionId  String?             @map("exam_question_id") @db.VarChar(64)
  /// * When set with JSON fields, card is studied as a mini NCLEX item (stem + A–D + rationales).
  examItemKind       FlashcardItemKind? @map("exam_item_kind")
  questionStem       String?            @map("question_stem")
  /// * JSON: [{ "letter": "A", "text": "..." }, ...] — expect 3–4 options for published exam-style cards.
  answerOptions      Json?              @map("answer_options")
  correctAnswer      String?            @map("correct_answer")
  rationaleCorrect   String?            @map("rationale_correct")
  /// * JSON: [{ "letter": "B", "rationale": "..." }, ...] — one entry per distractor letter.
  rationaleIncorrect Json?              @map("rationale_incorrect")
  category        Category            @relation(fields: [categoryId], references: [id])
  deck            FlashcardDeck?      @relation(fields: [deckId], references: [id])
  progressRecords FlashcardProgress[]
  /// * Canonical answer options (preferred over JSON answerOptions for new cards; JSON is the fallback for legacy rows).
  options         FlashcardOption[]

  @@index([status, country, tier])
  @@index([deckId, positionInDeck])
  @@index([deckId, status])
  @@index([lessonId])
  @@index([examQuestionId])
}

/// * Canonical relational answer options — preferred persistence for MCQ and SATA cards.
/// * Replaces the JSON answerOptions + rationaleIncorrect fields for new content.
/// * Legacy cards without rows fall back to JSON fields transparently.
model FlashcardOption {
  id                 String    @id @default(cuid())
  flashcardId        String    @map("flashcard_id")
  /// * Option key within the card: "A", "B", "C", "D" for MCQ/SATA.
  /// * Extended namespaces for future types: "action:A", "condition:1" (bowtie), "row:1:col:A" (matrix).
  optionKey          String    @map("option_key")
  content            String
  isCorrect          Boolean   @default(false) @map("is_correct")
  /// * Teaching rationale shown after reveal. Required for wrong answers; optional for correct options (card-level rationaleCorrect is used).
  rationale          String?
  displayOrder       Int       @default(0) @map("display_order")
  /// * Denormalized aggregate: how many times this option was selected (any user, all time). Updated atomically on each review.
  selectCount        Int       @default(0) @map("select_count")
  /// * Denormalized aggregate: how many times this option was selected by a user who got the card correct (SATA: partial credit counts).
  correctSelectCount Int       @default(0) @map("correct_select_count")
  flashcard          Flashcard @relation(fields: [flashcardId], references: [id], onDelete: Cascade)

  @@unique([flashcardId, optionKey])
  @@index([flashcardId])
  @@map("flashcard_options")
}

/// Option-level telemetry for distractor analytics, misconception heatmaps, and remediation targeting.
/// No FK to FlashcardOption intentionally — append-friendly at ingestion scale.
model FlashcardOptionResponse {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  flashcardId String   @map("flashcard_id")
  optionKey   String   @map("option_key") @db.VarChar(8)
  wasCorrect  Boolean  @map("was_correct")
  sessionId   String?  @map("session_id")
  respondedAt DateTime @default(now()) @map("responded_at")

  @@index([flashcardId, optionKey])
  @@index([userId, flashcardId])
  @@map("flashcard_option_responses")
}

model FlashcardProgress {
  id             String    @id @default(cuid())
  userId         String    @map("user_id")
  flashcardId    String    @map("flashcard_id")
  easeFactor     Float     @default(2.5) @map("ease_factor")
  intervalDays   Int       @default(0) @map("interval_days")
  repetitions    Int       @default(0)
  nextReviewAt   DateTime? @map("next_review_at")
  lastQuality    Int?      @map("last_quality")
  lastReviewedAt DateTime? @map("last_reviewed_at")
  /// * Incremented each time the card is rated "again" after it has been learned (repetitions > 0). Used to surface lapsing cards in the weak queue.
  lapses         Int       @default(0)
  flashcard      Flashcard @relation(fields: [flashcardId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, flashcardId])
  @@index([userId, nextReviewAt])
  @@index([userId, lapses])
  @@index([flashcardId])
  @@map("flashcard_progress")
}

model FlashcardStudySession {
  id        String        @id @default(cuid())
  userId    String        @map("user_id")
  deckId    String        @map("deck_id")
  queueIds  Json          @map("queue_ids")
  cursor    Int           @default(0)
  updatedAt DateTime      @updatedAt @map("updated_at")
  deck      FlashcardDeck @relation(fields: [deckId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deckId])
  @@index([userId])
  @@map("flashcard_study_sessions")
}

model FlashcardUserStats {
  userId             String    @id @map("user_id")
  currentStreak      Int       @default(0) @map("current_streak")
  longestStreak      Int       @default(0) @map("longest_streak")
  lastStudyDate      DateTime? @map("last_study_date")
  cardsReviewedTotal Int       @default(0) @map("cards_reviewed_total")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("flashcard_user_stats")
}

/// * Learner-owned verified study card decks (Quizlet-style, NurseNest-governed — not open free-text publishing).
model VerifiedStudyDeck {
  id                  String                           @id @default(cuid())
  title               String                           @db.VarChar(200)
  description         String?                          @db.VarChar(2000)
  pathwayId           String                           @map("pathway_id") @db.VarChar(64)
  professionKey       String?                          @map("profession_key") @db.VarChar(64)
  canonicalCategoryId String?                          @map("canonical_category_id") @db.VarChar(64)
  visibility          VerifiedStudyDeckVisibility      @default(PRIVATE)
  verificationStatus  VerifiedStudyVerificationStatus  @default(UNVERIFIED) @map("verification_status")
  moderationStatus    VerifiedStudyModerationStatus     @default(APPROVED) @map("moderation_status")
  sourceType          VerifiedStudySourceType           @default(USER_CREATED) @map("source_type")
  nurseNestVerified   Boolean                           @default(false) @map("nurse_nest_verified")
  ownerId             String                            @map("owner_id")
  publishedAt         DateTime?                         @map("published_at")
  /// * Secret segment for UNLISTED decks (never user PII).
  unlistedSlug        String?                           @unique @map("unlisted_slug") @db.VarChar(48)
  legacyImportBatch   String?                           @map("legacy_import_batch") @db.VarChar(80)
  duplicateOfDeckId   String?                           @map("duplicate_of_deck_id")
  createdAt           DateTime                          @default(now()) @map("created_at")
  updatedAt           DateTime                          @updatedAt @map("updated_at")

  owner        User                      @relation("VerifiedStudyDeckOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  duplicateOf  VerifiedStudyDeck?      @relation("VerifiedStudyDeckDuplicateOf", fields: [duplicateOfDeckId], references: [id], onDelete: SetNull)
  duplicates   VerifiedStudyDeck[]      @relation("VerifiedStudyDeckDuplicateOf")
  cards        VerifiedStudyCard[]
  shares       VerifiedStudyDeckShare[]
  reports      VerifiedStudyDeckReport[]

  @@index([ownerId, pathwayId])
  @@index([pathwayId, visibility, moderationStatus])
  @@index([visibility, moderationStatus, verificationStatus])
  @@map("verified_study_decks")
}

model VerifiedStudyDeckShare {
  id           String                           @id @default(cuid())
  deckId       String                           @map("deck_id")
  targetUserId String?                          @map("target_user_id")
  targetEmail  String?                          @map("target_email") @db.VarChar(320)
  permission   VerifiedStudyDeckSharePermission @default(VIEW)
  invitedById  String                           @map("invited_by_id")
  createdAt    DateTime                         @default(now()) @map("created_at")

  deck       VerifiedStudyDeck @relation(fields: [deckId], references: [id], onDelete: Cascade)
  targetUser User?             @relation("VerifiedStudyDeckShareTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  invitedBy  User              @relation("VerifiedStudyDeckShareInvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([deckId])
  @@index([targetUserId])
  @@index([targetEmail])
  @@map("verified_study_deck_shares")
}

model VerifiedStudyCard {
  id                    String                          @id @default(cuid())
  deckId                String                          @map("deck_id")
  position              Int                             @default(0)
  promptFront           String                          @map("prompt_front") @db.Text
  answerBack            String                          @map("answer_back") @db.Text
  rationale             String?                         @db.Text
  clinicalPearl         String?                         @map("clinical_pearl") @db.Text
  canonicalCategoryId   String?                         @map("canonical_category_id") @db.VarChar(64)
  relatedLessonSlug     String?                         @map("related_lesson_slug") @db.VarChar(200)
  relatedExamQuestionId String?                         @map("related_exam_question_id") @db.VarChar(64)
  referencesJson        Json                            @default("[]") @map("references_json")
  verificationStatus    VerifiedStudyVerificationStatus @default(UNVERIFIED) @map("verification_status")
  lastVerifiedAt        DateTime?                       @map("last_verified_at")
  aiRejectedReason      String?                         @map("ai_rejected_reason") @db.VarChar(500)
  createdAt             DateTime                        @default(now()) @map("created_at")
  updatedAt             DateTime                        @updatedAt @map("updated_at")

  deck     VerifiedStudyDeck           @relation(fields: [deckId], references: [id], onDelete: Cascade)
  progress VerifiedStudyCardProgress[]

  @@index([deckId, position])
  @@map("verified_study_cards")
}

