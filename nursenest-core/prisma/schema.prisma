  adaptiveState Json?
  updatedAt     DateTime           @updatedAt
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, updatedAt])
  @@index([userId, updatedAt(sort: Desc)])
  @@index([userId, status, completedAt(sort: Desc)])
  @@map("practice_tests")
