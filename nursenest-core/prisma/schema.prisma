/** Optional: lesson enhancement / repair drafts — not promoted until review. */
model GeneratedLessonDraft {
  id               String   @id @default(cuid())
  jobId            String?
  job              AiGenerationJob? @relation(fields: [jobId], references: [id], onDelete: SetNull)
  tool             String
  /** Fingerprint for duplicate detection (same as payload `batchTopicKey`); indexed for exact lookups. */
  lessonBatchTopicKey String? @db.VarChar(40)
  payloadJson      Json
  normalizedJson   Json?
  validationJson   Json
  reviewStatus     DraftReviewStatus @default(PENDING_REVIEW)
  reviewNotes      String?  @db.Text
  reviewedById     String?
  reviewedBy       User?    @relation("LessonDraftReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt       DateTime?
  promotedEntityId String?
  promotedAt       DateTime?
  titlePreview     String?
  targetLessonId   String?
  targetContent      ContentItem? @relation("LessonEnhancementTarget", fields: [targetLessonId], references: [id], onDelete: SetNull)
  sourcePrompt     String   @db.Text
  model            String
  createdById      String
  createdBy        User     @relation("LessonDraftCreatedBy", fields: [createdById], references: [id])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  lessonBatchQueueItems LessonBatchQueueItem[] @relation("LessonBatchGeneratedDraft")

  @@index([reviewStatus, createdAt])
  @@index([jobId])
  @@index([lessonBatchTopicKey])
}

/**
 * Localized display overlays for canonical English educational content (questions, pathway lessons, flashcards).
 * English remains on core rows / catalog JSON; overlays attach by stable `sourceId` + `locale`.
 * Only `PUBLISHED` rows are merged at read time (see `educational-translation-db.ts`).
 */
enum EducationalTranslationSourceKind {
  EXAM_QUESTION
  PATHWAY_LESSON
  FLASHCARD_DECK
  FLASHCARD
  FLASHCARD_TAG
}

enum EducationalTranslationStatus {
  DRAFT
  REVIEWED
  PUBLISHED
}

model EducationalTranslationOverlay {
  id         String                         @id @default(cuid())
  sourceKind EducationalTranslationSourceKind @map("source_kind")
  /**
   * Stable key: `ExamQuestion.id`, `pathwayId:slug` for pathway lessons, `FlashcardDeck.id`, `Flashcard.id`, `FlashcardTag.id`.
   */
  sourceId   String                         @map("source_id") @db.VarChar(512)
  locale     String                         @db.VarChar(32)
  status     EducationalTranslationStatus   @default(DRAFT)
  /** JSON payload — shape matches file-based overlays per kind (never replaces grading keys). */
  payload    Json
  reviewedAt DateTime?                      @map("reviewed_at")
  publishedAt DateTime?                     @map("published_at")
  createdAt  DateTime                       @default(now()) @map("created_at")
  updatedAt  DateTime                       @updatedAt @map("updated_at")

  @@unique([sourceKind, sourceId, locale])
  @@index([locale, status, sourceKind])
  @@index([sourceKind, status])
  @@map("educational_translation_overlays")
}
