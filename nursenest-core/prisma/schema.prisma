  tool             String
  batchId          String?
  payloadJson      Json
  normalizedJson   Json?
  validationJson   Json
  reviewStatus     DraftReviewStatus @default(PENDING_REVIEW)
  reviewNotes      String?
  reviewedById     String?
  reviewedAt       DateTime?
  promotedEntityId String?
  promotedAt       DateTime?
