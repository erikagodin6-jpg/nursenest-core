// ─────────────────────────────────────────────────────────────────────────────
// CANONICAL TOPIC GRAPH
//
// Architecture: canonical clinical foundation + pathway overlays
//
//   CanonicalTopic            — top-level topic node (COPD, Heart Failure, …)
//   CanonicalTopicSharedSection — reusable clinical foundation blocks
//                               (pathophysiology, core S/S, diagnostics)
//                               shared across all tiers/countries for a topic
//   PathwayLesson             — existing model; gains `canonicalTopicId` FK
//                               Tier/exam/country-specific overlay sections
//                               live inside PathwayLesson.sections as before
//
// Rendering pipeline:
//   1. Load CanonicalTopicSharedSection for the topic's foundation sections
//   2. Load PathwayLesson (tier/exam/country specific)
//   3. Merge: shared sections are injected unless the lesson has an override
//      section of the same `kind`
//   4. Apply educational overlay (locale/i18n)
//   5. Rewrite deprecated slugs
//   6. Evaluate structural gate
//
// This eliminates the NP triplication problem at the content layer:
// instead of 3 identical lesson rows, one canonical shared section
// is referenced by all three pathway lessons.
// ─────────────────────────────────────────────────────────────────────────────

/// * Top-level clinical topic node connecting lessons, flashcards, questions, and study plans.
/// * One node per clinical condition (COPD, Heart Failure, Diabetes, …) regardless of tier/country.
model CanonicalTopic {
  id               String   @id @default(cuid())
  /// * Stable, kebab-case key used as the join key across cross-surface systems.
  /// * Examples: "copd", "heart-failure", "type-2-diabetes", "aki"
  topicKey         String   @unique @map("topic_key") @db.VarChar(120)
  displayName      String   @map("display_name")
  bodySystem       String?  @map("body_system") @db.VarChar(80)
  clinicalCategory String?  @map("clinical_category") @db.VarChar(80)

  // ── Cross-surface connection keys (future-ready) ──────────────────────
  /// * Flashcard deck topic key for this condition.
  flashcardTopicKey    String? @map("flashcard_topic_key") @db.VarChar(120)
  /// * Practice question topic tag for this condition.
  practiceTopicKey     String? @map("practice_topic_key") @db.VarChar(120)
  /// * CAT pool key for adaptive testing.
  catPoolKey           String? @map("cat_pool_key") @db.VarChar(120)
  /// * Remediation tag used by the remediation engine.
  remediationTagKey    String? @map("remediation_tag_key") @db.VarChar(120)
  /// * Blog topic slug for SEO cross-linking.
  blogTopicKey         String? @map("blog_topic_key") @db.VarChar(120)

  // ── Relations ─────────────────────────────────────────────────────────
  sharedSections   CanonicalTopicSharedSection[]
  lessons          PathwayLesson[]

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("canonical_topics")
}

/// * Reusable clinical foundation sections shared across all tier/country variants of a topic.
/// * These contain medical-science facts (pathophysiology, core S/S, diagnostics, anatomy)
/// * that are tier-agnostic. Tier/exam/country-specific content stays in PathwayLesson.sections.
/// *
/// * Rendering: injected before pathway-lesson sections unless the lesson has
/// * a same-kind override section (lesson section wins on kind conflict).
model CanonicalTopicSharedSection {
  id               String         @id @default(cuid())
  canonicalTopicId String         @map("canonical_topic_id")
  canonicalTopic   CanonicalTopic @relation(fields: [canonicalTopicId], references: [id])

  /// * Section kind — must match PathwayLessonSectionKind enum values.
  /// * Shared sections are limited to: pathophysiology_overview, signs_symptoms,
  /// * labs_diagnostics, anatomy (future). Tier-specific kinds stay in PathwayLesson.
  kind             String @db.VarChar(80)
  heading          String
  body             String @db.Text

  /// * Which tiers this section applies to. Empty = all tiers.
  /// * Use to restrict a shared section to specific tiers (e.g. only RPN/PN).
  applicableTiers     String[] @default([]) @map("applicable_tiers")
  /// * Which country codes this section applies to. Empty = all countries.
  applicableCountries String[] @default([]) @map("applicable_countries")

  contentVersion   Int      @default(1) @map("content_version")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@index([canonicalTopicId, kind])
  @@map("canonical_topic_shared_sections")
}

/// *
/// * Marketing exam-pathway lessons (`/[locale]/[slug]/[exam]/lessons/...`).
/// * The loader prefers published rows for each `pathwayId` and falls back to `catalog.json` when that pathway has no DB rows.
model PathwayLesson {
  id                   String        @id @default(cuid())
  pathwayId            String        @map("pathway_id")
  slug                 String
  title                String
  topic                String
  topicSlug            String        @map("topic_slug")
  bodySystem           String        @map("body_system")
  previewSectionCount  Int           @default(1) @map("preview_section_count")
  seoTitle             String        @map("seo_title")
  seoDescription       String        @map("seo_description")
  /// * Array of { id, heading, kind, body } — normalized to five canonical sections at read time.
  sections             Json
  /// * Denormalized from {@link evaluatePathwayLessonStructuralGate} at write/import/backfill — list surfaces can filter without loading `sections` JSON.
  structuralPublicComplete Boolean @default(false) @map("structural_public_complete")
  /// * Optional row-level filter; null means “follow pathway registry” (country implied by pathway).
  countryCode          CountryCode?  @map("country_code")
  tierCode             TierCode?     @map("tier_code")
  status               ContentStatus @default(PUBLISHED)
  sortOrder            Int           @default(0) @map("sort_order")
  /// * BCP 47-style language tag (`en`, `fr`, …). Default `en` for catalog imports.
  locale               String        @default("en")
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")
  countries            String[]      @default([])
  /// * Runtime region-aware lesson filtering metadata (single global lesson dataset).
  exams                String[]      @default([])
  priority             String        @default("medium")
  /// * Exam-specific yield metadata: [{ exam, yieldLevel, clinicalPriority? }].
  examMeta             Json          @default("[]") @map("exam_meta")
  /// * Allied profession discriminator for marketing / learner hubs (null = shared or registry-owned topic scope).
  alliedProfessionKey  String?       @map("allied_profession_key") @db.VarChar(64)
  content_version      Int           @default(1)
  published_at         DateTime?
  published_by_user_id String?
  User                 User?         @relation(fields: [published_by_user_id], references: [id])

  /// * Canonical lesson consolidation metadata.
  /// * canonicalLessonId: non-null means this row is a deprecated duplicate; the value is the ID of the canonical lesson to serve instead.
  canonicalLessonId    String?       @map("canonical_lesson_id")
  /// * Slugs of lessons that were merged INTO this lesson. Populated on the canonical lesson, not the deprecated ones.
  mergedFromSlugs      String[]      @default([]) @map("merged_from_slugs")
  /// * Timestamp when this lesson was deprecated/merged. Used to exclude from sitemap and hub indexes.
  deprecatedAt         DateTime?     @map("deprecated_at")
  /// * Redirect target slug for deprecated lessons. Used by middleware to issue 301 to canonical URL.
  redirectToSlug       String?       @map("redirect_to_slug") @db.VarChar(512)
  /// * True for intentional numbered spaced-repetition review lessons (e.g. "Cardiovascular: Review 11").
  /// * Excludes from duplicate detection; these are sequential content, not semantic duplicates.
  isReviewLesson       Boolean       @default(false) @map("is_review_lesson")

  /// * FK to CanonicalTopic — the clinical topic node shared across RN/RPN/NP/CA/US variants.
  /// * Multiple PathwayLessons share the same canonicalTopicId.
  /// * Null = not yet mapped to a topic node (legacy lessons during migration).
  canonicalTopicId     String?         @map("canonical_topic_id")
  canonicalTopic       CanonicalTopic? @relation(fields: [canonicalTopicId], references: [id])

  @@unique([pathwayId, slug, locale])
  @@unique([pathwayId, slug])
  @@index([pathwayId, status, sortOrder])
  @@index([pathwayId, locale, status, sortOrder])
  @@index([pathwayId, topicSlug, locale, status])
  @@index([pathwayId, locale, status, sortOrder], map: "pathway_lessons_pathway_locale_status_sort_idx")
  @@index([pathwayId, topicSlug, locale, status], map: "pathway_lessons_pathway_topic_locale_status_idx")
  @@index([canonicalLessonId], map: "pathway_lessons_canonical_lesson_idx")
  @@index([canonicalTopicId], map: "pathway_lessons_canonical_topic_idx")
  @@map("pathway_lessons")
}

