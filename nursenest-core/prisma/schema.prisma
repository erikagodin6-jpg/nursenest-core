  /// * Linear vs CAT; CAT uses `adaptiveState` for theta, difficulty history, incidents.
  examMode      String            @default("linear") @map("exam_mode")
  adaptiveState Json?             @map("adaptive_state")
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  timedMode     Boolean           @default(false)
  timeLimitSec  Int?
  elapsedMs     Int?
  attempt       ExamAttempt?      @relation("ExamSessionAttempt", fields: [attemptId], references: [id])
  exam          Exam?             @relation(fields: [examId], references: [id])
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, updatedAt(sort: Desc), createdAt(sort: Desc)])
  @@index([examId])
}

/// * Learner-built timed/untimed practice tests with saved progress and results.
model PracticeTest {
  id            String             @id @default(cuid())
  userId        String
  title         String?
  /// * Build params: topics, selectionMode, difficulty bounds, pathwayId, etc.
  config        Json
  questionIds   Json
  answers       Json               @default("{}")
  cursorIndex   Int                @default(0)
  status        PracticeTestStatus @default(IN_PROGRESS)
  timedMode     Boolean            @default(false)
  timeLimitSec  Int?
  elapsedMs     Int?
  startedAt     DateTime           @default(now())
  completedAt   DateTime?
  /// * Score, topic breakdown, weak areas — set when status = COMPLETED.
  results       Json?
