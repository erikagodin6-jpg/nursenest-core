/// * DB-backed queue for `/api/admin/lessons/ai-generate-batch` — enables atomic claim and item-level metrics.
model LessonBatchQueueItem {
  id                  String                     @id @default(cuid())
  jobId               String
  /// * Stable ordering within the batch (0-based).
  position            Int
  /// * Client-visible id (matches legacy JSON `itemId` / payload `batchItemId`).
  publicItemId        String                     @unique
  topic               String
  normalizedTopic     String
  batchTopicKey       String                     @db.VarChar(40)
  status              LessonBatchQueueItemStatus @default(PENDING)
  attemptCount        Int                        @default(0)
  lastError           String?
  lastAttemptAt       DateTime?
  completedAt         DateTime?
  skippedAt           DateTime?
  startedAt           DateTime?
  claimedByRequestId  String?                    @db.VarChar(128)
  revivedAt           DateTime?
  revivalCount        Int                        @default(0)
  generatedDraftId    String?
  /// * When status is SKIPPED_DUPLICATE — link to an existing draft with the same fingerprint.
  existingDraftId     String?
  generatedDraftTitle String?
  /// * When the row was moved to CANCELLED (batch canceled or stale revive on a canceled job).
  canceledAt          DateTime?
  generatedDraft      GeneratedLessonDraft?      @relation("LessonBatchGeneratedDraft", fields: [generatedDraftId], references: [id])
  job                 AiGenerationJob            @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, status, position])
  @@index([jobId, position])
  @@index([batchTopicKey])
  @@map("lesson_batch_queue_item")
}

/// * Audit trail for AI steps (granular events under a job).
