  jobId     String
  step      String
  detail    Json?
  createdAt DateTime        @default(now())
  job       AiGenerationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

model GeneratedQuestionDraft {
