}

model ExamAttempt {
  id          String       @id @default(cuid())
  userId      String
  examId      String
  score       Int
  total       Int
  createdAt   DateTime     @default(now())
  /// * Topic breakdown, per-item flags, timing — set on graded submits.
  results     Json?
  exam        Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  examSession ExamSession? @relation("ExamSessionAttempt")

