/// * Each (canonicalArticleId, locale, region) tuple is unique — one variant per
/// * locale/region combination per canonical article.
model LocalizedBlogArticle {
  id                       String              @id @default(cuid())
  canonicalArticleId       String
  locale                   String              @db.VarChar(10)
  region                   String              @db.VarChar(32)
  profession               String?             @db.VarChar(32)
  exam                     String?             @db.VarChar(48)
  sourceLanguage           String              @default("en") @db.VarChar(10)
  adaptationType           BlogAdaptationType  @default(ADAPTED)
  contentStatus            LocalizedBlogStatus @default(DRAFT)
  aiModelVersion           String?             @db.VarChar(64)
  aiPromptVersion          String?             @db.VarChar(32)
  localizedTitle           String
  localizedExcerpt         String
  localizedBody            String
  canonicalSlug            String              @db.VarChar(200)
  localizedSlug            String              @db.VarChar(200)
  localizedMetaTitle       String?
  localizedMetaDescription String?
  seoKeywordPrimary        String?
  seoKeywordSecondary      String[]            @default([])
  searchIntent             String?             @db.VarChar(48)
  hreflangJson             Json?
  canonicalUrl             String?
  targetAudience           String?             @db.VarChar(64)
  ctaVariant               String?             @db.VarChar(48)
  ctaText                  String?
  ctaHref                  String?
  internalLinkTargets      Json?
  complianceReviewRequired Boolean             @default(false)
  medicalReviewRequired    Boolean             @default(false)
  editorialReviewRequired  Boolean             @default(true)
  reviewFlags              String[]            @default([])
  editorialNotes           String?
  publishedAt              DateTime?
  scheduledAt              DateTime?
  rejectedAt               DateTime?
  rejectionReason          String?
  generationLog            Json                @default("[]")
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt
  canonicalArticle         BlogPost            @relation(fields: [canonicalArticleId], references: [id], onDelete: Cascade)

  @@unique([canonicalArticleId, locale, region])
  @@index([contentStatus, scheduledAt])
  @@index([region, locale, contentStatus])
  @@index([canonicalArticleId])
  @@index([localizedSlug])
  @@index([createdAt])
}

/// * Production `content_items` — lessons are `type = "lesson"`.
