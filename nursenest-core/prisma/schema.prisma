/// * Operational launch pipeline for one exam pathway or one global expansion region (`/exams/…`).
/// * Stages are team-controlled; advancing to READY_TO_PUBLISH is blocked server-side until automated checks pass.
enum PathwayLaunchWorkflowStage {
  DRAFT
  CONTENT_BUILD
  QA_REVIEW
  SEO_REVIEW
  READY_TO_PUBLISH
  PUBLISHED_LIVE
  POST_PUBLISH_VERIFY
}

/// * `targetKey` format: `pathway:{pathwayId}` or `region:{GlobalRegionSlug}` (e.g. `region:japan`).
model PathwayLaunchWorkflow {
  id           String                   @id @default(cuid())
  targetKey    String                   @unique @db.VarChar(128)
  stage        PathwayLaunchWorkflowStage @default(DRAFT)
  /// * Manual sign-offs: { "qaReviewed": true, "seoReviewed": true, "postPublishVerified": true }
  attestations Json                     @default("{}")
  /// * At most one row should be true — enforced in application code when setting focus.
  isTeamFocus  Boolean                  @default(false) @map("is_team_focus")
  notes        String?                  @db.Text
  createdAt    DateTime                 @default(now()) @map("created_at")
  updatedAt    DateTime                 @updatedAt @map("updated_at")
  updatedById  String?                @map("updated_by_id")

  @@index([stage])
  @@index([isTeamFocus])
  @@map("pathway_launch_workflows")
}
