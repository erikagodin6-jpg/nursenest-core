model content_entity_revisions {
  id                  String               @id
  entity_kind         ContentEntityKind
  entity_id           String               @db.VarChar(128)
  version             Int
  snapshot            Json
  snapshot_sha256     String               @db.VarChar(64)
  reason              String?              @db.VarChar(64)
  previous_version    Int?
  import_run_id       String?
  created_at          DateTime             @default(now())
  created_by_user_id  String?
  User                User?                @relation(fields: [created_by_user_id], references: [id])
  content_import_runs content_import_runs? @relation(fields: [import_run_id], references: [id])

  @@index([created_at(sort: Desc)])
  @@index([entity_kind, entity_id, version(sort: Desc)])
  @@index([import_run_id])
}

model content_import_runs {
  id                       String                     @id
  label                    String?                    @db.VarChar(200)
  source_kind              String                     @db.VarChar(64)
  status                   ContentImportRunStatus     @default(STARTED)
  started_at               DateTime                   @default(now())
  finished_at              DateTime?
  manifest                 Json                       @default("{}")
  report                   Json                       @default("{}")
  stats                    Json                       @default("{}")
  input_sha256             String?                    @db.VarChar(64)
  git_commit_sha           String?                    @db.VarChar(64)
  environment              String?                    @db.VarChar(32)
  error_message            String?                    @db.VarChar(2000)
  triggered_by_user_id     String?
  content_entity_revisions content_entity_revisions[]
  User                     User?                      @relation(fields: [triggered_by_user_id], references: [id])

  @@index([source_kind, started_at(sort: Desc)])
  @@index([status, started_at(sort: Desc)])
}

