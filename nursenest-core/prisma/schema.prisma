generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// Same database, **direct** connection for migrate/introspect (non-pooler). Optional; derived from `DATABASE_URL` when unset.
model User {
  id                            String                      @id @default(cuid())
  email                         String                      @unique
  /// * Lowercase login handle; optional. PostgreSQL allows multiple NULLs under UNIQUE.
  username                      String?                     @unique
  name                          String
  passwordHash                  String?
  role                          UserRole                    @default(LEARNER)
  country                       CountryCode
  tier                          TierCode
  examFocus                     String?
  studyGoal                     String?
  dailyStudyMinutes             Int?
  learnerPath                   String?
  onboardingCompletedAt         DateTime?
  freeQuestionViews             Int                         @default(0)
  freeLessonOpens               Int                         @default(0)
  createdAt                     DateTime                    @default(now())
  updatedAt                     DateTime                    @updatedAt
  /// * When tier is ALLIED, optional short profession key (e.g. paramedic, mlt) for scoped UX and recommendations.
  alliedProfessionKey           String?                     @db.VarChar(64)
  /// * Clinical display units: `metric` | `imperial` (optional; cookie/localStorage when unset).
  measurementPreference         String?                     @map("measurement_preference") @db.VarChar(16)
  /// * Bumped on password change/reset so JWTs can be invalidated without per-device session rows.
  credentialVersion             Int                         @default(0)
  /// * Free Pre-Nursing: optional target readiness / school start date (UTC midnight).
  preNursingTargetDate          DateTime?
  preNursingDatePlanType        PreNursingDatePlanType?
  preNursingGoalSetAt           DateTime?
  /// * Soft hint for marketing CTAs: rn | rpn | pn | np | unsure
  preNursingFuturePathwayHint   String?                     @db.VarChar(16)
  /// * When the user last acknowledged legal policies at subscription checkout (server timestamp).
  legalPoliciesAcceptedAt       DateTime?
  /// * Bundle id from `LEGAL_POLICY_BUNDLE_VERSION` at acceptance time.
  legalPoliciesVersion          String?                     @db.VarChar(32)
  trialStatus                   TrialStatus                 @default(NONE)
  trialUsedAt                   DateTime?
  trialStartedAt                DateTime?
  trialEndsAt                   DateTime?
  /// * Target graded bank questions per UTC day; null uses product default (see load-daily-question-goal-progress).
  dailyQuestionGoal             Int?
  /// * UTC calendar day for which `bankQuestionsGradedCount` applies.
  bankQuestionsGradedUtcDay     DateTime?                   @db.Date
  /// * Graded bank questions counted on `bankQuestionsGradedUtcDay`.
  bankQuestionsGradedCount      Int                         @default(0)
  /// * Calendar date the learner is targeting (UTC midnight stored).
  examDate                      DateTime?
  examDatePlanType              ExamDatePlanType?
  examGoalSetAt                 DateTime?
  /// * Optional pathway id from exam registry when the goal is pathway-specific (NP tracks, etc.).
  targetExamPathwayId           String?                     @db.VarChar(64)
  /// * Optional learner preference: light | steady | intensive — used for copy only, not hours math.
  studyCadencePreference        String?                     @db.VarChar(32)
  /// * User dismissed the baseline assessment prompt (non-blocking).
  baselineAssessmentSkippedAt   DateTime?
  /// * User finished the short baseline question set.
  baselineAssessmentCompletedAt DateTime?
  /// * Summary: { correctCount, totalQuestions, weakTopics: string[], at: string }
  baselineAssessmentSummary     Json?
  /// * Governed RN learner cognition envelope (versioned); see cognition-snapshot-migrations.ts.
  learnerCognitionEnvelope      Json?                       @map("learner_cognition_envelope")
  /// * Lowercase, trimmed email for dedup (dot-stripping, alias-insensitive).
  normalizedEmail               String?
  emailVerified                 Boolean                     @default(false)
  /// * How the account was created (credentials, google, etc.).
  authProvider                  String                      @default("credentials") @db.VarChar(32)
  signupIp                      String?                     @db.VarChar(64)
  lastLoginIp                   String?                     @db.VarChar(64)
  lastLoginAt                   DateTime?
  firstName                     String?                     @db.VarChar(100)
  lastName                      String?                     @db.VarChar(100)
  displayName                   String?                     @db.VarChar(200)
  /// * When false, dashboard and study-entry surfaces avoid adaptive next-step recommendations.
  enableAdaptivePlan            Boolean?                    @map("enable_adaptive_plan")
  /// * When false, spaced-repetition recommendations and due-review nudges are suppressed.
  enableSpacedRepetition        Boolean?                    @map("enable_spaced_repetition")
  /// * When false, confidence-driven grouping and review insights are hidden from learner-facing flows.
  enableConfidenceTracking      Boolean?                    @map("enable_confidence_tracking")
  /// * When false, lesson pre/post quiz prompts and modules stay hidden.
  enablePrePostQuizzes          Boolean?                    @map("enable_pre_post_quizzes")
  /// * When false, weakness heatmap surfaces are hidden.
  showHeatmap                   Boolean?                    @map("show_heatmap")
  /// * When false, advanced readiness and dashboard insight surfaces stay simplified.
  showAdvancedInsights          Boolean?                    @map("show_advanced_insights")
  /// * When false, weak-area nudges and prompt cards are suppressed.
  enableWeaknessAlerts          Boolean?                    @map("enable_weakness_alerts")
  /// * When false, forgetting-risk alerts and decay-oriented reminders are suppressed.
  enableDecayAlerts             Boolean?                    @map("enable_decay_alerts")
  /// * Default smart-session size for learner flows; null uses product default.
  preferredSessionLength        Int?                        @map("preferred_session_length")
  /// *
  /// * When false, guided lesson study loop (optional bank-backed pre/post quick check + review) stays off.
  /// * Null defaults to enabled in app normalization.
  lessonStudyLoopEnabled        Boolean?                    @map("lesson_study_loop_enabled")
  /// * Demo QA accounts: admin-only creation, no real billing (guards checkout/trial).
  isDemoUser                    Boolean                     @default(false) @map("is_demo_user")
  /// * When true, learner engagement / retention marketing emails are suppressed (account still receives security mail).
  emailEngagementOptOut         Boolean                     @default(false) @map("email_engagement_opt_out")
  aiGenerationJobs              AiGenerationJob[]           @relation("AiJobCreatedBy")
  baselineAssessmentAttempts    BaselineAssessmentAttempt[]
  blogBatchSchedules            BlogBatchSchedule[]
  blogDraftGenerationBatches    BlogDraftGenerationBatch[]
  blogArticleGenerationJobs     BlogArticleGenerationJob[]
  contentAutomationLogs         ContentAutomationLog[]
  emailNotificationLogs         EmailNotificationLog[]
  emailVerificationTokens       EmailVerificationToken[]
  oauthProviderLinks            OAuthProviderLink[]
  attempts                      ExamAttempt[]
  examSessions                  ExamSession[]
  flashcardDraftsCreated        GeneratedFlashcardDraft[]   @relation("FlashcardDraftCreatedBy")
  flashcardDraftsReviewed       GeneratedFlashcardDraft[]   @relation("FlashcardDraftReviewedBy")
  lessonDraftsCreated           GeneratedLessonDraft[]      @relation("LessonDraftCreatedBy")
  lessonDraftsReviewed          GeneratedLessonDraft[]      @relation("LessonDraftReviewedBy")
  questionDraftsCreated         GeneratedQuestionDraft[]    @relation("QuestionDraftCreatedBy")
  questionDraftsReviewed        GeneratedQuestionDraft[]    @relation("QuestionDraftReviewedBy")
  learnerNotes                  LearnerNote[]
  passwordResetTokens           PasswordResetToken[]
  progress                      Progress[]
  subscriptions                 Subscription[]
  trialDeviceBindings           TrialDeviceBinding[]
  feedbackReports               UserFeedbackReport[]
  topicStats                    UserTopicStat[]
  content_entity_revisions      content_entity_revisions[]
  content_import_runs           content_import_runs[]
  content_items                 ContentItem[]
  exam_questions                ExamQuestion[]
  flashcardProgress             FlashcardProgress[]
  flashcardStudySessions        FlashcardStudySession[]
  flashcardSessions             FlashcardSession[]
  flashcardAttempts             FlashcardAttempt[]
  flashcardMastery              FlashcardMastery[]
  flashcardUserStats            FlashcardUserStats?
  verifiedStudyDecksOwned       VerifiedStudyDeck[]         @relation("VerifiedStudyDeckOwner")
  verifiedStudyDeckSharesToMe   VerifiedStudyDeckShare[]     @relation("VerifiedStudyDeckShareTarget")
  verifiedStudyDeckSharesSent   VerifiedStudyDeckShare[]     @relation("VerifiedStudyDeckShareInvitedBy")
  verifiedStudyCardProgress     VerifiedStudyCardProgress[]
  verifiedStudyDeckReports      VerifiedStudyDeckReport[]    @relation("VerifiedStudyDeckReporter")
  clinicalNursingScenariosCreated ClinicalNursingScenario[]  @relation("ClinicalNursingScenarioAuthor")
  clinicalScenarioSimulationRuns ClinicalScenarioSimulationRun[]
  longitudinalCaseSessions      LongitudinalCaseSession[]
  mediaAssetsUploaded           MediaAsset[]                @relation("MediaAssetUploadedBy")
  pathway_lessons               PathwayLesson[]
  practiceTests                 PracticeTest[]
  premiumProtectionUserDays     PremiumProtectionUserDay[]
  abuseReviewsDismissed         ProtectionAbuseReview[]     @relation("ProtectionAbuseReviewDismissedBy")
  protectionAbuseReviews        ProtectionAbuseReview[]
  inlineContentEdits            InlineContentEntry[]   @relation("InlineContentUpdatedBy")
  marketingPublicContentOverrides         MarketingPublicContentOverride[]
  marketingPublicContentOverrideRevisions MarketingPublicContentOverrideRevision[]
  remediationEvents                       UserRemediationEvent[]
  remediationQueueItems                   UserRemediationQueue[]
  learnerSessionActivities                LearnerSessionActivity[]
  learnerSessionIpObservations            LearnerSessionIpObservation[]
  printableProductsCreated                  PrintableProduct[]         @relation("PrintableProductCreatedBy")
  printableProductsUpdated                  PrintableProduct[]         @relation("PrintableProductUpdatedBy")
  printableDownloadEvents                   PrintableDownloadEvent[]
  printableAccesses                         PrintableAccess[]
  examQuestionPracticeAnswerAttempts        ExamQuestionPracticeAnswerAttempt[]
  ecgVideoQuestionPracticeAnswerAttempts    EcgVideoQuestionPracticeAnswerAttempt[]
  socialPrivacySetting                      SocialPrivacySetting?
  socialInviteCodes                         SocialInviteCode[]
  socialConnectionsRequested                SocialConnection[]            @relation("SocialConnectionRequester")
  socialConnectionsReceived                 SocialConnection[]            @relation("SocialConnectionAddressee")
  socialChallengesCreated                   SocialChallenge[]             @relation("SocialChallengeCreator")
  socialChallengeParticipants               SocialChallengeParticipant[]
  socialGroupsCreated                       SocialGroup[]                 @relation("SocialGroupCreatedBy")
  socialGroupsOwned                         SocialGroup[]                 @relation("SocialGroupOwner")
  socialGroupMemberships                    SocialGroupMembership[]
  socialStatSnapshots                       SocialStatSnapshot[]

  // ── Account lifecycle / inactivity management ──────────────────────────────
  /// * Exempt from automatic inactivity deletion regardless of role/tier.
  ///   Set manually by admins for special accounts (journalists, partners, etc.).
  isDeletionExempt              Boolean                     @default(false) @map("is_deletion_exempt")
  /// * Timestamp used as the baseline for inactivity calculation.
  ///   Set to the user's last real activity; reset on login/activity to NULL.
  inactivityBaselineAt          DateTime?                   @map("inactivity_baseline_at")
  /// * First warning email sent (45 days inactive for free; 135 days for engaged).
  warning1SentAt                DateTime?                   @map("warning1_sent_at")
  /// * Second warning email sent (53 / 143 days inactive).
  warning2SentAt                DateTime?                   @map("warning2_sent_at")
  /// * Final warning email sent (59 / 149 days inactive).
  warning3SentAt                DateTime?                   @map("warning3_sent_at")
  /// * Timestamp when account was soft-deleted (60 / 150 days inactive).
  ///   Non-null → account is soft-deleted; login blocked with recovery message.
  deletedAt                     DateTime?                   @map("deleted_at")
  /// * When the soft-delete is scheduled to escalate to permanent purge (deletedAt + 90 days).
  scheduledPermanentDeletionAt  DateTime?                   @map("scheduled_permanent_deletion_at")
  /// * Timestamp of permanent purge (PII cleared; row retained for audit).
  permanentlyPurgedAt           DateTime?                   @map("permanently_purged_at")
  /// * Human-readable last warning type sent for audit trail.
  lastLifecycleEmailType        String?                     @map("last_lifecycle_email_type") @db.VarChar(64)

  @@index([alliedProfessionKey])
  @@index([normalizedEmail])
  @@index([isDemoUser])
  @@index([deletedAt])
  @@index([scheduledPermanentDeletionAt])
}

/// * Admin-managed binary assets on Spaces (blogs, lessons, marketing).
model MediaAsset {
  id             String    @id @default(cuid())
  publicUrl      String    @unique
  storageKey     String    @unique
  filename       String
  mimeType       String
  kind           String    @default("image") @db.VarChar(16)
  fileSizeBytes  Int
  width          Int?
  height         Int?
  altText        String?
  tags           String[]  @default([])
  uploadedById   String?
  /// * Best-effort count from last usage scan (null = never scanned).
  usageRefCount  Int?
  usageRefs      Json?
  usageScannedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  uploadedBy     User?     @relation("MediaAssetUploadedBy", fields: [uploadedById], references: [id])
  printableProductsAsFile      PrintableProduct[] @relation("PrintableProductFileAsset")
  printableProductsAsThumbnail PrintableProduct[] @relation("PrintableProductThumbnailAsset")

  @@index([createdAt(sort: Desc)])
  @@index([kind])
  @@index([mimeType])
  @@map("media_assets")
}

enum PrintableDownloadSource {
  LEARNER
  ADMIN_PREVIEW
  PURCHASE
  SUBSCRIPTION
}

enum PrintableAccessSource {
  PURCHASE
  SUBSCRIPTION
  ADMIN_GRANT
  FREE
}

/// * Admin-managed downloadable printables (PDF) — binaries live in `MediaAsset` / Spaces, not in DB.
model PrintableProduct {
  id                String   @id @default(cuid())
  slug              String   @unique @db.VarChar(160)
  title             String   @db.VarChar(512)
  description       String   @db.Text
  category          String   @db.VarChar(128)
  pathwayId         String   @map("pathway_id") @db.VarChar(64)
  roleTrack         String   @map("role_track") @db.VarChar(64)
  fileAssetId       String   @map("file_asset_id")
  thumbnailAssetId  String?  @map("thumbnail_asset_id")
  priceCents        Int      @default(0) @map("price_cents")
  currency          String   @default("usd") @db.VarChar(8)
  isFree            Boolean  @default(false) @map("is_free")
  isPremiumIncluded Boolean  @default(false) @map("is_premium_included")
  isPublished       Boolean  @default(false) @map("is_published")
  version           Int      @default(1)
  createdByUserId   String?  @map("created_by_user_id")
  updatedByUserId   String?  @map("updated_by_user_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  fileAsset      MediaAsset @relation("PrintableProductFileAsset", fields: [fileAssetId], references: [id], onDelete: Restrict)
  thumbnailAsset MediaAsset? @relation("PrintableProductThumbnailAsset", fields: [thumbnailAssetId], references: [id], onDelete: SetNull)
  createdBy      User?      @relation("PrintableProductCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy      User?      @relation("PrintableProductUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  downloads      PrintableDownloadEvent[]
  accesses       PrintableAccess[]

  @@index([pathwayId])
  @@index([isPublished])
  @@index([category])
  @@map("printable_products")
}

model PrintableDownloadEvent {
  id                 String                  @id @default(cuid())
  printableProductId String                  @map("printable_product_id")
  userId             String?                 @map("user_id")
  pathwayId          String?                 @map("pathway_id") @db.VarChar(64)
  source             PrintableDownloadSource
  downloadedAt       DateTime                @default(now()) @map("downloaded_at")
  userAgentHash      String?                 @map("user_agent_hash") @db.VarChar(128)
  ipHash             String?                 @map("ip_hash") @db.VarChar(128)

  product PrintableProduct @relation(fields: [printableProductId], references: [id], onDelete: Cascade)
  user    User?            @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([printableProductId, downloadedAt])
  @@index([userId])
  @@index([source])
  @@map("printable_download_events")
}

model PrintableAccess {
  id                 String                @id @default(cuid())
  printableProductId String                @map("printable_product_id")
  userId             String                @map("user_id")
  source             PrintableAccessSource
  createdAt          DateTime              @default(now()) @map("created_at")

  product PrintableProduct @relation(fields: [printableProductId], references: [id], onDelete: Cascade)
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, printableProductId])
  @@index([printableProductId, source])
  @@map("printable_accesses")
}

/// * ECG worksheet catalog metadata. Runtime downloads are still authorized and tracked through PrintableProduct.
model EcgWorksheet {
  id           String   @id @default(cuid())
  title        String
  description  String?
  pdfUrl       String   @map("pdf_url")
  thumbnailUrl String?  @map("thumbnail_url")
  level        String
  tags         String[]
  isPremium    Boolean  @default(true) @map("is_premium")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([level])
  @@map("ecg_worksheets")
}

/// * Premium ECG video-based learning questions. Intentionally isolated from the core `exam_questions` bank.
model EcgVideoQuestion {
  id               String   @id @default(cuid())
  videoUrl         String   @map("video_url")
  thumbnailUrl     String?  @map("thumbnail_url")
  durationSeconds  Int?     @map("duration_seconds")
  mediaType        String   @default("video_url") @map("media_type") @db.VarChar(32)
  mediaConfig      Json?    @map("media_config")
  questionText     String   @map("question_text")
  answerOptions    Json     @default("[]") @map("answer_options")
  correctAnswerId  String   @map("correct_answer_id") @db.VarChar(64)
  rationale        String
  difficulty       String   @db.VarChar(16)
  rhythmTag        String   @map("rhythm_tag") @db.VarChar(64)
  clinicalPriority String?  @map("clinical_priority") @db.VarChar(64)
  allowedTiers     String[] @map("allowed_tiers")
  isPremium        Boolean  @default(true) @map("is_premium")
  level            String   @db.VarChar(16)
  mode             String   @db.VarChar(16)
  topicTags        String[] @default([]) @map("topic_tags")
  lessonLinkCount  Int      @default(0) @map("lesson_link_count")
  medicalQaStatus  String   @default("pending") @map("medical_qa_status") @db.VarChar(32)
  manualReviewedAt DateTime? @map("manual_reviewed_at")
  manualReviewedBy String?  @map("manual_reviewed_by")
  clinicianReviewedAt DateTime? @map("clinician_reviewed_at")
  clinicianReviewedBy String?   @map("clinician_reviewed_by")
  waveformFidelity    String    @default("educational_simplified") @map("waveform_fidelity") @db.VarChar(40)
  qaStatus            String    @default("pending") @map("qa_status") @db.VarChar(32)
  publishSafetyStatus String    @default("internal_only") @map("publish_safety_status") @db.VarChar(32)
  createdAt        DateTime @default(now()) @map("created_at")

  practiceAnswerAttempts EcgVideoQuestionPracticeAnswerAttempt[]
  answerOptionAggregates EcgVideoQuestionAnswerOptionAggregate[]
  performanceAggregate   EcgVideoQuestionPerformanceAggregate?

  @@index([level, mode])
  @@index([rhythmTag])
  @@index([mediaType])
  @@index([medicalQaStatus])
  @@index([qaStatus])
  @@index([publishSafetyStatus])
  @@map("ecg_video_questions")
}

/// * Shared hidden/admin-preview mastery module catalog. All premium mastery systems should register here instead of creating one-off module tables.
model MasteryModule {
  id               String   @id @default(cuid())
  slug             String   @unique @db.VarChar(128)
  moduleType       String   @map("module_type") @db.VarChar(64)
  title            String
  description      String?
  professionKeys   String[] @default([]) @map("profession_keys")
  route            String   @db.VarChar(240)
  entitlementKey   String?  @map("entitlement_key") @db.VarChar(120)
  isPublic         Boolean  @default(false) @map("is_public")
  adminPreviewOnly Boolean  @default(true) @map("admin_preview_only")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  lessons          MasteryLesson[]
  questions        MasteryQuestion[]
  caseScenarios    MasteryCaseScenario[]
  patternMaps      MasteryPatternMap[]

  @@index([moduleType])
  @@index([isPublic, adminPreviewOnly])
  @@map("mastery_modules")
}

model MasteryLesson {
  id               String        @id @default(cuid())
  moduleId         String        @map("module_id")
  title            String
  slug             String        @db.VarChar(140)
  level            String?       @db.VarChar(32)
  content          Json          @default("{}")
  tags             String[]      @default([])
  isPublic         Boolean       @default(false) @map("is_public")
  adminPreviewOnly Boolean       @default(true) @map("admin_preview_only")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  module           MasteryModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([moduleId, slug])
  @@index([moduleId, level])
  @@map("mastery_lessons")
}

model MasteryQuestion {
  id               String        @id @default(cuid())
  moduleId         String        @map("module_id")
  prompt           String
  answerOptions    Json          @default("[]") @map("answer_options")
  correctAnswerId  String?       @map("correct_answer_id") @db.VarChar(80)
  rationale        String?
  modalityData     Json          @default("{}") @map("modality_data")
  media            Json          @default("{}")
  difficulty       String?       @db.VarChar(32)
  mode             String?       @db.VarChar(32)
  tags             String[]      @default([])
  isPublic         Boolean       @default(false) @map("is_public")
  adminPreviewOnly Boolean       @default(true) @map("admin_preview_only")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  module           MasteryModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([moduleId, mode])
  @@index([isPublic, adminPreviewOnly])
  @@map("mastery_questions")
}

model MasteryCaseScenario {
  id               String        @id @default(cuid())
  moduleId         String        @map("module_id")
  title            String
  slug             String        @db.VarChar(140)
  scenario         Json          @default("{}")
  rationale        String?
  modalityData     Json          @default("{}") @map("modality_data")
  actionLayer      Json          @default("{}") @map("action_layer")
  isPublic         Boolean       @default(false) @map("is_public")
  adminPreviewOnly Boolean       @default(true) @map("admin_preview_only")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  module           MasteryModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([moduleId, slug])
  @@index([moduleId])
  @@map("mastery_case_scenarios")
}

model MasteryPatternMap {
  id               String        @id @default(cuid())
  moduleId         String        @map("module_id")
  title            String
  slug             String        @db.VarChar(140)
  nodes            Json          @default("[]")
  edges            Json          @default("[]")
  isPublic         Boolean       @default(false) @map("is_public")
  adminPreviewOnly Boolean       @default(true) @map("admin_preview_only")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  module           MasteryModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([moduleId, slug])
  @@index([moduleId])
  @@map("mastery_pattern_maps")
}

/// * Aggregated premium UX telemetry (UTC day; global counts, no user PII).
model PremiumProtectionRollup {
  id        String   @id @default(cuid())
  day       DateTime @db.Date
  metricKey String   @map("metric_key") @db.VarChar(96)
  segment   String   @default("") @db.VarChar(96)
  count     Int      @default(0)

  @@unique([day, metricKey, segment])
  @@index([day])
  @@map("premium_protection_rollups")
}

/// * Per-user daily tallies for abuse heuristics (admin review; subscriber ids).
model PremiumProtectionUserDay {
  id        String   @id @default(cuid())
  userId    String
  day       DateTime @db.Date
  metricKey String   @map("metric_key") @db.VarChar(96)
  count     Int      @default(0)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, day, metricKey])
  @@index([day])
  @@index([userId, day])
  @@map("premium_protection_user_days")
}

/// * Flagged accounts for manual review (rate limits, scraping signals).
model ProtectionAbuseReview {
  id                String                           @id @default(cuid())
  userId            String
  reason            String                           @db.VarChar(80)
  score             Int
  evidence          Json?
  createdAt         DateTime                         @default(now())
  /// * When an admin closed this item (dismiss or resolve).
  dismissedAt       DateTime?
  resolution        ProtectionAbuseReviewResolution?
  /// * Short admin note (optional).
  adminNote         String?                          @db.VarChar(500)
  dismissedByUserId String?
  dismissedBy       User?                            @relation("ProtectionAbuseReviewDismissedBy", fields: [dismissedByUserId], references: [id])
  user              User                             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([dismissedAt, createdAt])
  @@index([userId, createdAt])
  @@index([dismissedAt])
  @@map("protection_abuse_reviews")
}

/// * Soft account-sharing telemetry: one row per stable session slot (JWT jti when present).
/// * Stores only HMAC hashes of IP and User-Agent — never raw values.
model LearnerSessionActivity {
  id               String    @id @default(cuid())
  userId           String
  sessionKeyHash   String    @map("session_key_hash") @db.VarChar(64)
  userAgentHash    String    @map("user_agent_hash") @db.VarChar(64)
  ipHash           String    @map("ip_hash") @db.VarChar(64)
  regionHint       String?   @map("region_hint") @db.VarChar(8)
  firstSeenAt      DateTime  @default(now()) @map("first_seen_at")
  lastSeenAt       DateTime  @updatedAt @map("last_seen_at")
  revokedAt        DateTime? @map("revoked_at")
  suspiciousReason String?   @map("suspicious_reason") @db.VarChar(240)
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sessionKeyHash])
  @@index([userId, lastSeenAt(sort: Desc)])
  @@map("learner_session_activities")
}

/// * Deduped IP hashes per learner for rolling distinct-IP heuristics (no raw IP).
model LearnerSessionIpObservation {
  id         String   @id @default(cuid())
  userId     String
  ipHash     String   @map("ip_hash") @db.VarChar(64)
  regionHint String?  @map("region_hint") @db.VarChar(8)
  lastSeenAt DateTime @updatedAt @map("last_seen_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ipHash])
  @@index([userId, lastSeenAt(sort: Desc)])
  @@map("learner_session_ip_observations")
}

model BaselineAssessmentAttempt {
  id          String                          @id @default(cuid())
  userId      String
  questionIds Json
  status      BaselineAssessmentAttemptStatus @default(OPEN)
  createdAt   DateTime                        @default(now())
  submittedAt DateTime?
  user        User                            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([createdAt])
}

/// * Subscriber-authored notes; source references only (ids/titles), not lesson/question bodies.
model LearnerNote {
  id        String           @id @default(cuid())
  userId    String
  scope     LearnerNoteScope
  contextId String           @db.VarChar(128)
  pathwayId String?          @db.VarChar(64)
  topic     String?          @db.VarChar(200)
  title     String?          @db.VarChar(200)
  body      String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, scope, contextId])
  @@index([userId, updatedAt])
}

/// * Per-user topic performance for weak-area recommendations (question bank, mocks, practice tests).
model UserTopicStat {
  id            String    @id @default(cuid())
  userId        String
  topic         String    @db.VarChar(80)
  correctCount  Int       @default(0)
  wrongCount    Int       @default(0)
  /// * Consecutive wrong answers for this topic; resets on a correct attempt.
  wrongStreak   Int       @default(0)
  lastWrongAt   DateTime?
  lastAttemptAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, topic])
  @@index([userId, updatedAt])
}

/// * Mistake taxonomy for the remediation engine (NN_ENABLE_REMEDIATION_ENGINE).
enum RemediationMistakeType {
  knowledge_gap
  prioritization
  pharmacology
  safety
  delegation
  misread_question
}

enum RemediationQueueSource {
  question
  lesson
  flashcard
}

/// * Captured learner mistakes / low-confidence correct answers for spaced remediation.
model UserRemediationEvent {
  id                 String                 @id @default(cuid())
  userId             String
  questionId       String                 @db.VarChar(64)
  pathwayId        String?                @db.VarChar(64)
  topic            String?                @db.VarChar(200)
  bodySystem       String?                @db.VarChar(128)
  examMeta         Json?
  mistakeType      RemediationMistakeType
  confidence       String?                @db.VarChar(16)
  catDifficultyHint Float?
  createdAt        DateTime               @default(now())
  user             User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, topic])
}

/// * Aggregated remediation slots (upserted from events); study plan reads open rows due today.
model UserRemediationQueue {
  id              String                 @id @default(cuid())
  userId          String
  pathwayId       String?                @db.VarChar(64)
  topic           String?                @db.VarChar(200)
  bodySystem      String?                @db.VarChar(128)
  pathwayKey      String                 @default("") @db.VarChar(64)
  topicKey        String                 @default("") @db.VarChar(200)
  bodySystemKey   String                 @default("") @db.VarChar(128)
  priorityScore   Float                  @default(0)
  nextReviewAt    DateTime
  source          RemediationQueueSource @default(question)
  resolved        Boolean                @default(false)
  resolvedAt      DateTime?
  mistakeCount    Int                    @default(0)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  user            User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, pathwayKey, topicKey, bodySystemKey])
  @@index([userId, resolved, nextReviewAt])
  @@index([userId, resolved, priorityScore])
}

model TrialDeviceBinding {
  id              String   @id @default(cuid())
  fingerprintHash String   @unique
  userId          String
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// * Idempotency and cooldown tracking for retention and transactional emails.
model EmailNotificationLog {
  id        String   @id @default(cuid())
  userId    String
  kind      String
  meta      Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, kind, createdAt])
  @@index([createdAt])
}

/// * Postmark inbound MessageID idempotency + audit for `/api/inbound-email` AI autoreply.
enum InboundEmailAutoreplyStatus {
  PENDING
  SKIPPED
  REPLIED
  FAILED
}

model InboundEmailAutoreplyEvent {
  id                         String                      @id @default(cuid())
  postmarkInboundMessageId   String                      @unique @map("postmark_inbound_message_id") @db.VarChar(200)
  senderEmail                String                      @map("sender_email") @db.VarChar(320)
  subject                    String                      @db.VarChar(998)
  receivedAt                 DateTime                    @default(now()) @map("received_at")
  replySentAt                DateTime?                   @map("reply_sent_at")
  status                     InboundEmailAutoreplyStatus @default(PENDING)
  /// * Skip or failure detail (e.g. auto_reply_disabled, missing_openai_api_key).
  failureReason              String?                     @map("failure_reason") @db.Text
  postmarkOutboundMessageId  String?                     @map("postmark_outbound_message_id") @db.VarChar(200)

  @@index([status, receivedAt])
  @@map("inbound_email_autoreply_events")
}

/// * One-time password reset tokens; raw token is never stored (only SHA-256 hex).
model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// * Immutable OAuth provider subject binding (Google/Apple). Subject ID is authoritative; email is a snapshot only.
model OAuthProviderLink {
  id                  String   @id @default(cuid())
  userId              String
  provider            String   @db.VarChar(16)
  providerAccountId   String   @db.VarChar(255)
  emailSnapshot       String?  @db.VarChar(320)
  isApplePrivateRelay Boolean  @default(false)
  linkedAt            DateTime @default(now())
  lastSignInAt        DateTime?
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("oauth_provider_links")
}

/// * Email verification tokens; raw token is never stored (only SHA-256 hex).
model EmailVerificationToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Persisted Stripe subscription row — logical **user subscription** (region, tier/profession, plan, status, renewal).
model Subscription {
  id                   String             @id @default(cuid())
  userId               String
  status               SubscriptionStatus @default(ACTIVE)
  stripeCustomerId     String?
  stripeSubscriptionId String             @unique
  /// * Stripe checkout / price-derived plan; when set, entitlements prefer this over `User.tier` for access scope.
  planTier             TierCode?
  planCountry          CountryCode?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  planDuration         String?            @db.VarChar(20)
  currentPeriodEnd     DateTime?
  trialEnd             DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  /// * When planTier is ALLIED, the specific career line purchased (e.g. paramedic, mlt).
  alliedCareer         String?            @db.VarChar(64)
  /// * Checkout `metadata.planCode` (e.g. `canada_nursing_monthly` or regional code).
  planCode             String?            @db.VarChar(96)
  /// * Checkout `metadata.region` when global regional pricing was used (e.g. `philippines`).
  billingRegionSlug    String?            @db.VarChar(32)
  pastDueSince         DateTime?
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

/// * **Claim** row inserted **before** webhook handlers run — prevents concurrent double-apply across instances.
/// * Deleted on handler failure so Stripe retries are not permanently skipped.
model StripeWebhookEvent {
  id        String   @id
  createdAt DateTime @default(now())
}

/// * Dedupes internal owner alerts for paid subscription checkout (`checkout.session.completed`) — one row per Stripe `evt_…`.
model StripeOwnerPaidSubscriptionNotify {
  id        String   @id
  createdAt DateTime @default(now())
}

model Category {
  id                       String                    @id @default(cuid())
  name                     String
  slug                     String                    @unique
  topicCode                String?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  flashcards               Flashcard[]
  generatedFlashcardDrafts GeneratedFlashcardDraft[]
  generatedQuestionDrafts  GeneratedQuestionDraft[]
  Lesson                   Lesson[]
  Question                 Question[]
}

/// * Aggregated full-corpus lesson/question quality (refreshed via admin POST, not hot-path).
model ContentQualityCorpusSnapshot {
  id        String   @id
  payload   Json
  updatedAt DateTime @updatedAt

  @@map("content_quality_corpus_snapshots")
}

/// * Public SEO blog posts (migrated from legacy content_items / static allied data). Not the same rows as `content_items.type = 'lesson'`.
model BlogPost {
  id                         String                         @id @default(cuid())
  slug                       String                         @unique
  title                      String
  excerpt                    String
  body                       String
  coverImage                 String?
  tags                       String[]                       @default([])
  category                   String?
  createdAt                  DateTime                       @default(now())
  updatedAt                  DateTime                       @updatedAt
  /// * e.g. content_items, paramedic-static, legacy-json
  legacySource               String?
  /// * Visibility: DRAFT never public; SCHEDULED goes live when publishAt <= now; PUBLISHED always public (after publishAt if set).
  postStatus                 BlogPostStatus                 @default(DRAFT)
  /// * When status is SCHEDULED, this is the go-live instant (UTC). Also used as canonical “publish” time for SEO when set.
  publishAt                  DateTime?
  /// * RN | PN | NP | Allied — drives cross-links and topic hubs (string for flexibility vs exam registry keys).
  exam                       String?
  /// * Optional: overrides <title> / OG when set.
  seoTitle                   String?
  seoDescription             String?
  /// * Structured template for generators and footer CTAs.
  postTemplate               BlogPostTemplate?
  /// * Internal paths e.g. `/us/rn/nclex-rn/lessons/slug` — no full lesson HTML stored here.
  relatedLessonPaths         String[]                       @default([])
  /// * Exam question UUIDs for deep links (public pages never expose rationales).
  relatedQuestionIds         String[]                       @default([])
  /// * Tool route slugs e.g. `labs`, `med-math` resolved under /tools.
  relatedTools               String[]                       @default([])
  /// * Admin-only append-only JSON array: generation, saves, publish attempts, status transitions.
  adminPublishLog            Json                           @default("[]")
  campaignId                 String?
  targetKeyword              String?
  keywordCluster             String?
  countryTarget              CountryCode?
  intent                     BlogPostIntent?
  funnelStage                BlogFunnelStage?
  workflowStatus             BlogWorkflowStatus             @default(GENERATED)
  outlineJson                Json?
  keyQuestions               String[]                       @default([])
  keywordPlan                String[]                       @default([])
  internalLinkPlan           Json?
  ctaType                    String?
  ctaText                    String?
  ctaHref                    String?
  titleAlternates            String[]                       @default([])
  clickTitle                 String?
  metaTitleVariant           String?
  metaDescriptionVariant     String?
  featuredSnippet            String?
  keyTakeaways               String[]                       @default([])
  faqBlock                   Json?
  definitionBox              String?
  checklistBlock             Json?
  quickReferenceBlock        Json?
  sourceReliabilityScore     Int?
  sourcesJson                Json?
  apaReferences              String[]                       @default([])
  requiresReferences         Boolean                        @default(false)
  medicalRiskFlags           String[]                       @default([])
  reviewDueAt                DateTime?
  lastReviewedAt             DateTime?
  coverImageAlt              String?
  coverImageCaption          String?
  coverImagePrompt           String?
  imageStyleType             String?
  imageStatus                BlogImageStatus                @default(NONE)
  socialCaption              String?
  emailTeaser                String?
  shortSummary               String?
  promoBlurb                 String?
  schemaSummary              String?
  perfImpressions            Int?
  perfClicks                 Int?
  perfCtr                    Float?
  perfInternalClicks         Int?
  perfConversionAssists      Int?
  perfSubscriptionAssists    Int?
  updateNeeded               Boolean                        @default(false)
  rankingNote                String?
  /// * Original legacy schedule timestamp (if imported from scheduled content).
  scheduledAt                DateTime?
  /// * Profession/career dimension for shared nursing+allied infrastructure (e.g., rn, paramedic, mlt).
  careerSlug                 String?
  /// * Content locale used for language-aware blog delivery.
  locale                     String                         @default("en")
  /// * Shared identifier linking translations of the same post.
  translationGroupId         String?
  /// * Locale of the canonical/source article.
  sourceLocale               String?
  /// * Whether this row was auto-translated from a source post.
  isAutoTranslated           Boolean                        @default(false)
  /// * Translation provenance such as `ai`, `manual`, or `legacy`.
  translationSource          String?
  /// * Canonical/source BlogPost row for translation variants (self relation).
  canonicalPostId            String?
  authorDisplayName          String?
  authorCredentials          String?
  authorBio                  String?
  medicalReviewerName        String?
  medicalReviewerCredentials String?
  batchScheduleItems         BlogBatchScheduleItem[]
  campaignItems              BlogCampaignItem[]
  draftGenerationBatchItems  BlogDraftGenerationBatchItem[]
  blogArticleGenerationJobs  BlogArticleGenerationJob[]
  campaign                   BlogCampaign?                  @relation(fields: [campaignId], references: [id])
  canonicalPost              BlogPost?                      @relation("BlogPostCanonicalRelation", fields: [canonicalPostId], references: [id])
  translatedVariants         BlogPost[]                     @relation("BlogPostCanonicalRelation")
  contentAutomationLogs      ContentAutomationLog[]
  localizedVariants          LocalizedBlogArticle[]

  @@index([postStatus, publishAt])
  @@index([careerSlug, locale, postStatus, publishAt])
  @@index([translationGroupId, locale])
  @@index([canonicalPostId])
  @@index([scheduledAt])
  @@index([createdAt])
  @@index([campaignId, postStatus, publishAt])
  @@index([targetKeyword])
  @@index([keywordCluster])
  @@index([workflowStatus])
}

model BlogCampaign {
  id                String             @id @default(cuid())
  name              String
  keywordCluster    String
  targetExam        String?
  targetProfession  String?
  targetPathway     String?
  countryTarget     CountryCode?
  desiredPostCount  Int
  postsPerWeek      Int?
  preferredWeekdays Int[]              @default([])
  startDate         DateTime?
  templateMix       BlogPostTemplate[] @default([])
  intentMix         BlogPostIntent[]   @default([])
  funnelStage       BlogFunnelStage?
  includeImages     Boolean            @default(false)
  includeAiImages   Boolean            @default(false)
  requireReferences Boolean            @default(false)
  status            BlogCampaignStatus @default(DRAFT)
  progressJson      Json?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  items             BlogCampaignItem[]
  posts             BlogPost[]

  @@index([status, startDate])
  @@index([keywordCluster])
}

model BlogCampaignItem {
  id                String                 @id @default(cuid())
  campaignId        String
  ordinal           Int
  status            BlogCampaignItemStatus @default(QUEUED)
  plannedKeyword    String?
  plannedTitle      String?
  plannedSlug       String?
  plannedPublishAt  DateTime?
  preferredTemplate BlogPostTemplate?
  preferredIntent   BlogPostIntent?
  preferredFunnel   BlogFunnelStage?
  includeImage      Boolean                @default(false)
  includeAiImage    Boolean                @default(false)
  postId            String?
  error             String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  campaign          BlogCampaign           @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  post              BlogPost?              @relation(fields: [postId], references: [id])

  @@unique([campaignId, ordinal])
  @@index([campaignId, status, ordinal])
  @@index([plannedPublishAt])
}

/// *
/// * Paste-many-topics batch schedule (admin). Items get staggered `plannedPublishAt`; a cron/admin runner
/// * generates AI drafts and schedules publication (reuses `generateBlogAiDraft` + canonical intent dedupe).
model BlogBatchSchedule {
  id                  String                  @id @default(cuid())
  status              BlogBatchScheduleStatus @default(ACTIVE)
  /// * Posts per 24h window (1–12). Slot interval = 24h / cadencePerDay.
  cadencePerDay       Int
  startAt             DateTime
  /// * Earliest pending item publish slot (denormalized for ops UI).
  nextRunAt           DateTime?
  lastRunAt           DateTime?
  totalItems          Int
  publishedCount      Int                     @default(0)
  failedCount         Int                     @default(0)
  skippedCount        Int                     @default(0)
  exam                String
  country             String                  @default("unspecified")
  defaultTemplate     BlogPostTemplate        @default(TOPIC_EXPLAINED)
  defaultIntent       BlogPostIntent?
  createdById         String?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  publishMode         BlogBatchPublishMode    @default(STAGGERED_PUBLISH)
  /// * Optional JSON: `{ "locales": ["fr","es","tl","hi"] }` — server maps default region per locale after each canonical item succeeds.
  localizationOptions Json?
  createdBy           User?                   @relation(fields: [createdById], references: [id])
  items               BlogBatchScheduleItem[]

  @@index([status, nextRunAt])
}

model BlogBatchScheduleItem {
  id                String                      @id @default(cuid())
  scheduleId        String
  ordinal           Int
  topicRaw          String
  canonicalTopicKey String?
  plannedPublishAt  DateTime
  status            BlogBatchScheduleItemStatus @default(PENDING)
  blogPostId        String?
  failureReason     String?
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt
  blogPost          BlogPost?                   @relation(fields: [blogPostId], references: [id])
  schedule          BlogBatchSchedule           @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, ordinal])
  @@index([scheduleId, status, plannedPublishAt])
  @@index([plannedPublishAt, status])
}

/// *
/// * Admin paste-many-topics draft batch: one `BlogPost` draft per line when processed.
/// * Progress is persisted; call process API in chunks to stay within request timeouts.
model BlogDraftGenerationBatch {
  id                           String                         @id @default(cuid())
  status                       BlogDraftGenerationBatchStatus @default(ACTIVE)
  exam                         String
  country                      String                         @default("unspecified")
  defaultTemplate              BlogPostTemplate               @default(TOPIC_EXPLAINED)
  defaultIntent                BlogPostIntent?
  funnelStage                  BlogFunnelStage?
  tone                         String                         @default("professional") @db.VarChar(32)
  keywords                     String?
  keywordCluster               String?
  countryTarget                CountryCode?
  includeImage                 Boolean                        @default(true)
  includeAiImage               Boolean                        @default(false)
  allowDuplicateCanonicalTopic Boolean                        @default(false)
  /// When true, cron (and optional admin tick) advance items without browser-driven process loops.
  backgroundProcessing         Boolean                        @default(false)
  /// Client-supplied key to dedupe double-submit within a short window (same admin user).
  idempotencyKey               String?                        @db.VarChar(128)
  processorStartedAt         DateTime?
  lastProcessorError           String?                        @db.VarChar(512)
  totalItems                   Int
  completedCount               Int                            @default(0)
  failedCount                  Int                            @default(0)
  skippedCount                 Int                            @default(0)
  createdById                  String?
  createdAt                    DateTime                       @default(now())
  updatedAt                    DateTime                       @updatedAt
  createdBy                    User?                          @relation(fields: [createdById], references: [id])
  items                        BlogDraftGenerationBatchItem[]

  @@index([status, createdAt])
  @@index([backgroundProcessing, status, updatedAt])
  @@index([createdById, idempotencyKey])
}

model BlogDraftGenerationBatchItem {
  id                String                             @id @default(cuid())
  batchId           String
  ordinal           Int
  topicRaw          String
  canonicalTopicKey String?
  status            BlogDraftGenerationBatchItemStatus @default(PENDING)
  blogPostId        String?
  error             String?
  createdAt         DateTime                           @default(now())
  updatedAt         DateTime                           @updatedAt
  batch             BlogDraftGenerationBatch           @relation(fields: [batchId], references: [id], onDelete: Cascade)
  blogPost          BlogPost?                          @relation(fields: [blogPostId], references: [id])

  @@unique([batchId, ordinal])
  @@index([batchId, status, ordinal])
}

/// * Async admin control-panel article generation (plan → body → repair → publish). Avoids long synchronous HTTP.
model BlogArticleGenerationJob {
  id               String    @id @default(cuid())
  createdById      String?
  /// * Pipeline progress / terminal: queued, generating_plan, generating_body, repairing_body, validating_citations, prepublish_checks, publishing, published, failed
  stage            String    @default("queued") @db.VarChar(40)
  requestPayload   Json
  planSnapshot       Json?
  bodyHtmlSnapshot   String? @db.Text
  blogPostId       String?
  lastError        String?   @db.Text
  failureCode      String?   @db.VarChar(64)
  repairable       Boolean   @default(false)
  retryCount       Int       @default(0)
  resultWarnings   Json?
  resultSlug       String?   @db.VarChar(200)
  resultTitle      String?   @db.VarChar(300)
  resultPostStatus String?   @db.VarChar(32)
  /// * When set, `pumpBlogArticleGenerationJobs` must not claim the row until `now >= nextAttemptAt` (retry backoff).
  nextAttemptAt    DateTime? @map("next_attempt_at")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  createdBy        User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)
  blogPost         BlogPost? @relation(fields: [blogPostId], references: [id], onDelete: SetNull)

  @@index([stage, createdAt])
  @@index([stage, nextAttemptAt])
  @@map("blog_article_generation_jobs")
}

model ContentAutomationLog {
  id            String                       @id @default(cuid())
  category      ContentAutomationLogCategory
  jobType       String                       @db.VarChar(96)
  status        ContentAutomationLogStatus
  topic         String?
  summary       String?                      @db.VarChar(480)
  error         String?
  metadata      Json?
  blogPostId    String?
  correlationId String?                      @db.VarChar(64)
  sourceItemId  String?                      @db.VarChar(64)
  retryOfId     String?                      @db.VarChar(64)
  completedAt   DateTime?
  createdById   String?
  createdAt     DateTime                     @default(now())
  updatedAt     DateTime                     @updatedAt
  blogPost      BlogPost?                    @relation(fields: [blogPostId], references: [id])
  createdBy     User?                        @relation(fields: [createdById], references: [id])

  @@index([category, status, createdAt])
  @@index([createdAt])
  @@index([blogPostId])
  @@index([correlationId])
}

/// *
/// * Localized variant of a canonical BlogPost for international SEO expansion.
/// * References the canonical BlogPost via canonicalArticleId but stores its own
/// * fully adapted content, SEO metadata, and editorial state.
/// *
/// * Each (canonicalArticleId, locale, region) tuple is unique — one variant per
/// * locale/region combination per canonical article.
model LocalizedBlogArticle {
  id                       String              @id @default(cuid())
  canonicalArticleId       String
  locale                   String              @db.VarChar(10)
  region                   String              @db.VarChar(32)
  profession               String?             @db.VarChar(32)
  exam                     String?             @db.VarChar(48)
  sourceLanguage           String              @default("en") @db.VarChar(10)
  adaptationType           BlogAdaptationType  @default(ADAPTED)
  contentStatus            LocalizedBlogStatus @default(DRAFT)
  aiModelVersion           String?             @db.VarChar(64)
  aiPromptVersion          String?             @db.VarChar(32)
  localizedTitle           String
  localizedExcerpt         String
  localizedBody            String
  canonicalSlug            String              @db.VarChar(200)
  localizedSlug            String              @db.VarChar(200)
  localizedMetaTitle       String?
  localizedMetaDescription String?
  seoKeywordPrimary        String?
  seoKeywordSecondary      String[]            @default([])
  searchIntent             String?             @db.VarChar(48)
  hreflangJson             Json?
  canonicalUrl             String?
  targetAudience           String?             @db.VarChar(64)
  ctaVariant               String?             @db.VarChar(48)
  ctaText                  String?
  ctaHref                  String?
  internalLinkTargets      Json?
  complianceReviewRequired Boolean             @default(false)
  medicalReviewRequired    Boolean             @default(false)
  editorialReviewRequired  Boolean             @default(true)
  reviewFlags              String[]            @default([])
