generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CountryCode {
  CA
  US
}

enum TierCode {
  PRE_NURSING
  NEW_GRAD
  RPN
  LVN_LPN
  RN
  NP
  ALLIED
}

enum UserRole {
  LEARNER
  /** @deprecated Prefer SUPER_ADMIN — retained for existing rows and JWT compatibility. */
  ADMIN
  /** Full admin: billing, support tools, publishing, dangerous ops. */
  SUPER_ADMIN
  /** Content & publishing: lessons, blog, SEO, generation — not user PII/support or raw billing lists. */
  CONTENT_ADMIN
  /** Support: user lookup, subscription/analytics read, ops health — not publishing or AI generation. */
  SUPPORT_ADMIN
}

enum TrialStatus {
  NONE
  ACTIVE
  EXPIRED
  EXHAUSTED
}

enum ContentStatus {
  DRAFT
  IN_REVIEW
  PUBLISHED
  ARCHIVED
}

enum ExamFamily {
  NCLEX_RN
  NCLEX_PN
  REX_PN
  NP
  ALLIED
  GENERIC
}

enum DifficultyBand {
  FOUNDATION
  INTERMEDIATE
  ADVANCED
}

enum QuestionType {
  MCQ
  SATA
  NGN_CASE
  ORDERING
  FIB_NUMERIC
}

enum SubscriptionStatus {
  ACTIVE
  GRACE
  CANCELLED
  PAST_DUE
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

/** Admin lesson batch queue — one row per topic; statuses drive atomic claim + recovery. */
enum LessonBatchQueueItemStatus {
  PENDING
  GENERATING
  COMPLETED
  FAILED
  SKIPPED_DUPLICATE
  CANCELLED
}

enum ExamSessionStatus {
  IN_PROGRESS
  COMPLETED
}

enum PracticeTestStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

/** Who can browse/study a flashcard deck from marketing vs subscriber surfaces. */
enum FlashcardDeckVisibility {
  PUBLIC_PREVIEW
  SUBSCRIBER
  HIDDEN
}

/** AI-generated content review workflow — never auto-published to learner pools. */
enum DraftReviewStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  PROMOTED
}

/** Learner-declared exam timing for pacing and countdown (not a booking record). */
enum ExamDatePlanType {
  UNSURE
  PROPOSED
  CONFIRMED
}

/** Target readiness / program start for free Pre-Nursing pacing (not a licensure exam date). */
enum PreNursingDatePlanType {
  UNSURE
  PROPOSED
}

model User {
  id                      String         @id @default(cuid())
  email                   String         @unique
  /** Lowercase, trimmed email for dedup (dot-stripping, alias-insensitive). */
  normalizedEmail         String?
  /** Lowercase login handle; optional. PostgreSQL allows multiple NULLs under UNIQUE. */
  username                String?        @unique
  name                    String
  firstName               String?        @db.VarChar(100)
  lastName                String?        @db.VarChar(100)
  displayName             String?        @db.VarChar(200)
  passwordHash            String?
  /** Bumped on password change/reset so JWTs can be invalidated without per-device session rows. */
  credentialVersion       Int            @default(0)
  emailVerified           Boolean        @default(false)
  /** How the account was created (credentials, google, etc.). */
  authProvider            String         @default("credentials") @db.VarChar(32)
  role                    UserRole       @default(LEARNER)
  country                 CountryCode
  tier                    TierCode
  signupIp                String?        @db.VarChar(64)
  lastLoginIp             String?        @db.VarChar(64)
  lastLoginAt             DateTime?
  examFocus               String?
  studyGoal               String?
  dailyStudyMinutes       Int?
  /** Target graded bank questions per UTC day; null uses product default (see load-daily-question-goal-progress). */
  dailyQuestionGoal       Int?
  /** UTC calendar day for which `bankQuestionsGradedCount` applies. */
  bankQuestionsGradedUtcDay DateTime? @db.Date
  /** Graded bank questions counted on `bankQuestionsGradedUtcDay`. */
  bankQuestionsGradedCount  Int         @default(0)
  learnerPath             String?
  /** Calendar date the learner is targeting (UTC midnight stored). */
  examDate                DateTime?
  examDatePlanType        ExamDatePlanType?
  examGoalSetAt           DateTime?
  /** Optional pathway id from exam registry when the goal is pathway-specific (NP tracks, etc.). */
  targetExamPathwayId     String?        @db.VarChar(64)
  /** When tier is ALLIED, optional short profession key (e.g. paramedic, mlt) for scoped UX and recommendations. */
  alliedProfessionKey     String?        @db.VarChar(64)
  /** Free Pre-Nursing: optional target readiness / school start date (UTC midnight). */
  preNursingTargetDate      DateTime?
  preNursingDatePlanType    PreNursingDatePlanType?
  preNursingGoalSetAt       DateTime?
  /** Soft hint for marketing CTAs: rn | rpn | pn | np | unsure */
  preNursingFuturePathwayHint String?    @db.VarChar(16)
  /** Optional learner preference: light | steady | intensive — used for copy only, not hours math. */
  studyCadencePreference  String?        @db.VarChar(32)
  onboardingCompletedAt   DateTime?
  /** User dismissed the baseline assessment prompt (non-blocking). */
  baselineAssessmentSkippedAt    DateTime?
  /** User finished the short baseline question set. */
  baselineAssessmentCompletedAt  DateTime?
  /** Summary: { correctCount, totalQuestions, weakTopics: string[], at: string } */
  baselineAssessmentSummary      Json?
  baselineAssessmentAttempts     BaselineAssessmentAttempt[]

  freeQuestionViews       Int            @default(0)
  freeLessonOpens         Int            @default(0)
  trialStatus             TrialStatus    @default(NONE)
  trialUsedAt             DateTime?
  trialStartedAt          DateTime?
  trialEndsAt             DateTime?
  /** When the user last acknowledged legal policies at subscription checkout (server timestamp). */
  legalPoliciesAcceptedAt DateTime?
  /** Bundle id from `LEGAL_POLICY_BUNDLE_VERSION` at acceptance time. */
  legalPoliciesVersion    String?        @db.VarChar(32)
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  subscriptions           Subscription[]
  attempts                ExamAttempt[]
  examSessions            ExamSession[]
  progress                Progress[]
  aiGenerationJobs        AiGenerationJob[]           @relation("AiJobCreatedBy")
  questionDraftsCreated   GeneratedQuestionDraft[]    @relation("QuestionDraftCreatedBy")
  questionDraftsReviewed  GeneratedQuestionDraft[]    @relation("QuestionDraftReviewedBy")
  flashcardDraftsCreated  GeneratedFlashcardDraft[]   @relation("FlashcardDraftCreatedBy")
  flashcardDraftsReviewed GeneratedFlashcardDraft[]   @relation("FlashcardDraftReviewedBy")
  lessonDraftsCreated     GeneratedLessonDraft[]      @relation("LessonDraftCreatedBy")
  lessonDraftsReviewed    GeneratedLessonDraft[]      @relation("LessonDraftReviewedBy")
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  emailNotificationLogs   EmailNotificationLog[]
  flashcardProgress       FlashcardProgress[]
  flashcardStudySessions  FlashcardStudySession[]
  flashcardUserStats      FlashcardUserStats?
  practiceTests           PracticeTest[]
  trialDeviceBindings     TrialDeviceBinding[]
  /** Aggregated per-topic accuracy / streaks from graded bank, mocks, and practice tests. */
  topicStats              UserTopicStat[]
  /** User-authored study notes (never stores premium HTML bodies). */
  learnerNotes            LearnerNote[]
  /** Daily per-user protection / API abuse tallies (admin-only; no note bodies). */
  premiumProtectionUserDays PremiumProtectionUserDay[]
  protectionAbuseReviews    ProtectionAbuseReview[]
  /** Abuse review rows this admin closed (dismiss / resolve). */
  abuseReviewsDismissed     ProtectionAbuseReview[] @relation("ProtectionAbuseReviewDismissedBy")
  blogBatchSchedules           BlogBatchSchedule[]
  blogDraftGenerationBatches   BlogDraftGenerationBatch[]
  contentAutomationLogs        ContentAutomationLog[]
  mediaAssetsUploaded          MediaAsset[]                 @relation("MediaAssetUploadedBy")

  @@index([alliedProfessionKey])
  @@index([normalizedEmail])
}

/** Admin-managed binary assets on Spaces (blogs, lessons, marketing). */
model MediaAsset {
  id              String    @id @default(cuid())
  publicUrl       String    @unique
  storageKey      String    @unique
  filename        String
  mimeType        String
  kind            String    @default("image") @db.VarChar(16)
  fileSizeBytes   Int
  width           Int?
  height          Int?
  altText         String?   @db.Text
  tags            String[]  @default([])
  uploadedById    String?
  uploadedBy      User?     @relation("MediaAssetUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)
  /** Best-effort count from last usage scan (null = never scanned). */
  usageRefCount   Int?
  usageRefs       Json?
  usageScannedAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([createdAt(sort: Desc)])
  @@index([kind])
  @@index([mimeType])
  @@map("media_assets")
}

/** Aggregated premium UX telemetry (UTC day; global counts, no user PII). */
model PremiumProtectionRollup {
  id        String   @id @default(cuid())
  day       DateTime @db.Date
  metricKey String   @map("metric_key") @db.VarChar(96)
  segment   String   @default("") @db.VarChar(96)
  count     Int      @default(0)

  @@unique([day, metricKey, segment])
  @@index([day])
  @@map("premium_protection_rollups")
}

/** Per-user daily tallies for abuse heuristics (admin review; subscriber ids). */
model PremiumProtectionUserDay {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  day       DateTime @db.Date
  metricKey String   @map("metric_key") @db.VarChar(96)
  count     Int      @default(0)

  @@unique([userId, day, metricKey])
  @@index([day])
  @@index([userId, day])
  @@map("premium_protection_user_days")
}

enum ProtectionAbuseReviewResolution {
  DISMISSED
  RESOLVED
}

/** Flagged accounts for manual review (rate limits, scraping signals). */
model ProtectionAbuseReview {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason      String    @db.VarChar(80)
  score       Int
  evidence    Json?
  createdAt   DateTime  @default(now())
  /** When an admin closed this item (dismiss or resolve). */
  dismissedAt DateTime?
  resolution  ProtectionAbuseReviewResolution?
  dismissedByUserId String?
  dismissedBy       User?   @relation("ProtectionAbuseReviewDismissedBy", fields: [dismissedByUserId], references: [id], onDelete: SetNull)
  /** Short admin note (optional). */
  adminNote   String?   @db.VarChar(500)

  @@index([dismissedAt, createdAt])
  @@index([userId, createdAt])
  @@index([dismissedAt])
  @@map("protection_abuse_reviews")
}

enum BaselineAssessmentAttemptStatus {
  OPEN
  SUBMITTED
}

model BaselineAssessmentAttempt {
  id          String                        @id @default(cuid())
  userId      String
  user        User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionIds Json
  status      BaselineAssessmentAttemptStatus @default(OPEN)
  createdAt   DateTime                      @default(now())
  submittedAt DateTime?

  @@index([userId, status])
  @@index([createdAt])
}

enum LearnerNoteScope {
  PATHWAY_LESSON
  CONTENT_LESSON
  QUESTION_BANK
  PRACTICE_TEST
  FLASHCARD_DECK
}

/** Subscriber-authored notes; source references only (ids/titles), not lesson/question bodies. */
model LearnerNote {
  id         String           @id @default(cuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  scope      LearnerNoteScope
  contextId  String           @db.VarChar(128)
  pathwayId  String?          @db.VarChar(64)
  topic      String?          @db.VarChar(200)
  title      String?          @db.VarChar(200)
  body       String           @db.Text
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([userId, scope, contextId])
  @@index([userId, updatedAt])
}

/** Per-user topic performance for weak-area recommendations (question bank, mocks, practice tests). */
model UserTopicStat {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic          String    @db.VarChar(80)
  correctCount   Int       @default(0)
  wrongCount     Int       @default(0)
  /** Consecutive wrong answers for this topic; resets on a correct attempt. */
  wrongStreak    Int       @default(0)
  lastWrongAt    DateTime?
  lastAttemptAt  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([userId, topic])
  @@index([userId, updatedAt])
}

model TrialDeviceBinding {
  id              String   @id @default(cuid())
  fingerprintHash String   @unique
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
}

/** Idempotency and cooldown tracking for retention and transactional emails. */
model EmailNotificationLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      String
  meta      Json?
  createdAt DateTime @default(now())

  @@index([userId, kind, createdAt])
  @@index([createdAt])
}

/** One-time password reset tokens; raw token is never stored (only SHA-256 hex). */
model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

/** Email verification tokens; raw token is never stored (only SHA-256 hex). */
model EmailVerificationToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  status               SubscriptionStatus @default(ACTIVE)
  stripeCustomerId     String?
  stripeSubscriptionId String             @unique
  /** Stripe checkout / price-derived plan; when set, entitlements prefer this over `User.tier` for access scope. */
  planTier             TierCode?
  planCountry          CountryCode?
  planDuration         String?            @db.VarChar(20)
  /** When planTier is ALLIED, the specific career line purchased (e.g. paramedic, mlt). */
  alliedCareer         String?            @db.VarChar(64)
  currentPeriodEnd     DateTime?
  trialEnd             DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

/** Dedup Stripe webhook deliveries (evt_…) so retries are safe. */
model StripeWebhookEvent {
  id        String   @id
  createdAt DateTime @default(now())
}

model Category {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  topicCode String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  flashcards Flashcard[]
  generatedQuestionDrafts  GeneratedQuestionDraft[]
  generatedFlashcardDrafts GeneratedFlashcardDraft[]
}

enum BlogPostStatus {
  DRAFT
  NEEDS_REVIEW
  APPROVED
  SCHEDULED
  PUBLISHED
  FAILED
}

/** Editorial templates for generation + internal linking (not shown as raw enum in UI). */
enum BlogPostTemplate {
  HOW_TO_PASS
  TOPIC_EXPLAINED
  TOP_MISTAKES
  PRACTICE_QUESTIONS
  STUDY_PLAN
  EXAM_GUIDE
  MEDICATION_REVIEW
  LAB_VALUES_GUIDE
  DISEASE_PROCESS_EXPLAINER
  PRIORITIZATION_ARTICLE
  COMPARISON_ARTICLE
  CHECKLIST_ARTICLE
  FAQ_STYLE
  GLOSSARY
}

enum BlogPostIntent {
  INFORMATIONAL
  EXAM_PREP
  STUDY_STRATEGY
  COMPARISON
  CONVERSION
  PRACTICE_QUESTIONS
  CHECKLIST
  CONCEPT_EXPLAINER
}

enum BlogFunnelStage {
  AWARENESS
  CONSIDERATION
  CONVERSION
  RETENTION
}

enum BlogWorkflowStatus {
  OUTLINE_READY
  GENERATED
  NEEDS_SOURCE_REVIEW
  NEEDS_MEDICAL_REVIEW
  NEEDS_SEO_REVIEW
  APPROVED
  SCHEDULED
  PUBLISHED
  STALE
  FAILED_GENERATION
  FAILED_IMAGE
  NEEDS_METADATA
  NEEDS_REFERENCES
}

enum BlogCampaignStatus {
  DRAFT
  QUEUED
  RUNNING
  PAUSED
  COMPLETED
  FAILED
}

enum BlogCampaignItemStatus {
  QUEUED
  GENERATING
  GENERATED
  FAILED
  SCHEDULED
  PUBLISHED
}

/** Admin topic-paste batch: automatic AI generation + publish/slot cadence. */
enum BlogBatchScheduleStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum BlogBatchScheduleItemStatus {
  PENDING
  GENERATING
  PUBLISHED
  FAILED
  SKIPPED
}

/** Ad-hoc admin batch: generate drafts from a topic list (no publish cadence). */
enum BlogDraftGenerationBatchStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum BlogDraftGenerationBatchItemStatus {
  PENDING
  GENERATING
  COMPLETED
  FAILED
  SKIPPED
}

enum BlogImageStatus {
  NONE
  REQUESTED
  GENERATED
  FAILED
}

/** Aggregated full-corpus lesson/question quality (refreshed via admin POST, not hot-path). */
model ContentQualityCorpusSnapshot {
  id        String   @id @default("default")
  payload   Json
  updatedAt DateTime @updatedAt

  @@map("content_quality_corpus_snapshots")
}

/** Public SEO blog posts (migrated from legacy content_items / static allied data). Not the same rows as `content_items.type = 'lesson'`. */
model BlogPost {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  excerpt      String
  body         String   @db.Text
  coverImage   String?
  tags         String[] @default([])
  category     String?
  /** Visibility: DRAFT never public; SCHEDULED goes live when publishAt <= now; PUBLISHED always public (after publishAt if set). */
  postStatus   BlogPostStatus @default(DRAFT)
  /** When status is SCHEDULED, this is the go-live instant (UTC). Also used as canonical “publish” time for SEO when set. */
  publishAt    DateTime?
  /** RN | PN | NP | Allied — drives cross-links and topic hubs (string for flexibility vs exam registry keys). */
  exam         String?
  /** Optional: overrides <title> / OG when set. */
  seoTitle     String?
  seoDescription String? @db.Text
  /** Structured template for generators and footer CTAs. */
  postTemplate BlogPostTemplate?
  /** Internal paths e.g. `/us/rn/nclex-rn/lessons/slug` — no full lesson HTML stored here. */
  relatedLessonPaths String[] @default([])
  /** Exam question UUIDs for deep links (public pages never expose rationales). */
  relatedQuestionIds String[] @default([])
  /** Tool route slugs e.g. `labs`, `med-math` resolved under /tools. */
  relatedTools       String[] @default([])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  /** e.g. content_items, paramedic-static, legacy-json */
  legacySource String?
  campaignId   String?
  campaign     BlogCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  campaignItems BlogCampaignItem[]
  batchScheduleItems           BlogBatchScheduleItem[]
  draftGenerationBatchItems    BlogDraftGenerationBatchItem[]
  contentAutomationLogs        ContentAutomationLog[]
  localizedVariants            LocalizedBlogArticle[]
  targetKeyword String?
  keywordCluster String?
  countryTarget CountryCode?
  intent       BlogPostIntent?
  funnelStage  BlogFunnelStage?
  workflowStatus BlogWorkflowStatus @default(GENERATED)
  outlineJson  Json?
  keyQuestions String[] @default([])
  keywordPlan  String[] @default([])
  internalLinkPlan Json?
  ctaType      String?
  ctaText      String?
  ctaHref      String?
  titleAlternates String[] @default([])
  clickTitle   String?
  metaTitleVariant String?
  metaDescriptionVariant String?
  featuredSnippet String? @db.Text
  keyTakeaways String[] @default([])
  faqBlock     Json?
  definitionBox String? @db.Text
  checklistBlock Json?
  quickReferenceBlock Json?
  sourceReliabilityScore Int?
  sourcesJson  Json?
  apaReferences String[] @default([])
  requiresReferences Boolean @default(false)
  medicalRiskFlags String[] @default([])
  reviewDueAt  DateTime?
  lastReviewedAt DateTime?
  coverImageAlt String?
  coverImageCaption String?
  coverImagePrompt String? @db.Text
  imageStyleType String?
  imageStatus  BlogImageStatus @default(NONE)
  socialCaption String? @db.Text
  emailTeaser  String? @db.Text
  shortSummary String? @db.Text
  promoBlurb   String? @db.Text
  schemaSummary String? @db.Text
  perfImpressions Int?
  perfClicks   Int?
  perfCtr      Float?
  perfInternalClicks Int?
  perfConversionAssists Int?
  perfSubscriptionAssists Int?
  updateNeeded Boolean @default(false)
  rankingNote  String? @db.Text
  /** Admin-only append-only JSON array: generation, saves, publish attempts, status transitions. */
  adminPublishLog Json @default("[]")

  @@index([postStatus, publishAt])
  @@index([createdAt])
  @@index([campaignId, postStatus, publishAt])
  @@index([targetKeyword])
  @@index([keywordCluster])
  @@index([workflowStatus])
}

model BlogCampaign {
  id                 String              @id @default(cuid())
  name               String
  keywordCluster     String
  targetExam         String?
  targetProfession   String?
  targetPathway      String?
  countryTarget      CountryCode?
  desiredPostCount   Int
  postsPerWeek       Int?
  preferredWeekdays  Int[]               @default([])
  startDate          DateTime?
  templateMix        BlogPostTemplate[]  @default([])
  intentMix          BlogPostIntent[]    @default([])
  funnelStage        BlogFunnelStage?
  includeImages      Boolean             @default(false)
  includeAiImages    Boolean             @default(false)
  requireReferences  Boolean             @default(false)
  status             BlogCampaignStatus  @default(DRAFT)
  progressJson       Json?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  posts              BlogPost[]
  items              BlogCampaignItem[]

  @@index([status, startDate])
  @@index([keywordCluster])
}

model BlogCampaignItem {
  id                 String                 @id @default(cuid())
  campaignId         String
  campaign           BlogCampaign           @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  ordinal            Int
  status             BlogCampaignItemStatus @default(QUEUED)
  plannedKeyword     String?
  plannedTitle       String?
  plannedSlug        String?
  plannedPublishAt   DateTime?
  preferredTemplate  BlogPostTemplate?
  preferredIntent    BlogPostIntent?
  preferredFunnel    BlogFunnelStage?
  includeImage       Boolean                @default(false)
  includeAiImage     Boolean                @default(false)
  postId             String?
  post               BlogPost?              @relation(fields: [postId], references: [id], onDelete: SetNull)
  error              String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  @@unique([campaignId, ordinal])
  @@index([campaignId, status, ordinal])
  @@index([plannedPublishAt])
}

/**
 * Paste-many-topics batch schedule (admin). Items get staggered `plannedPublishAt`; a cron/admin runner
 * generates AI drafts and schedules publication (reuses `generateBlogAiDraft` + canonical intent dedupe).
 */
model BlogBatchSchedule {
  id              String                  @id @default(cuid())
  status          BlogBatchScheduleStatus @default(ACTIVE)
  /** Posts per 24h window (1–12). Slot interval = 24h / cadencePerDay. */
  cadencePerDay   Int
  startAt         DateTime
  /** Earliest pending item publish slot (denormalized for ops UI). */
  nextRunAt       DateTime?
  lastRunAt       DateTime?
  totalItems      Int
  publishedCount  Int                     @default(0)
  failedCount     Int                     @default(0)
  skippedCount    Int                     @default(0)
  exam            String
  country         String                  @default("unspecified")
  defaultTemplate BlogPostTemplate        @default(TOPIC_EXPLAINED)
  defaultIntent   BlogPostIntent?
  createdById     String?
  createdBy       User?                   @relation(fields: [createdById], references: [id], onDelete: SetNull)
  items           BlogBatchScheduleItem[]
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@index([status, nextRunAt])
}

model BlogBatchScheduleItem {
  id                String                      @id @default(cuid())
  scheduleId        String
  schedule          BlogBatchSchedule           @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  ordinal           Int
  topicRaw          String
  canonicalTopicKey String?
  plannedPublishAt  DateTime
  status            BlogBatchScheduleItemStatus @default(PENDING)
  blogPostId        String?
  blogPost          BlogPost?                   @relation(fields: [blogPostId], references: [id], onDelete: SetNull)
  failureReason     String?                   @db.Text
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt

  @@unique([scheduleId, ordinal])
  @@index([scheduleId, status, plannedPublishAt])
  @@index([plannedPublishAt, status])
}

/**
 * Admin paste-many-topics draft batch: one `BlogPost` draft per line when processed.
 * Progress is persisted; call process API in chunks to stay within request timeouts.
 */
model BlogDraftGenerationBatch {
  id                           String                         @id @default(cuid())
  status                       BlogDraftGenerationBatchStatus @default(ACTIVE)
  exam                         String
  country                      String                         @default("unspecified")
  defaultTemplate              BlogPostTemplate               @default(TOPIC_EXPLAINED)
  defaultIntent                BlogPostIntent?
  funnelStage                  BlogFunnelStage?
  tone                         String                         @default("professional") @db.VarChar(32)
  keywords                     String?                        @db.Text
  keywordCluster               String?
  countryTarget                CountryCode?
  includeImage                 Boolean                        @default(true)
  includeAiImage               Boolean                        @default(false)
  allowDuplicateCanonicalTopic Boolean                        @default(false)
  totalItems                   Int
  completedCount               Int                            @default(0)
  failedCount                  Int                            @default(0)
  skippedCount                 Int                            @default(0)
  createdById                  String?
  createdBy                    User?                          @relation(fields: [createdById], references: [id], onDelete: SetNull)
  items                        BlogDraftGenerationBatchItem[]
  createdAt                    DateTime                       @default(now())
  updatedAt                    DateTime                       @updatedAt

  @@index([status, createdAt])
}

model BlogDraftGenerationBatchItem {
  id                String                             @id @default(cuid())
  batchId           String
  batch             BlogDraftGenerationBatch           @relation(fields: [batchId], references: [id], onDelete: Cascade)
  ordinal           Int
  topicRaw          String
  canonicalTopicKey String?
  status            BlogDraftGenerationBatchItemStatus @default(PENDING)
  blogPostId        String?
  blogPost          BlogPost?                          @relation(fields: [blogPostId], references: [id], onDelete: SetNull)
  error             String?                            @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([batchId, ordinal])
  @@index([batchId, status, ordinal])
}

/** Admin-only audit trail for blog/content automation (generation, publish gates, validation). */
enum ContentAutomationLogCategory {
  BLOG_AI_SIMPLE
  BLOG_AI_BATCH_ITEM
  BLOG_CONTROL_PANEL_PIPELINE
  BLOG_CONTROL_PANEL_PERSIST
  BLOG_PUBLISH
  BLOG_PUBLISH_BLOCKED
  BLOG_MARK_FAILED
  BLOG_REFERENCE_GATE
  BLOG_INTERNAL_LINK_CHECK
}

enum ContentAutomationLogStatus {
  SUCCEEDED
  FAILED
  SKIPPED
  WARNING
}

model ContentAutomationLog {
  id            String                       @id @default(cuid())
  category      ContentAutomationLogCategory
  jobType       String                       @db.VarChar(96)
  status        ContentAutomationLogStatus
  topic         String?                      @db.Text
  summary       String?                      @db.VarChar(480)
  error         String?                      @db.Text
  metadata      Json?
  blogPostId    String?
  blogPost      BlogPost?                    @relation(fields: [blogPostId], references: [id], onDelete: SetNull)
  correlationId String?                      @db.VarChar(64)
  sourceItemId  String?                      @db.VarChar(64)
  retryOfId     String?                      @db.VarChar(64)
  completedAt   DateTime?
  createdById   String?
  createdBy     User?                        @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime                     @default(now())
  updatedAt     DateTime                     @updatedAt

  @@index([category, status, createdAt])
  @@index([createdAt])
  @@index([blogPostId])
  @@index([correlationId])
}

// ── Localized blog content (international SEO expansion) ─────────────────────

/** Lifecycle of a localized blog article from AI generation through editorial approval to publication. */
enum LocalizedBlogStatus {
  DRAFT
  AI_GENERATED
  AI_ADAPTED
  PENDING_REVIEW
  APPROVED
  SCHEDULED
  PUBLISHED
  REJECTED
}

/** How a localized variant was produced from the canonical article. */
enum BlogAdaptationType {
  ORIGINAL
  TRANSLATED
  ADAPTED
  LOCALIZED_REWRITE
  MARKET_EXPANSION
}

/**
 * Localized variant of a canonical BlogPost for international SEO expansion.
 * References the canonical BlogPost via canonicalArticleId but stores its own
 * fully adapted content, SEO metadata, and editorial state.
 *
 * Each (canonicalArticleId, locale, region) tuple is unique — one variant per
 * locale/region combination per canonical article.
 */
model LocalizedBlogArticle {
  id                    String               @id @default(cuid())
  canonicalArticleId    String
  canonicalArticle      BlogPost             @relation(fields: [canonicalArticleId], references: [id], onDelete: Cascade)

  // ── Localization coordinates ──────────────────────────────────────────────
  locale                String               @db.VarChar(10)
  region                String               @db.VarChar(32)
  profession            String?              @db.VarChar(32)
  exam                  String?              @db.VarChar(48)

  // ── Adaptation metadata ───────────────────────────────────────────────────
  sourceLanguage        String               @default("en") @db.VarChar(10)
  adaptationType        BlogAdaptationType   @default(ADAPTED)
  contentStatus         LocalizedBlogStatus  @default(DRAFT)
  aiModelVersion        String?              @db.VarChar(64)
  aiPromptVersion       String?              @db.VarChar(32)

  // ── Content ───────────────────────────────────────────────────────────────
  localizedTitle        String
  localizedExcerpt      String               @db.Text
  localizedBody         String               @db.Text
  canonicalSlug         String               @db.VarChar(200)
  localizedSlug         String               @db.VarChar(200)

  // ── SEO ───────────────────────────────────────────────────────────────────
  localizedMetaTitle    String?
  localizedMetaDescription String?           @db.Text
  seoKeywordPrimary     String?
  seoKeywordSecondary   String[]             @default([])
  searchIntent          String?              @db.VarChar(48)
  hreflangJson          Json?
  canonicalUrl          String?

  // ── Conversion ────────────────────────────────────────────────────────────
  targetAudience        String?              @db.VarChar(64)
  ctaVariant            String?              @db.VarChar(48)
  ctaText               String?
  ctaHref               String?
  internalLinkTargets   Json?

  // ── Review / safety ───────────────────────────────────────────────────────
  complianceReviewRequired Boolean           @default(false)
  medicalReviewRequired    Boolean           @default(false)
  editorialReviewRequired  Boolean           @default(true)
  reviewFlags            String[]            @default([])
  editorialNotes         String?             @db.Text

  // ── Publishing ────────────────────────────────────────────────────────────
  publishedAt           DateTime?
  scheduledAt           DateTime?
  rejectedAt            DateTime?
  rejectionReason       String?              @db.Text

  // ── Diagnostics ───────────────────────────────────────────────────────────
  generationLog         Json                 @default("[]")

  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@unique([canonicalArticleId, locale, region])
  @@index([contentStatus, scheduledAt])
  @@index([region, locale, contentStatus])
  @@index([canonicalArticleId])
  @@index([localizedSlug])
  @@index([createdAt])
}

/** Production `content_items` — lessons are `type = "lesson"`. */
model ContentItem {
  id                   String    @id @default(uuid()) @db.VarChar
  title                String
  slug                 String    @unique
  type                 String    @default("lesson")
  category             String?
  bodySystem           String?   @map("body_system")
  tier                 String?
  status               String?   @default("draft")
  tags                 String[]  @default([])
  summary              String?
  content              Json      @default("[]")
  seoTitle             String?   @map("seo_title")
  seoDescription       String?   @map("seo_description")
  seoKeywords          String[]  @default([]) @map("seo_keywords")
  primaryKeyword       String?   @map("primary_keyword")
  secondaryKeywords    String[]  @default([]) @map("secondary_keywords")
  scheduledAt          DateTime? @map("scheduled_at")
  clinicalSafetyReview Boolean   @default(false) @map("clinical_safety_review")
  autoPublish          Boolean   @default(false) @map("auto_publish")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  publishedAt          DateTime? @map("published_at")
  authorId             String?   @map("author_id")
  authorName           String?   @map("author_name")
  regionScope          String?   @default("BOTH") @map("region_scope")
  versionKey           String?   @map("version_key")
  updatedByAi          Boolean   @default(false) @map("updated_by_ai")
  protectedFields      String[]  @default([]) @map("protected_fields")
  sourceVersion        Int       @default(1) @map("source_version")

  generatedQuestionDrafts  GeneratedQuestionDraft[]
  generatedFlashcardDrafts GeneratedFlashcardDraft[]
  lessonEnhancementTargets GeneratedLessonDraft[] @relation("LessonEnhancementTarget")

  @@map("content_items")
  @@index([type, status])
  @@index([type, status, updatedAt])
}

/**
 * Marketing exam-pathway lessons (`/[locale]/[slug]/[exam]/lessons/...`).
 * The loader prefers published rows for each `pathwayId` and falls back to `catalog.json` when that pathway has no DB rows.
 */
model PathwayLesson {
  id                  String        @id @default(cuid())
  pathwayId           String        @map("pathway_id")
  slug                String
  title               String
  topic               String
  topicSlug           String        @map("topic_slug")
  bodySystem          String        @map("body_system")
  previewSectionCount Int           @default(1) @map("preview_section_count")
  seoTitle            String        @map("seo_title") @db.Text
  seoDescription      String        @map("seo_description") @db.Text
  /** Array of { id, heading, kind, body } — normalized to five canonical sections at read time. */
  sections            Json
  /** Optional row-level filter; null means “follow pathway registry” (country implied by pathway). */
  countryCode         CountryCode?  @map("country_code")
  tierCode            TierCode?     @map("tier_code")
  status              ContentStatus @default(PUBLISHED)
  sortOrder           Int           @default(0) @map("sort_order")
  /** BCP 47-style language tag (`en`, `fr`, …). Default `en` for catalog imports. */
  locale              String        @default("en")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  @@unique([pathwayId, slug, locale])
  @@index([pathwayId, status, sortOrder])
  @@index([pathwayId, locale, status, sortOrder])
  @@index([pathwayId, topicSlug, locale, status])
  /** Student app lesson list sorted by updatedAt (recently changed lessons appear first). */
  @@index([pathwayId, status, locale, updatedAt(sort: Desc)])
  /** Batch topic-coverage groupBy: group by pathwayId for all-pathway progress summaries. */
  @@index([status, locale, pathwayId, topicSlug])
  @@map("pathway_lessons")
}

/** Production `exam_questions` question bank. */
model ExamQuestion {
  id                         String    @id @default(uuid()) @db.VarChar
  tier                       String
  exam                       String
  questionType               String    @map("question_type")
  status                     String?   @default("draft")
  publishAt                  DateTime? @map("publish_at")
  stem                       String
  options                    Json?     @default("[]")
  correctAnswer              Json?     @map("correct_answer")
  rationale                  String?
  difficulty                 Int?      @default(3)
  /** Lightweight IRT-style discrimination for CAT (default 1.0 in engine when null). */
  discrimination             Float?    @map("discrimination")
  tags                       String[]  @default([])
  bodySystem                 String?   @map("body_system")
  topic                      String?
  subtopic                   String?
  caseId                     String?   @map("case_id")
  exhibitData                Json?     @map("exhibit_data")
  regionScope                String?   @default("BOTH") @map("region_scope")
  stemHash                   String?   @map("stem_hash")
  careerType                 String?   @default("nursing") @map("career_type")
  scenario                   String?
  clinicalPearl              String?   @map("clinical_pearl")
  examStrategy               String?   @map("exam_strategy")
  memoryHook                 String?   @map("memory_hook")
  frameworkUsed              String?   @map("framework_used")
  clinicalTrap               String?   @map("clinical_trap")
  distractorRationales       Json?     @map("distractor_rationales")
  qualityScores              Json?     @map("quality_scores")
  qualityFeedback            Json?     @map("quality_feedback")
  qualityScore               Int?      @map("quality_score")
  countryCode                String?   @map("country_code")
  regionCode                 String?   @map("region_code")
  licensingBody              String?   @map("licensing_body")
  languageCode               String?   @default("en") @map("language_code")
  cognitiveLevel             String?   @map("cognitive_level")
  questionFormat             String?   @map("question_format")
  isScenario                 Boolean   @default(false) @map("is_scenario")
  isMockExamEligible         Boolean   @default(true) @map("is_mock_exam_eligible")
  isAdaptiveEligible         Boolean   @default(true) @map("is_adaptive_eligible")
  isFlashcardSource          Boolean   @default(false) @map("is_flashcard_source")
  isStudyGuideLinked         Boolean   @default(false) @map("is_study_guide_linked")
  isTutorReady               Boolean   @default(false) @map("is_tutor_ready")
  correctAnswerExplanation   String?   @map("correct_answer_explanation")
  incorrectAnswerRationale   Json?     @map("incorrect_answer_rationale")
  clinicalReasoning          String?   @map("clinical_reasoning")
  keyTakeaway                String?   @map("key_takeaway")
  mnemonic                   String?
  referenceSource            String?   @map("reference_source")
  labUnitVariant             String?   @map("lab_unit_variant")
  medicationNamingVariant    String?   @map("medication_naming_variant")
  caseContext                String?   @map("case_context")
  vitals                     Json?
  labs                       Json?
  images                     Json?
  scenarioId                 String?   @map("scenario_id")
  blueprintWeight            Float?    @map("blueprint_weight")
  /// Blueprint major id: NCLEX client-needs (e.g. safe-effective) or AANP-style NP (e.g. aanp-clinical-management). See `exam-config`.
  nclexClientNeedsCategory    String?   @map("nclex_client_needs_category") @db.VarChar(64)
  /// Optional subcategory / content area label for audits (not required for CAT balancing).
  nclexClientNeedsSubcategory String?   @map("nclex_client_needs_subcategory") @db.VarChar(128)
  createdAt                  DateTime  @default(now()) @map("created_at")
  updatedAt                  DateTime  @updatedAt @map("updated_at")
  publishedAt                DateTime? @map("published_at")
  sourceVersion              Int       @default(1) @map("source_version")

  @@map("exam_questions")
  @@index([status, tier])
  @@index([exam])
  @@index([stemHash])
  @@index([status, updatedAt])
  @@index([status, exam, tier, countryCode])
  /** Topic / category-scoped bank queries (e.g. filters, analytics) alongside exam + status. */
  @@index([status, exam, topic])
  /** Marketing adaptive count queries: status + isAdaptiveEligible + tier (for pathway snapshots). */
  @@index([status, isAdaptiveEligible, tier])
}

/**
 * Allied exam blueprint definitions (legacy monolith `allied_blueprints` / Replit export).
 * Referenced by import pipelines; no FK from `exam_questions` required.
 */
model AlliedBlueprint {
  id                       String   @id @default(uuid()) @db.VarChar
  careerType               String   @map("career_type")
  version                  Int      @default(1)
  domains                  Json
  difficultyDistribution   Json     @map("difficulty_distribution")
  cognitiveDistribution    Json     @map("cognitive_distribution")
  allowedQuestionTypes     Json     @map("allowed_question_types")
  isActive                 Boolean? @default(true) @map("is_active")
  createdAt                DateTime @default(now()) @map("created_at")

  @@index([careerType, isActive])
  @@index([careerType, version])
  @@map("allied_blueprints")
}

model FlashcardDeck {
  id          String                   @id @default(cuid())
  slug        String                   @unique
  title       String
  description String?                  @db.Text
  country     CountryCode
  tier        TierCode
  examFamily  ExamFamily               @default(GENERIC)
  pathwayId   String?                  @map("pathway_id")
  visibility  FlashcardDeckVisibility  @default(SUBSCRIBER)
  status      ContentStatus            @default(DRAFT)
  sortOrder   Int                      @default(0) @map("sort_order")
  cardCount   Int                      @default(0) @map("card_count")
  createdAt   DateTime                 @default(now()) @map("created_at")
  updatedAt   DateTime                 @updatedAt @map("updated_at")

  cards         Flashcard[]
  tags          FlashcardDeckOnTag[]
  studySessions FlashcardStudySession[]

  @@index([status, visibility, country])
  @@index([status, examFamily])
  @@map("flashcard_decks")
}

model FlashcardTag {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  decks FlashcardDeckOnTag[]

  @@map("flashcard_tags")
}

model FlashcardDeckOnTag {
  deckId String @map("deck_id")
  tagId  String @map("tag_id")
  deck   FlashcardDeck @relation(fields: [deckId], references: [id], onDelete: Cascade)
  tag    FlashcardTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([deckId, tagId])
  @@map("flashcard_deck_tags")
}

model Flashcard {
  id             String         @id @default(cuid())
  front          String
  back           String
  country        CountryCode
  tier           TierCode
  status         ContentStatus  @default(DRAFT)
  examFamily     ExamFamily     @default(GENERIC)
  categoryId     String
  category       Category       @relation(fields: [categoryId], references: [id])
  deckId         String?        @map("deck_id")
  deck           FlashcardDeck? @relation(fields: [deckId], references: [id], onDelete: SetNull)
  positionInDeck Int            @default(0) @map("position_in_deck")
  /**
   * Stable deduplication key for pipeline-generated cards.
   * Format: "{sourceType}:{sourceId}" — e.g. "exam_q:abc123", "lesson:cardio-basics:intro:0"
   * Null for manually authored cards. Unique so sync scripts can upsert without duplicating.
   */
  sourceKey      String?        @unique @map("source_key")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  progressRecords FlashcardProgress[]

  @@index([status, country, tier])
  @@index([deckId, positionInDeck])
  @@index([deckId, status])
}

model FlashcardProgress {
  id             String    @id @default(cuid())
  userId         String    @map("user_id")
  flashcardId    String    @map("flashcard_id")
  easeFactor     Float     @default(2.5) @map("ease_factor")
  intervalDays   Int       @default(0) @map("interval_days")
  repetitions    Int       @default(0)
  nextReviewAt   DateTime? @map("next_review_at")
  lastQuality    Int?      @map("last_quality")
  lastReviewedAt DateTime? @map("last_reviewed_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  flashcard Flashcard @relation(fields: [flashcardId], references: [id], onDelete: Cascade)

  @@unique([userId, flashcardId])
  @@index([userId, nextReviewAt])
  @@index([flashcardId])
  @@map("flashcard_progress")
}

model FlashcardStudySession {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  deckId    String   @map("deck_id")
  queueIds  Json     @map("queue_ids")
  cursor    Int      @default(0)
  updatedAt DateTime @updatedAt @map("updated_at")

  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  deck FlashcardDeck @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@unique([userId, deckId])
  @@index([userId])
  @@map("flashcard_study_sessions")
}

model FlashcardUserStats {
  userId             String    @id @map("user_id")
  currentStreak      Int       @default(0) @map("current_streak")
  longestStreak      Int       @default(0) @map("longest_streak")
  lastStudyDate      DateTime? @map("last_study_date")
  cardsReviewedTotal Int       @default(0) @map("cards_reviewed_total")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("flashcard_user_stats")
}

model Exam {
  id          String         @id @default(cuid())
  title       String
  country     CountryCode
  tier        TierCode
  status      ContentStatus  @default(DRAFT)
  examFamily  ExamFamily     @default(GENERIC)
  attempts    ExamAttempt[]
  sessions    ExamSession[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([status, country, tier])
}

model ExamAttempt {
  id          String        @id @default(cuid())
  userId      String
  examId      String
  score       Int
  total       Int
  /** Topic breakdown, per-item flags, timing — set on graded submits. */
  results     Json?
  createdAt   DateTime      @default(now())
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam        Exam          @relation(fields: [examId], references: [id], onDelete: Cascade)
  examSession ExamSession?  @relation("ExamSessionAttempt")

  @@index([examId])
  @@index([userId, createdAt])
}

model ExamSession {
  id           String            @id @default(cuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  examId       String?
  exam         Exam?             @relation(fields: [examId], references: [id], onDelete: SetNull)
  questionIds  Json
  answers      Json              @default("{}")
  currentIndex Int               @default(0)
  status       ExamSessionStatus @default(IN_PROGRESS)
  attemptId    String?           @unique
  attempt      ExamAttempt?      @relation("ExamSessionAttempt", fields: [attemptId], references: [id], onDelete: SetNull)
  /** Linear vs CAT; CAT uses `adaptiveState` for theta, difficulty history, incidents. */
  examMode     String            @default("linear") @map("exam_mode")
  adaptiveState Json?            @map("adaptive_state")
  timedMode    Boolean           @default(false)
  timeLimitSec Int?
  elapsedMs    Int?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([userId, status])
  @@index([examId])
}

/** Learner-built timed/untimed practice tests with saved progress and results. */
model PracticeTest {
  id           String             @id @default(cuid())
  userId       String
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  title        String?
  /** Build params: topics, selectionMode, difficulty bounds, pathwayId, etc. */
  config       Json
  questionIds  Json
  answers      Json               @default("{}")
  cursorIndex  Int                @default(0)
  status       PracticeTestStatus @default(IN_PROGRESS)
  timedMode    Boolean            @default(false)
  timeLimitSec Int?
  elapsedMs    Int?
  startedAt    DateTime           @default(now())
  completedAt  DateTime?
  /** Score, topic breakdown, weak areas — set when status = COMPLETED. */
  results      Json?
  /** CAT: theta, SE, item history, stop reason — updated each adaptive step. */
  adaptiveState Json?
  updatedAt    DateTime           @updatedAt

  @@index([userId, status, updatedAt])
  @@map("practice_tests")
}

model Progress {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String
  completed Boolean  @default(false)
  /** First insert time (lesson opened / progress row created). */
  createdAt DateTime @default(now())
  /** Set when learner crosses read-depth threshold (scroll) — optional; not started = no row. */
  engagedAt DateTime?
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId, updatedAt])
  /** Pathway progress summaries: prefix scan on lessonId after userId equality filter. */
  @@index([userId, lessonId, completed])
}

model BackgroundJob {
  id           String    @id @default(cuid())
  type         String
  payload      Json
  status       JobStatus @default(PENDING)
  attempts     Int       @default(0)
  maxAttempts  Int       @default(3)
  lastError    String?
  scheduledFor DateTime  @default(now())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status, scheduledFor])
  @@index([type])
}

/** One admin AI generation run (batch). */
model AiGenerationJob {
  id             String    @id @default(cuid())
  tool           String
  status         JobStatus @default(COMPLETED)
  model          String?
  sourcePrompt   String    @db.Text
  inputPayload   Json
  resultSummary  Json?
  error          String?   @db.Text
  tokensUsed     Int?
  /** Set when a lesson batch job is canceled via admin API (tool = ADMIN_LESSON_BATCH). */
  lessonBatchCanceledAt DateTime? @map("lesson_batch_canceled_at")
  createdById    String
  createdBy      User      @relation("AiJobCreatedBy", fields: [createdById], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  logs           AiGenerationLog[]
  questionDrafts GeneratedQuestionDraft[]
  flashcardDrafts GeneratedFlashcardDraft[]
  lessonDrafts   GeneratedLessonDraft[]
  lessonBatchQueueItems LessonBatchQueueItem[]

  @@index([tool, createdAt])
  @@index([createdById])
}

/** DB-backed queue for `/api/admin/lessons/ai-generate-batch` — enables atomic claim and item-level metrics. */
model LessonBatchQueueItem {
  id                  String                    @id @default(cuid())
  jobId               String
  job                 AiGenerationJob           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  /** Stable ordering within the batch (0-based). */
  position            Int
  /** Client-visible id (matches legacy JSON `itemId` / payload `batchItemId`). */
  publicItemId        String                    @unique
  topic               String                    @db.Text
  normalizedTopic     String                    @db.Text
  batchTopicKey       String                    @db.VarChar(40)
  status              LessonBatchQueueItemStatus @default(PENDING)
  attemptCount        Int                       @default(0)
  lastError           String?                   @db.Text
  lastAttemptAt       DateTime?
  completedAt         DateTime?
  skippedAt           DateTime?
  /** When the row was moved to CANCELLED (batch canceled or stale revive on a canceled job). */
  canceledAt          DateTime?
  startedAt           DateTime?
  claimedByRequestId  String?                   @db.VarChar(128)
  revivedAt           DateTime?
  revivalCount        Int                       @default(0)
  generatedDraftId    String?
  generatedDraft      GeneratedLessonDraft?     @relation("LessonBatchGeneratedDraft", fields: [generatedDraftId], references: [id], onDelete: SetNull)
  /** When status is SKIPPED_DUPLICATE — link to an existing draft with the same fingerprint. */
  existingDraftId     String?
  generatedDraftTitle String?                   @db.Text

  @@index([jobId, status, position])
  @@index([jobId, position])
  @@index([batchTopicKey])
  @@map("lesson_batch_queue_item")
}

/** Audit trail for AI steps (granular events under a job). */
model AiGenerationLog {
  id        String          @id @default(cuid())
  jobId     String
  job       AiGenerationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  step      String
  detail    Json?
  createdAt DateTime        @default(now())

  @@index([jobId])
}

