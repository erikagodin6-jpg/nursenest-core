# Copy to `.env.playwright.local` (gitignored) — never commit real credentials.
# Used by Playwright E2E paid/free login flows when vars are not set in the shell.
#
# E2E_ADMIN_EMAIL=qa-admin-e2e@example.invalid
# E2E_ADMIN_PASSWORD=use-a-throwaway-password-from-your-admin-seed
# Admin account must have DB role: ADMIN / SUPER_ADMIN / CONTENT_ADMIN / SUPPORT_ADMIN
#
# E2E_PAID_EMAIL=qa-paid-e2e@example.invalid
# E2E_PAID_PASSWORD=use-a-throwaway-password-from-your-staging-user
# E2E_FREE_EMAIL=qa-free-e2e@example.invalid
# E2E_FREE_PASSWORD=use-a-throwaway-password-from-your-staging-user
# Free account must be a normal learner role (non-admin / no staff privileges).
#
# Optional: point at a staging app, not production, for automated tests.
# BASE_URL=https://staging.example.com
