# -----------------------------------------------------------------------------
# NurseNest — example environment (SAFE TO COMMIT — placeholders only)
# Copy to `.env.local` or your host’s secret store. Never commit filled files.
# Policy: docs/SECRETS_AND_ENV.md
# -----------------------------------------------------------------------------

# --- Database (server only; never NEXT_PUBLIC_) ---
# Use placeholders locally; managed DB URLs belong in the host env only.
# Local CLI scripts (`npm run admin:qa-paid-test-reset`, etc.): they run in your terminal, not on DigitalOcean.
# `scripts/load-dotenv-for-cli.mts` loads `.env.local` → `.env.playwright.local` → `.env` from the `nursenest-core/`
# package folder (next to this repo’s app `package.json`), not from `process.cwd()`. Copy your DO `DATABASE_URL`
# into `.env.local` here so Prisma-backed scripts can connect.
# Canonical Postgres URL for the app and Prisma (pooled URI on DO is normal for runtime).
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
# Prisma schema `directUrl` — non-pooler Postgres URI for `prisma migrate` / introspection.
# If omitted, env-bootstrap mirrors DATABASE_URL with `pgbouncer` stripped (OK for single DB).
# DigitalOcean: use the "direct" / private host for migrations; "pooled" for app traffic.
# DATABASE_DIRECT_URL=postgresql://USER:PASSWORD@DIRECT_HOST:5432/DATABASE?sslmode=require
#
# Do not set PROD_DATABASE_URL — it is ignored. Use DATABASE_URL only (docs/database-environment.md).
#
# PgBouncer / DO connection pool: set so runtime can append `pgbouncer=true` (Prisma prepared-statement compat).
# You may also add `pgbouncer=true` directly to DATABASE_URL (e.g. for `prisma migrate` which does not load env-bootstrap).
# PRISMA_USE_PGBOUNCER=true

# --- Auth (server only) ---
AUTH_SECRET=replace-with-openssl-rand-base64-32-minimum-length-string
# NEXTAUTH_SECRET=  # legacy alias; prefer AUTH_SECRET

# --- App URLs ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# AUTH_URL=http://localhost:3000
# NEXTAUTH_URL=http://localhost:3000

# --- Stripe (server: sk_* / whsec_* ; client: pk_* only) ---
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# --- DigitalOcean Spaces (S3-compatible; server only) ---
SPACES_KEY=
SPACES_SECRET=
SPACES_REGION=tor1
SPACES_BUCKET=
# SPACES_ENDPOINT=
# SPACES_EXTRA_PUBLIC_BASES=

# --- Email (e.g. Resend) ---
# Required in production for password reset emails (`/api/auth/forgot-password`) and related flows.
# RESEND_API_KEY=
# Optional sender for password reset (defaults to Resend onboarding domain in dev).
# PASSWORD_RESET_EMAIL_FROM="NurseNest <noreply@yourdomain.com>"

# --- Marketing / auth UX (optional) ---
# Set to "1" only during a known sign-in or email outage to show a temporary incident notice on /login.
# Leave unset in normal production so “Forgot password?” and self-serve recovery stay primary.
# NEXT_PUBLIC_AUTH_INCIDENT_NOTICE=

# --- Node / memory (production standalone server via `npm run start`; optional) ---
# Bounds V8 heap for the server process — set lower on small droplets (e.g. 384 on 1 GB RAM).
# NODE_MAX_OLD_SPACE_SIZE_MB=512
# Periodic RSS/heap logs (ms). Default 600000 (10 min) in production when unset. Use 0 to disable.
# PERF_MEMORY_LOG_INTERVAL_MS=
# Emit `memory_pressure` when process RSS exceeds this % of cgroup limit or host RAM (default 70).
# PERF_MEMORY_RSS_WARN_PCT=70

# --- Resilience / load (optional) ---
# Cap concurrent Prisma ops per Node process (queues when busy; default 22).
# NN_DB_MAX_CONCURRENT_QUERIES=22
# Log API Route Handler duration when over N ms (use with logSlowApiResponse in hot routes).
# NN_SLOW_API_LOG_MS=3000

# --- Horizontal scale (Postgres-backed; set explicitly only if you need to opt into distributed limits in dev) ---
# In production with DATABASE_URL, rate limits and login lockout use shared DB tables automatically.
# RATE_LIMIT_DISTRIBUTED=true
# LOGIN_LOCKOUT_DISTRIBUTED=true

# --- Cron / internal APIs ---
# CRON_SECRET=replace-with-long-random-string

# --- Playwright E2E (local only; see .env.playwright.example) ---
# E2E_PAID_EMAIL=
# E2E_PAID_PASSWORD=
# E2E_FREE_EMAIL=
# E2E_FREE_PASSWORD=
