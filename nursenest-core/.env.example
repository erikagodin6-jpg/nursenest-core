# NurseNest — example environment (copy to `.env.local` for local dev).
# Never commit real secrets. Validation: `npm run env:validate` / `npm run env:validate:production`

# --- Database (Prisma) ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST_DIRECT:PORT/DATABASE?sslmode=require

# --- Auth (Auth.js / NextAuth JWT signing) ---
# Required for local learner app: set AUTH_SECRET (preferred) or NEXTAUTH_SECRET (legacy).
# Generate: openssl rand -base64 32
AUTH_SECRET=
NEXTAUTH_SECRET=
AUTH_URL=http://127.0.0.1:3000
NEXTAUTH_URL=http://127.0.0.1:3000

# --- Public origin ---
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs — Canonical (STRIPE_PRICE_NURSENEST_*) — set these in production.
# Runtime resolves canonical keys first; legacy aliases below serve as fallback.

# New Grad (legacy format — no canonical key yet)
STRIPE_PRICE_NEW_GRAD_MONTHLY=
STRIPE_PRICE_NEW_GRAD_6MONTH=
STRIPE_PRICE_NEW_GRAD_YEARLY=

# LVN/LPN / NCLEX-PN (legacy format — no canonical key yet)
STRIPE_PRICE_LVN_LPN_MONTHLY=
STRIPE_PRICE_LVN_LPN_3MONTH=
STRIPE_PRICE_LVN_LPN_6MONTH=
STRIPE_PRICE_LVN_LPN_YEARLY=

# RPN / REx-PN (Canada)
STRIPE_PRICE_NURSENEST_RPN_1_MONTH_SUBSCRIPTION=
STRIPE_PRICE_NURSENEST_RPN_3_MONTH_SUBSCRIPTION=
STRIPE_PRICE_NURSENEST_RPN_6_MONTH_SUBSCRIPTION=
STRIPE_PRICE_NURSENEST_RPN_YEARLY_SUBSCRIPTION=

# RN / NCLEX-RN
STRIPE_PRICE_NURSENEST_RN_1_MONTH_SUBSCRIPTION=
STRIPE_PRICE_NURSENEST_RN_3_MONTH_SUBSCRIPTION=
STRIPE_PRICE_NURSENEST_RN_6_MONTH_SUBSCRIPTION=
STRIPE_PRICE_NURSENEST_RN_1_YEAR_SUBSCRIPTION=

# NP / Nurse Practitioner
STRIPE_PRICE_NURSENEST_NP_1_MONTH_SUBSCRIPTION=
STRIPE_PRICE_NURSENEST_NP_3_MONTH_SUBSCRIPTION=
STRIPE_PRICE_NURSENEST_NP_6_MONTH_SUBSCRIPTION=
STRIPE_PRICE_NURSENEST_NP_1_YEAR_SUBSCRIPTION=

# Allied Health — shared keys (preferred: one price id covers all 7 careers per duration)
# When set, these override per-career keys below for all allied checkouts.
STRIPE_PRICE_NURSENEST_ALLIED_HEALTH_EXAM_PREP_MONTHLY=
STRIPE_PRICE_NURSENEST_ALLIED_HEALTH_EXAM_PREP_3_MONTHS=
STRIPE_PRICE_NURSENEST_ALLIED_HEALTH_6_MONTH_SUBSCRIPTION=
STRIPE_PRICE_NURSENEST_ALLIED_HEALTH_EXAM_PREP_YEARLY=

# Allied Health — per-career fallback (only needed when shared keys above are NOT set)
STRIPE_PRICE_NURSENEST_ALLIED_PARAMEDIC_MONTHLY=
STRIPE_PRICE_NURSENEST_ALLIED_PARAMEDIC_3MONTH=
STRIPE_PRICE_NURSENEST_ALLIED_PARAMEDIC_6MONTH=
STRIPE_PRICE_NURSENEST_ALLIED_PARAMEDIC_YEARLY=
STRIPE_PRICE_NURSENEST_ALLIED_RRT_MONTHLY=
STRIPE_PRICE_NURSENEST_ALLIED_RRT_3MONTH=
STRIPE_PRICE_NURSENEST_ALLIED_RRT_6MONTH=
STRIPE_PRICE_NURSENEST_ALLIED_RRT_YEARLY=
STRIPE_PRICE_NURSENEST_ALLIED_MLT_MONTHLY=
STRIPE_PRICE_NURSENEST_ALLIED_MLT_3MONTH=
STRIPE_PRICE_NURSENEST_ALLIED_MLT_6MONTH=
STRIPE_PRICE_NURSENEST_ALLIED_MLT_YEARLY=
STRIPE_PRICE_NURSENEST_ALLIED_IMAGING_MONTHLY=
STRIPE_PRICE_NURSENEST_ALLIED_IMAGING_3MONTH=
STRIPE_PRICE_NURSENEST_ALLIED_IMAGING_6MONTH=
STRIPE_PRICE_NURSENEST_ALLIED_IMAGING_YEARLY=
STRIPE_PRICE_NURSENEST_ALLIED_OTA_PTA_MONTHLY=
STRIPE_PRICE_NURSENEST_ALLIED_OTA_PTA_3MONTH=
STRIPE_PRICE_NURSENEST_ALLIED_OTA_PTA_6MONTH=
STRIPE_PRICE_NURSENEST_ALLIED_OTA_PTA_YEARLY=
STRIPE_PRICE_NURSENEST_ALLIED_PHARMTECH_MONTHLY=
STRIPE_PRICE_NURSENEST_ALLIED_PHARMTECH_3MONTH=
STRIPE_PRICE_NURSENEST_ALLIED_PHARMTECH_6MONTH=
STRIPE_PRICE_NURSENEST_ALLIED_PHARMTECH_YEARLY=
STRIPE_PRICE_NURSENEST_ALLIED_SOCIALWORK_MONTHLY=
STRIPE_PRICE_NURSENEST_ALLIED_SOCIALWORK_3MONTH=
STRIPE_PRICE_NURSENEST_ALLIED_SOCIALWORK_6MONTH=
STRIPE_PRICE_NURSENEST_ALLIED_SOCIALWORK_YEARLY=

# Advanced ECG add-on (single price — duration variant is metadata only)
STRIPE_PRICE_ADVANCED_ECG=price_1TVo8vFbgp0Ub5P7aTySWrbU

# Stripe Price IDs — Legacy aliases (deprecated fallbacks; remove once canonical keys are deployed)
# These are read only when the canonical key above is not set.
# STRIPE_PRICE_RPN_MONTHLY=
# STRIPE_PRICE_RPN_3MONTH=
# STRIPE_PRICE_RPN_6MONTH=
# STRIPE_PRICE_RPN_YEARLY=
# STRIPE_PRICE_RN_MONTHLY=
# STRIPE_PRICE_RN_3MONTH=
# STRIPE_PRICE_RN_6MONTH=
# STRIPE_PRICE_RN_YEARLY=
# STRIPE_PRICE_NP_MONTHLY=
# STRIPE_PRICE_NP_3MONTH=
# STRIPE_PRICE_NP_6MONTH=
# STRIPE_PRICE_NP_YEARLY=
# STRIPE_PRICE_ALLIED_MONTHLY=
# STRIPE_PRICE_ALLIED_3MONTH=
# STRIPE_PRICE_ALLIED_6MONTH=
# STRIPE_PRICE_ALLIED_YEARLY=

# --- PostHog ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=

# --- Cron ---
CRON_SECRET=

# --- Reliability probes ---
NURSENEST_RELIABILITY_SECRET=

# --- i18n ---
SKIP_I18N_PREBUILD=0
NEXT_PUBLIC_ENABLE_MULTILINGUAL_ROLLOUT=false

# --- Optional ---
# NN_ENV_BOOT_DIAGNOSTICS=1
# NN_STRICT_PRODUCTION_ENV=1
# NN_DATABASE_URL_SHAPE_GUARD=1
# NN_PRISMA_HEALTH_SKIP_MIGRATE_STATUS=1

AI_ADMIN_GENERATION_ENABLED=false
# Blog / marketing AI: OpenRouter is preferred when OPENROUTER_API_KEY is present.
# OpenAI blog generation requires an explicit BLOG_AI_PROVIDER=openai opt-in.
# AI_PROVIDER=openrouter
# BLOG_AI_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_HTTP_REFERER=https://nursenest.ca
OPENROUTER_APP_TITLE=NurseNest
AI_INTEGRATIONS_OPENAI_API_KEY=
OPENAI_API_KEY=
BLOG_OPENAI_API_KEY=
BLOG_OPENAI_MODEL=
AI_INTEGRATIONS_OPENAI_MODEL=

# ─── Resilience: Redis (Upstash REST / Railway Redis HTTP adapter) ────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Resilience: DigitalOcean Spaces (S3-compatible snapshot storage) ────────
SPACES_ENDPOINT=https://tor1.digitaloceanspaces.com
SPACES_BUCKET=nursenest-resilience
SPACES_KEY=
SPACES_SECRET=
SPACES_REGION=us-east-1
SPACES_PREFIX=content-snapshots
# SPACES_ACL=public-read
# SPACES_DRY_RUN=false

# ─── Resilience: Snapshot filesystem path ────────────────────────────────────
STUDY_PUBLISHED_SNAPSHOT_DIR=/var/nursenest/snapshots
# Dev override: STUDY_PUBLISHED_SNAPSHOT_DIR=./.snapshots
