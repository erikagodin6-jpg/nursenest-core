# -----------------------------------------------------------------------------
# NurseNest — example environment (SAFE TO COMMIT — placeholders only)
# Copy to `.env.local` or your host’s secret store. Never commit filled files.
# Policy: docs/SECRETS_AND_ENV.md
# Full reference: docs/environment-reference.md
# -----------------------------------------------------------------------------

# --- Database (server only; never NEXT_PUBLIC_) ---
# Local CLI scripts load `.env.local` → `.env.playwright.local` → `.env` from
# this package folder via `scripts/load-dotenv-for-cli.mts`.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
# Prisma `directUrl` — non-pooler URI for migrate / introspection.
# Legacy alias: DATABASE_DIRECT_URL (env-bootstrap maps to DIRECT_URL if DIRECT_URL unset).
# DIRECT_URL=postgresql://USER:PASSWORD@DIRECT_HOST:5432/DATABASE?sslmode=require
# Do not set PROD_DATABASE_URL — ignored. Use DATABASE_URL only.
# PRISMA_USE_PGBOUNCER=true
# PRISMA_CONNECTION_LIMIT= / PRISMA_POOL_TIMEOUT= / PRISMA_STATEMENT_TIMEOUT_MS= / PRISMA_CONNECT_TIMEOUT_SEC=

# --- Auth (server only) ---
AUTH_SECRET=replace-with-openssl-rand-base64-32-minimum-length-string
# NEXTAUTH_SECRET=  # legacy alias; prefer AUTH_SECRET
# Public origin (no path). Recommended in production for correct callbacks.
# AUTH_URL=https://app.example.com
# NEXTAUTH_URL=https://app.example.com

# --- Public app origin (build + runtime; exposed to client as NEXT_PUBLIC_) ---
# Required in production (production-env-guard). Stripe return URLs, absolute links.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional marketing/legal surfaces (see code usages under NEXT_PUBLIC_*).
# NEXT_PUBLIC_SITE_URL=
# NEXT_PUBLIC_SUPPORT_EMAIL=
# NEXT_PUBLIC_BUSINESS_PHONE=
# NEXT_PUBLIC_LEGAL_ENTITY_NAME=
# NEXT_PUBLIC_LEGAL_MAILING_ADDRESS=

# --- Stripe (server only for secrets) ---
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
# Live production webhook URL (must match TLS hostname Stripe calls): https://www.nursenest.ca/api/subscriptions/webhook
# Set STRIPE_WEBHOOK_SECRET to the Signing secret (whsec_…) of that Dashboard endpoint — if you create a new endpoint, update this env to its new secret before sending traffic.
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
# STRIPE_WEBHOOK_TOLERANCE_SECONDS=
# STRIPE_RECONCILE_CRON_APPLY=
# Nursing + allied catalog: STRIPE_PRICE_<TIER>_<MONTHLY|3MONTH|6MONTH|YEARLY> and STRIPE_PRICE_ALLIED_<CAREER>_*
# Global regional checkout: STRIPE_PRICE_<REGION>_<NURSING|ALLIED>_<MONTHLY|3MONTH|6MONTH|YEARLY>
# Generate the full matrix from Stripe Dashboard; see src/lib/stripe/pricing-map.ts and src/lib/pricing/regional-pricing-map.ts.
# (No STRIPE_PUBLISHABLE_KEY in this codebase — checkout is server-driven.)

# --- DigitalOcean Spaces (S3-compatible; server only) ---
SPACES_KEY=
SPACES_SECRET=
SPACES_REGION=tor1
SPACES_BUCKET=
# SPACES_ENDPOINT=
# SPACES_EXTRA_PUBLIC_BASES=

# --- Email (Resend; server only) ---
# RESEND_API_KEY=
# PASSWORD_RESET_EMAIL_FROM="NurseNest <noreply@yourdomain.com>"
# RETENTION_EMAIL_FROM=

# --- Captcha (Cloudflare Turnstile) ---
# Site key is public; secret must never be NEXT_PUBLIC_.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
# If TURNSTILE_SECRET_KEY is unset, server verify is fail-open (captcha effectively off).

# --- Redis / distributed limits (Upstash; server only) ---
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# If unset: in-memory / DB fallbacks per feature (rate limits may not share across instances).

# --- PostHog ---
# Browser: project key + host (inlined at build for client bundle).
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Server capture: prefer POSTHOG_KEY (falls back to NEXT_PUBLIC_POSTHOG_KEY if only client key is set).
# POSTHOG_KEY=
# POSTHOG_HOST=https://us.i.posthog.com
# Admin HogQL (personal API key — never expose): POSTHOG_PERSONAL_API_KEY + POSTHOG_PROJECT_ID

# --- Sentry ---
# SENTRY_ENABLED=true
# NEXT_PUBLIC_SENTRY_ENABLED=true   # optional; defaults from SENTRY_ENABLED at build if omitted
# SENTRY_DSN= / NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ENVIRONMENT= / NEXT_PUBLIC_SENTRY_ENVIRONMENT=
# SENTRY_RELEASE= / NEXT_PUBLIC_SENTRY_RELEASE=
# SENTRY_TRACES_SAMPLE_RATE= / NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=
# SENTRY_PROFILES_SAMPLE_RATE=0
# Session replay (browser): NEXT_PUBLIC_SENTRY_REPLAY_ENABLED= / NEXT_PUBLIC_SENTRY_REPLAY_SESSION_SAMPLE_RATE= / NEXT_PUBLIC_SENTRY_REPLAY_ON_ERROR_SAMPLE_RATE=
# Source maps at build (never runtime): SENTRY_AUTH_TOKEN= SENTRY_ORG= SENTRY_PROJECT=

# --- Inngest (self-hosted route /api/inngest) ---
# SDK reads standard Inngest signing keys from the environment when deployed to Inngest Cloud.
# INNGEST_EVENT_KEY= / INNGEST_SIGNING_KEY=  (see Inngest docs; not hard-coded in repo)

# --- AI (optional admin / learner surfaces) ---
# OPENAI_API_KEY=   # or AI_INTEGRATIONS_OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# AI_INTEGRATIONS_OPENAI_BASE_URL=
# AI_OPENAI_MODEL= / AI_ADMIN_MODEL=
# AI_ADMIN_GENERATION_ENABLED=true   # or 1, yes, on (trimmed, case-insensitive)
# NN_ADMIN_AI_GATE_DIAGNOSTIC_LOG=1  # optional: log one redacted admin-AI gate snapshot outside production
# AI_STUDY_COACH_ENABLED= / AI_STUDY_PLAN_ENABLED= / AI_TUTOR_SURFACE_ENABLED=
# GEMINI_API_KEY= / GEMINI_MODEL=gemini-2.5-flash

# --- Cron & internal jobs ---
# CRON_SECRET=   # POST /api/cron/* Authorization: Bearer …
# NURSE_NEST_ENFORCE_CRON_SECRET=  # stricter policy when set (see enforce-cron-secret)

# --- Trial / abuse (server) ---
# TRIAL_FINGERPRINT_SECRET=   # defaults to AUTH_SECRET then dev-only string if unset
# TRIAL_STRIPE_EMAIL_CHECK=

# --- Marketing CDN / home diagnostics (optional) ---
# NEXT_PUBLIC_MARKETING_CDN_BASE= / NEXT_PUBLIC_MARKETING_USE_SPACES_PROXY=
# MARKETING_I18N_CDN_BASE=
# MARKETING_HOME_SKIP_OPTIONAL_DB=  # optional: "true" = never hit optional home DB (stats/blog shell);
#   "false" = always try DB (including during `next build` static gen — needs DATABASE_URL). When unset,
#   optional reads skip only while NEXT_PHASE=phase-production-build (see default home page).
# NEXT_PUBLIC_NN_DEGRADED_MODE= / NN_DEGRADED_MODE=
# NEXT_PUBLIC_NN_CORE_ONLY_EMERGENCY= / NN_CORE_ONLY_EMERGENCY=

# --- Conversion / premium UX (server) ---
# NN_CONVERSION_VARIANT=default|urgency|outcome
# PREMIUM_COPY_DETERRENCE= / PREMIUM_WATERMARK= / PREMIUM_PRINT_HIDE_PROTECTED= / PREMIUM_BLUR_ON_TAB_HIDDEN=

# --- Build & deploy (DigitalOcean App Platform / CI) ---
# Source directory for DO should be `nursenest-core` (see next.config.ts header).
# NN_BUILD_SAFE_MODE=1          # build only: trim heavy sitemap SEO fan-out (src/lib/build/build-safe-mode.ts)
# RUN_HEAVY_BUILD_TASKS=false   # default in package.json build; heavy redirect graphs
# RUNTIME_SAFE_MODE=            # runtime: skip non-essential DB reads (src/lib/runtime/safe-mode.ts)
# SKIP_I18N_PREBUILD=           # set in npm build script; optional override
# BUILD_WEBPACK_PARALLELISM=1
# BUILD_NODE_MAX_OLD_SPACE_SIZE_MB=4096   # used by run-next-prod-build.mjs / package.json for next build heap
# SENTRY_ENABLED=false          # default in npm build to skip requiring Sentry at compile

# --- Strict checks ---
# NN_STRICT_PRODUCTION_ENV=1   # exit on critical env_guard issues (production only)
# NN_STRICT_PUBLIC_ENV=        # stricter public env checks when enabled

# --- Node / memory (production `npm run start`) ---
# NODE_MAX_OLD_SPACE_SIZE_MB=
# PERF_MEMORY_LOG_INTERVAL_MS= / PERF_MEMORY_RSS_WARN_PCT=

# --- Ops tuning (optional; see docs/environment-reference.md) ---
# NN_DB_MAX_CONCURRENT_QUERIES= / NN_SLOW_API_LOG_MS= / NN_ENABLE_RATE_LIMITING=
# RATE_LIMIT_DISTRIBUTED= / LOGIN_LOCKOUT_DISTRIBUTED=

# --- Marketing / auth UX ---
# NEXT_PUBLIC_AUTH_INCIDENT_NOTICE=

# --- Playwright E2E (local only) ---
# See `.env.playwright.example` — E2E_*, PLAYWRIGHT_*, BASE_URL, etc.
