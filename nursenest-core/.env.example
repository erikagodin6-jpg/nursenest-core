# -----------------------------------------------------------------------------
# NurseNest — example environment (SAFE TO COMMIT — placeholders only)
# Copy to `.env.local` or your host’s secret store. Never commit filled files.
# Policy: docs/SECRETS_AND_ENV.md
# -----------------------------------------------------------------------------

# --- Database (server only; never NEXT_PUBLIC_) ---
# Use placeholders locally; managed DB URLs belong in the host env only.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
# Optional legacy alias (see src/lib/db/env-bootstrap.ts) — prefer DATABASE_URL
# PROD_DATABASE_URL=

# --- Auth (server only) ---
AUTH_SECRET=replace-with-openssl-rand-base64-32-minimum-length-string
# NEXTAUTH_SECRET=  # legacy alias; prefer AUTH_SECRET

# --- App URLs ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# AUTH_URL=http://localhost:3000
# NEXTAUTH_URL=http://localhost:3000

# --- Stripe (server: sk_* / whsec_* ; client: pk_* only) ---
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# --- DigitalOcean Spaces (S3-compatible; server only) ---
SPACES_KEY=
SPACES_SECRET=
SPACES_REGION=tor1
SPACES_BUCKET=
# SPACES_ENDPOINT=
# SPACES_EXTRA_PUBLIC_BASES=

# --- Email (e.g. Resend) ---
# RESEND_API_KEY=

# --- Cron / internal APIs ---
# CRON_SECRET=replace-with-long-random-string

# --- Playwright E2E (local only; see .env.playwright.example) ---
# E2E_PAID_EMAIL=
# E2E_PAID_PASSWORD=
# E2E_FREE_EMAIL=
# E2E_FREE_PASSWORD=
