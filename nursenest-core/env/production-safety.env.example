# Production safety toggles (copy into your real env; defaults in code favor protection when unset).
# Auth, entitlements, and admin RBAC are NOT controlled here.

# Tier-2 learner degradation (skips optional panels; does not weaken paid access checks).
NN_DEGRADED_MODE=false
NEXT_PUBLIC_NN_DEGRADED_MODE=false

# Operational guards (default ON when unset — set to false only for local debugging).
NN_ENABLE_RATE_LIMITING=true
NN_ENABLE_CIRCUIT_BREAKER=true
NN_ENABLE_QUERY_TIMEOUTS=true
NN_ENABLE_RESPONSE_GUARD=true

# Infrastructure (set in DigitalOcean / Vercel / etc. — not read by this file):
# - instance_count >= 2 or autoscaling min >= 2
# - Managed Postgres with failover + daily backups
# - SENTRY_ENABLED=true for production error monitoring
