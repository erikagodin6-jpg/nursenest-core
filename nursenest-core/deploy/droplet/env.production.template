# NurseNest Core — production environment (Droplet)
# Copy to a path OUTSIDE git (e.g. /var/www/nursenest/env/.env.production).
# Never commit real values.

NODE_ENV=production
PORT=3000
TMPDIR=/tmp

# --- Database (managed Postgres recommended) ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/db?sslmode=require
# Optional legacy fallback if DATABASE_URL empty in prod (prefer setting DATABASE_URL only):
# PROD_DATABASE_URL=

# --- Auth (required in production) ---
AUTH_SECRET=
# AUTH_URL=https://your-public-domain.com
# NEXTAUTH_URL=https://your-public-domain.com
NEXT_PUBLIC_APP_URL=https://your-public-domain.com

# Trust reverse proxy (also defaulted in next.config; set explicitly if you prefer)
AUTH_TRUST_HOST=true

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price / plan envs as already used in your App Platform project — copy verbatim.

# --- DigitalOcean Spaces (optional; for uploads / asset proxy) ---
# SPACES_KEY=
# SPACES_SECRET=
# SPACES_BUCKET=nursenest-images
# SPACES_REGION=tor1
# SPACES_ENDPOINT=
# NEXT_PUBLIC_MARKETING_USE_SPACES_PROXY=false

# --- Email (password reset, etc.) ---
# RESEND_API_KEY=
# PASSWORD_RESET_EMAIL_FROM=

# --- Sentry (optional) ---
# SENTRY_AUTH_TOKEN=           # build-time source maps only
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production

# --- Ops tuning ---
# PERF_MEMORY_LOG_INTERVAL_MS=0
