#!/usr/bin/env tsx
import { existsSync, mkdirSync, readFileSync, writeFileSync } from "node:fs";
import { resolve } from "node:path";
import { parse as parseDotenv } from "dotenv";
import { PrismaClient } from "@prisma/client";

import {
  auditQuestionEnrichment,
  summarizeQuestionEnrichment,
  QUESTION_ENRICHMENT_TARGET_EXAMS,
  type QuestionEnrichmentAuditResult,
  type QuestionEnrichmentPathwayGroup,
} from "../src/lib/questions/question-enrichment-governance";

function loadEnv(): void {
  for (const name of [".env", ".env.local", ".env.production"]) {
    const file = resolve(process.cwd(), name);
    if (!existsSync(file)) continue;
    const parsed = parseDotenv(readFileSync(file, "utf8"));
    for (const [key, value] of Object.entries(parsed)) {
      if (process.env[key] === undefined) process.env[key] = value;
    }
  }
}

function pct(part: number, whole: number): number {
  return whole > 0 ? Number(((part / whole) * 100).toFixed(1)) : 0;
}

function avg(values: number[]): number {
  return values.length ? Math.round(values.reduce((sum, value) => sum + value, 0) / values.length) : 0;
}

function mdTable(rows: string[][]): string[] {
  if (rows.length === 0) return [];
  const header = rows[0]!;
  return [
    `| ${header.join(" |")} |`,
    `| ${header.map(() => "---").join(" |")} |`,
    ...rows.slice(1).map((row) => `| ${row.map((cell) => String(cell).replace(/\|/g, "\\|")).join(" |")} |`),
  ];
}

function groupResults(results: QuestionEnrichmentAuditResult[], group: QuestionEnrichmentPathwayGroup): QuestionEnrichmentAuditResult[] {
  return results.filter((result) => result.pathwayGroup === group);
}

function readinessLines(results: QuestionEnrichmentAuditResult[]): string[] {
  const total = results.length;
  return [
    `- Questions audited: ${total}`,
    `- Publication-ready: ${results.filter((r) => r.publicationReady).length} (${pct(results.filter((r) => r.publicationReady).length, total)}%)`,
    `- Flashcard-ready: ${results.filter((r) => r.flashcardReady).length} (${pct(results.filter((r) => r.flashcardReady).length, total)}%)`,
    `- Practice-exam-ready: ${results.filter((r) => r.practiceExamReady).length} (${pct(results.filter((r) => r.practiceExamReady).length, total)}%)`,
    `- CAT-ready: ${results.filter((r) => r.catReady).length} (${pct(results.filter((r) => r.catReady).length, total)}%)`,
    `- Adaptive-learning-ready: ${results.filter((r) => r.adaptiveLearningReady).length} (${pct(results.filter((r) => r.adaptiveLearningReady).length, total)}%)`,
    `- Monetization-ready: ${results.filter((r) => r.monetizationReady).length} (${pct(results.filter((r) => r.monetizationReady).length, total)}%)`,
    `- Average overall quality: ${avg(results.map((r) => r.scores.overallQuality))}`,
  ];
}

function weakestRows(results: QuestionEnrichmentAuditResult[], limit = 25): string[][] {
  return [
    ["ID", "Exam", "Score", "Band", "Missing Fields"],
    ...results
      .slice()
      .sort((a, b) => a.scores.overallQuality - b.scores.overallQuality)
      .slice(0, limit)
      .map((result) => [
        result.id,
        result.exam,
        String(result.scores.overallQuality),
        result.qualityBand,
        result.missingFields.join(", "),
      ]),
  ];
}

function writeGroupReport(outDir: string, fileName: string, title: string, results: QuestionEnrichmentAuditResult[]): void {
  writeFileSync(
    resolve(outDir, fileName),
    [
      `# ${title}`,
      "",
      `Generated: ${new Date().toISOString()}`,
      "",
      "## Readiness",
      "",
      ...readinessLines(results),
      "",
      "## Weakest Items",
      "",
      ...mdTable(weakestRows(results)),
      "",
      "## Remediation Rule",
      "",
      "Questions below `90/100` are not publication-ready. Remediation drafts generated by the audit are authoring aids only and remain unpublished until clinical, educational, SEO, accessibility, and localization review gates pass.",
      "",
    ].join("\n"),
  );
}

function writeReadinessReport(outDir: string, fileName: string, title: string, results: QuestionEnrichmentAuditResult[], selector: (r: QuestionEnrichmentAuditResult) => boolean): void {
  const ready = results.filter(selector);
  writeFileSync(
    resolve(outDir, fileName),
    [
      `# ${title}`,
      "",
      `Generated: ${new Date().toISOString()}`,
      "",
      `- Ready: ${ready.length} / ${results.length} (${pct(ready.length, results.length)}%)`,
      `- Not ready: ${results.length - ready.length}`,
      "",
      "## Not Ready Items",
      "",
      ...mdTable(weakestRows(results.filter((result) => !selector(result)), 50)),
      "",
    ].join("\n"),
  );
}

function writeDatabaseUnavailableReports(outDir: string, reason: string): void {
  const generatedAt = new Date().toISOString();
  const base = [
    "Generated: " + generatedAt,
    "",
    "The live `exam_questions` inventory was not audited because the database was unavailable in this environment.",
    "",
    `Reason: ${reason.replace(/\s+/g, " ").slice(0, 500)}`,
    "",
    "Run against a reachable read-only staging or production database:",
    "",
    "`npx tsx scripts/audit-rn-rpn-np-question-enrichment.mts`",
    "",
    "The audit engine and contract tests remain available without database access.",
    "",
  ].join("\n");

  const files: Array<[string, string]> = [
    ["rn-audit-report.md", "RN Question Enrichment Audit Report"],
    ["rpn-audit-report.md", "RPN / PN Question Enrichment Audit Report"],
    ["np-audit-report.md", "NP Question Enrichment Audit Report"],
    ["blueprint-coverage-report.md", "Blueprint Coverage Report"],
    ["question-quality-report.md", "Question Quality Report"],
    ["flashcard-readiness-report.md", "Flashcard Readiness Report"],
    ["practice-exam-readiness-report.md", "Practice Exam Readiness Report"],
    ["cat-readiness-report.md", "CAT Readiness Report"],
    ["publication-readiness-report.md", "Publication Readiness Report"],
    ["monetization-readiness-report.md", "Monetization Readiness Report"],
    ["estimated-remediation-work-remaining.md", "Estimated Remediation Work Remaining"],
  ];

  for (const [file, title] of files) {
    writeFileSync(resolve(outDir, file), [`# ${title}`, "", base].join("\n"));
  }
}

async function main(): Promise<void> {
  loadEnv();
  const outDir = resolve(process.cwd(), "docs/reports/question-enrichment");
  mkdirSync(outDir, { recursive: true });

  if (!process.env.DATABASE_URL?.trim()) {
    const note = [
      "# RN / RPN / NP Question Enrichment Audit",
      "",
      `Generated: ${new Date().toISOString()}`,
      "",
      "DATABASE_URL is unset, so the live question inventory was not queried.",
      "",
      "Run with a read-only production or staging database connection:",
      "",
      "`npx tsx scripts/audit-rn-rpn-np-question-enrichment.mts`",
      "",
    ].join("\n");
    writeFileSync(resolve(outDir, "question-quality-report.md"), note);
    console.log("DATABASE_URL is unset; wrote audit runner note.");
    return;
  }

  const limit = Math.max(1, Number.parseInt(process.env.NN_QUESTION_ENRICHMENT_AUDIT_LIMIT ?? "100000", 10));
  const prisma = new PrismaClient();

  try {
    const rows = await prisma.examQuestion.findMany({
      where: {
        OR: [
          { exam: { in: [...QUESTION_ENRICHMENT_TARGET_EXAMS] } },
          { tier: { in: ["RN", "RPN", "PN", "LPN", "NP"] } },
        ],
      },
      orderBy: [{ updatedAt: "desc" }],
      take: limit,
      select: {
        id: true,
        exam: true,
        tier: true,
        countryCode: true,
        languageCode: true,
        status: true,
        questionType: true,
        stem: true,
        options: true,
        correctAnswer: true,
        rationale: true,
        correctAnswerExplanation: true,
        distractorRationales: true,
        incorrectAnswerRationale: true,
        clinicalReasoning: true,
        clinicalPearl: true,
        examStrategy: true,
        clinicalTrap: true,
        memoryHook: true,
        mnemonic: true,
        keyTakeaway: true,
        difficulty: true,
        cognitiveLevel: true,
        bodySystem: true,
        topic: true,
        subtopic: true,
        nclexClientNeedsCategory: true,
        nclexClientNeedsSubcategory: true,
        tags: true,
        isMockExamEligible: true,
        isAdaptiveEligible: true,
        isFlashcardSource: true,
        blueprintWeight: true,
      },
    });

    const results = rows.map((row) => auditQuestionEnrichment(row));
    const summary = summarizeQuestionEnrichment(results);
    writeFileSync(resolve(outDir, "question-enrichment-audit.json"), JSON.stringify({ generatedAt: new Date().toISOString(), summary, results }, null, 2));

    writeGroupReport(outDir, "rn-audit-report.md", "RN Question Enrichment Audit Report", groupResults(results, "RN"));
    writeGroupReport(outDir, "rpn-audit-report.md", "RPN / PN Question Enrichment Audit Report", groupResults(results, "RPN_PN"));
    writeGroupReport(outDir, "np-audit-report.md", "NP Question Enrichment Audit Report", groupResults(results, "NP"));

    writeReadinessReport(outDir, "flashcard-readiness-report.md", "Flashcard Readiness Report", results, (r) => r.flashcardReady);
    writeReadinessReport(outDir, "practice-exam-readiness-report.md", "Practice Exam Readiness Report", results, (r) => r.practiceExamReady);
    writeReadinessReport(outDir, "cat-readiness-report.md", "CAT Readiness Report", results, (r) => r.catReady);
    writeReadinessReport(outDir, "publication-readiness-report.md", "Publication Readiness Report", results, (r) => r.publicationReady);
    writeReadinessReport(outDir, "monetization-readiness-report.md", "Monetization Readiness Report", results, (r) => r.monetizationReady);

    const byExam = new Map<string, QuestionEnrichmentAuditResult[]>();
    for (const result of results) {
      byExam.set(result.exam, [...(byExam.get(result.exam) ?? []), result]);
    }

    const blueprintRows = [
      ["Exam", "Questions", "Blueprint Missing", "Difficulty Missing", "Cognitive Missing", "Average Score"],
      ...[...byExam.entries()].map(([exam, rowsForExam]) => {
        return [
          exam,
          String(rowsForExam.length),
          String(rowsForExam.filter((r) => r.missingFields.includes("blueprint_mapping")).length),
          String(rowsForExam.filter((r) => r.missingFields.includes("difficulty_rating")).length),
          String(rowsForExam.filter((r) => r.missingFields.includes("cognitive_classification")).length),
          String(avg(rowsForExam.map((r) => r.scores.overallQuality))),
        ];
      }),
    ];

    writeFileSync(
      resolve(outDir, "blueprint-coverage-report.md"),
      ["# Blueprint Coverage Report", "", `Generated: ${new Date().toISOString()}`, "", ...mdTable(blueprintRows), ""].join("\n"),
    );

    writeFileSync(
      resolve(outDir, "question-quality-report.md"),
      [
        "# Question Quality Report",
        "",
        `Generated: ${new Date().toISOString()}`,
        "",
        "## Gap Analysis",
        "",
        `- Total Questions Audited: ${summary.totalQuestionsAudited}`,
        `- Questions Missing Rationales: ${summary.questionsMissingRationales}`,
        `- Questions Missing Hints: ${summary.questionsMissingHints}`,
        `- Questions Missing Clinical Pearls: ${summary.questionsMissingClinicalPearls}`,
        `- Questions Missing Metadata: ${summary.questionsMissingMetadata}`,
        `- Questions Missing Flashcard Outputs: ${summary.questionsMissingFlashcardOutputs}`,
        `- Questions Missing Difficulty Ratings: ${summary.questionsMissingDifficultyRatings}`,
        `- Questions Missing Blueprint Mapping: ${summary.questionsMissingBlueprintMapping}`,
        `- Questions Requiring Major Revision: ${summary.questionsRequiringMajorRevision}`,
        "",
        "## Pathway Summary",
        "",
        ...mdTable([
          ["Pathway", "Total", "Publication Ready", "Average Score"],
          ...Object.entries(summary.byPathwayGroup).map(([group, row]) => [
            group,
            String(row.total),
            String(row.publicationReady),
            String(row.averageScore),
          ]),
        ]),
        "",
      ].join("\n"),
    );

    writeFileSync(
      resolve(outDir, "estimated-remediation-work-remaining.md"),
      [
        "# Estimated Remediation Work Remaining",
        "",
        `Generated: ${new Date().toISOString()}`,
        "",
        "Planning estimate uses deterministic audit flags. Clinical writing time will vary by topic complexity.",
        "",
        `- Major revisions: ${summary.questionsRequiringMajorRevision} x 12-20 min`,
        `- Missing rationales: ${summary.questionsMissingRationales} x 8-15 min`,
        `- Missing distractor/hint/pearl/anchor fields: ${results.reduce((sum, r) => sum + r.missingFields.length, 0)} total missing fields x 3-8 min`,
        "",
        "All generated remediation drafts remain unpublished until reviewed.",
        "",
      ].join("\n"),
    );

    console.log(`Audited ${results.length.toLocaleString()} RN/RPN/NP questions.`);
    console.log(`Publication-ready: ${results.filter((r) => r.publicationReady).length.toLocaleString()}`);
    console.log(`Reports written to ${outDir}`);
  } catch (error) {
    writeDatabaseUnavailableReports(outDir, error instanceof Error ? error.message : String(error));
    console.log("Database unavailable; wrote audit deliverable stubs with the failure reason.");
  } finally {
    await prisma.$disconnect();
  }
}

main().catch((error) => {
  console.error(error);
  process.exit(1);
});
