/** Simplified Chinese long-form sections (educational register; placeholders §T§ §E§ §N§). */
export function zhHansSectionBlocks(ctx: { topicPhrase: string; examFrame: string; n: number }): string[] {
  const { topicPhrase: T, examFrame: E, n: N } = ctx;
  const sub = (s: string) => s.replace(/§T§/g, T).replace(/§E§/g, E).replace(/§N§/g, String(N));
  return [
    sub(`<h2>引言</h2>
<p>本篇教育性文章将 §T§ 与评估、沟通及患者安全等常在 §E§ 中被考查的要点联系起来。它不能替代本地规程或临床督导，而是为在不同医疗体系间过渡的考生提供学习框架。</p>
<p>清晰的主线包括：识别风险、准确记录、及时上报与教育（在病情允许时）。</p>
<p>编号 §N§ 强调深度来自在同一临床框架下反复练习细微差别：药物相互作用、文化障碍、资源限制与跨专业协作。</p>`),
    sub(`<h2>关键要点</h2>
<ul>
  <li>§T§ 融入优先级决策：先稳定血流动力学与气道（如需要），再处理可逆原因并进行教育。</li>
  <li>病历应体现客观体征、干预措施与患者反应；可追溯性受重视。</li>
  <li>用药前需核对过敏史、肝肾功能与治疗重复；给药或建议调整前尤然。</li>
  <li>患者教育应使用可核实的语言并检验理解，尤其在交接环节。</li>
  <li>通过迫使比较两种合理措施并论证更安全者的病例训练，可更好准备 §E§。</li>
</ul>`),
    sub(`<h2>临床概览与考试关联</h2>
<p>在 §E§ 中，题目常把不完整信息与似是而非的干扰项混合。对 §T§，可采用脚本：识别主要生理缺陷、预判并发症，并使干预与目标国护理法定范围一致。</p>
<p>安全框架（核查表、双签、抗生素/再灌注时间窗）往往是隐含期望；先点明安全原则再选技术选项。</p>
<p>与医师沟通应简洁：情境、相关既往、聚焦评估及在格式允许时的护理建议。</p>
<p>伦理与知情同意在自主性与急迫风险冲突时塑造答案。</p>`),
    sub(`<h2>相关时的病理生理</h2>
<p>病理生理指导观察：何种体征预示何种衰竭。对 §T§，将血流动力学、酸碱平衡、炎症或靶器官功能障碍与床旁可监测指标联系。</p>
<p>不必背诵每条分子通路；理解代偿有助于解释监测与检验趋势。</p>
<p>考试常考查干预后出现意外结果背后的机制。</p>
<p>在儿童或老年场景，调整预期阈值并记录衰弱与共病。</p>`),
    sub(`<h2>评估重点</h2>
<p>不稳定时从 ABC 开始；随后按规程完成与 §T§ 相关的系统评估（视触叩听与监测）。</p>
<p>记录疼痛、意识、尿量、呼吸做功与灌注指标；主观资料应引用患者原话与量表。</p>
<p>纳入早期预警与上报路径（如存在）。</p>
<p>考虑可能影响表现或依从性的社会心理与语言因素。</p>`),
    sub(`<h2>护理干预与协调</h2>
<p>干预应具体、可计时、可评价。对 §T§，描述体位、氧疗、静脉通路、药物准备、操作后监测及适当时机的教育。</p>
<p>跨专业协调包括澄清含糊医嘱与保障转运交接。</p>
<p>感染预防与无菌技术具有横切意义。</p>
<p>以可观察事实与时间记录不良事件与纠正措施。</p>`),
    sub(`<h2>药理与相关药物</h2>
<p>核对名称、剂量、途径、频次与相对禁忌。对 §T§，关注按体重、年龄、妊娠或器官功能调整。</p>
<p>评估与居家药物及补充剂的相互作用。</p>
<ul>
  <li>高危药物独立核对。</li>
  <li>教育常见不良反应与警示征象。</li>
  <li>入院、转科与出院时的用药重整。</li>
</ul>
<p>在考试中，正确选项常与安全政策及指南摘要一致。</p>`),
    sub(`<h2>患者与家庭教育</h2>
<ol>
  <li>§T§：用通俗语言说明出院后需继续监测的内容及必要时如何测量体征。</li>
  <li>对装置或敷料采用回示法确认理解。</li>
  <li>提供可及的书面材料与提问时间；记录感觉或认知障碍。</li>
  <li>存在重大社会风险或语言鸿沟时联动社工或口译。</li>
  <li>重申早期复诊指征与合适联系方式。</li>
</ol>`),
    sub(`<h2>临床判断与优先级</h2>
<p>面对两种合理措施时，优先消除生命威胁或防止即刻损害。§T§ 适合用于混杂数据的优先级题目。</p>
<p>避免锚定偏误：症状变化或干预后重新评估。</p>
<p>纳入伦理：保密、公平与在法律范围内尊重自主。</p>`),
    sub(`<h2>考试快速复习要点</h2>
<ul>
  <li>与 §T§ 相关的明确恶化征象及上报升级。</li>
  <li>能体现连续性与安全的最低限度记录。</li>
  <li>可核实教育且避免文化刻板印象。</li>
  <li>团队协作与结构化沟通。</li>
  <li>过渡期用药重整与药学监测。</li>
</ul>`),
    sub(`<h2>深入：安全与连续性</h2>
<p>连续性体现在夜班同事也能读懂的记录：改变了什么、为何、已尝试的措施及恶化时的计划。对 §T§，避免无数据的笼统“稳定”；优先呈现生命体征趋势、液体平衡或相关实验室指标。</p>
<p>安全亦含人体工学、跌倒预防与皮肤完整性；在 §E§ 中，当首要选项已覆盖最急迫风险时，这些主题可能以“次优但正确”的形式出现。</p>
<p>思考镇痛可及性、口译与社会支持的公平性；准确记录观察与偏好。</p>`),
    sub(`<h2>深入：危机沟通与伦理边界</h2>
<p>危机中冷静而简短的技术性表达可降低错误。练习在 §T§ 关联急性不稳定时明确提出即刻复核需求，并在电话沟通中复述确认。</p>
<p>伦理边界包括在合法框架内拒绝执行认为有害医嘱并启动恰当机构上报链。</p>
<p>以一句学习收获结束每个案例：明天你会不同地监测什么，使 §T§ 成为累积经验而非脆弱记忆。</p>`),
  ];
}
