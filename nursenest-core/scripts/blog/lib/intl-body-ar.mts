/** Arabic long-form sections (MSA educational register; placeholders §T§ §E§ §N§). */
export function arSectionBlocks(ctx: { topicPhrase: string; examFrame: string; n: number }): string[] {
  const { topicPhrase: T, examFrame: E, n: N } = ctx;
  const sub = (s: string) => s.replace(/§T§/g, T).replace(/§E§/g, E).replace(/§N§/g, String(N));
  return [
    sub(`<h2>مقدمة</h2>
<p>يربط هذا المقال التعليمي بين §T§ وبين أولويات التقييم والتواصل وسلامة المريض التي غالبًا ما تُختبر في إطار §E§. وهو لا يغني عن البروتوكولات المحلية أو الإشراف السريري، بل يقدّم إطارًا دراسيًا للمرشحين الذين ينتقلون بين أنظمة رعاية مختلفة.</p>
<p>يظل الخيط الواضح هو: التعرف على الخطر، والتوثيق الدقيق، والتصعيد في الوقت المناسب، وتثقيف المريض عندما تسمح الحالة بذلك. وغالبًا ما تُعرض هذه الخطوات في الاختبارات كقرارات متتابعة لا كقوائم منفصلة عن السياق.</p>
<p>يشير الرقم §N§ إلى أن العمق يأتي من تكرار نفس الهيكل السريري مع فروق في التفاعلات الدوائية والحواجز الثقافية وقيود الموارد والعمل بين المهن.</p>`),
    sub(`<h2>نقاط رئيسية</h2>
<ul>
  <li>تندمج §T§ في خيارات تحديد الأولويات: الاستقرار الدموي ومجال الهواء عند الحاجة أولًا، ثم الأسباب القابلة للعكس ثم التثقيف.</li>
  <li>يجب أن يعكس السجل العلامات الموضوعية والتدخلات واستجابة المريض؛ وتُقدَّر القابلية للتتبع.</li>
  <li>تتطلب العلاجات الدوائية التحقق من الحساسية ووظائف الكبد/الكلى والتداخل العلاجي قبل الإعطاء أو اقتراح تعديل.</li>
  <li>ينبغي أن يستخدم التثقيف الصحي لغة يمكن التحقق من فهمها، خصوصًا عند انتقالات الرعاية.</li>
  <li>تتحسن الاستعدادية لـ §E§ عند التدرب على سيناريوهات تجبرك على مقارنة إجراءين معقولين وتبرير الأكثر أمانًا.</li>
</ul>`),
    sub(`<h2>نظرة سريرية وارتباط الاختبار</h2>
<p>في §E§، غالبًا ما تُمزج بيانات جزئية مع خيارات مشوشة معقولة. ولـ §T§، من المفيد أن تبدأ بتحديد العجز الفسلجي الأساسي وتوقع المضاعفات ومواءمة التدخل مع نطاق ممارسة التمريض القانوني في بلد الوجهة.</p>
<p>تظل معايير السلامة (قوائم التحقق، التحقق المزدوج، زمن البدء بالمضادات أو إعادة التروية) توقعات ضمنية؛ سمِّ مبدأ السلامة قبل اختيار الخيار التقني.</p>
<p>ينبغي أن يكون التواصل مع الفريق الطبي موجزًا: الحالة، التاريخ المهم، التقييم البؤري، وتوصية التمريض عندما يناسب النموذج ذلك.</p>
<p>كما يؤطر الالتزام الأخلاقي والموافقة المستنيرة الإجابات عندما تتعارض الاستقلالية مع خطر حادٍّ.</p>`),
    sub(`<h2>فسيولوجيا المرض عندما ينطبق ذلك على §T§</h2>
<p>توجّه الفسيولوجيا المرضية الملاحظة: أي علامة تسبق أي خلل. وبالنسبة إلى §T§، اربط اضطرابات الدورة الدموية والتوازن الحمضي القاعدي والالتهاب أو خلل وظيفة العضو بمؤشرات يمكن مراقبتها عند السرير.</p>
<p>لا يلزم حفظ كل مسار جزيئي؛ يكفي فهم التعويضات لتفسير اتجاهات المراقبة والمختبر.</p>
<p>غالبًا ما تسأل الاختبارات عن الآلية التي تفسر نتيجة غير متوقعة بعد تدخل؛ تدريب هذا الربط يقلل الاستجابات الاندفاعية.</p>
<p>في الأطفال أو كبار السن، عدّل العتبات المتوقعة ووثِّق الهشاشة أو الاعتلالات المصاحبة.</p>`),
    sub(`<h2>أولويات التقييم</h2>
<p>ابدأ بمسار ABC عند عدم الاستقرار؛ ثم أكمل الأنظمة ذات الصلة بـ §T§ وفق التفتيش والمسح والسماع والمراقبة وفق البروتوكول.</p>
<p>سجّل الألم والمستوى الواعي وإدرار البول وجهد التنفس وعلامات التروية. وللبيانات الذاتية، اذكر كلام المريض والمقياس المستخدم.</p>
<p>ادمج أنظمة الإنذار المبكر ومسار التصعيد إن وجدت؛ يتحقق الاختبار من أنك تتعرف على التدهور والقناة الصحيحة للإبلاغ.</p>
<p>اعتبر العوامل الاجتماعية والنفسية واللغوية التي تغيّر العرض أو الالتزام؛ والحكم الثقافي المسؤول جزء من الرعاية الآمنة.</p>`),
    sub(`<h2>تدخلات التمريض والتنسيق</h2>
<p>ينبغي أن تكون التدخلات محددة ومؤرخة وقابلة للتقييم. ولـ §T§، صف الوضعية والأكسجين والوصول الوري وتحضير الأدوية والمراقبة بعد الإجراء والتثقيف عند الاقتضاء.</p>
<p>يشمل التنسيق بين المهن إزالة الغموض عن التوجيهات وتأمين الانتقالات بين الوحدات.</p>
<p>الوقاية من العدوى والتقنية المعقمة موضوعات عابرة حتى إن بدا البند مركزًا على العلاج الدوائي.</p>
<p>وثِّق الأحداث الضائرة والإجراءات التصحيحية بحقائق ملاحظة وأزمنة.</p>`),
    sub(`<h2>علم الأدوية والأدوية ذات الصلة</h2>
<p>تحقق من الاسم والجرعة والمسار والتكرار والموانع النسبية. ولـ §T§، انتبه لتعديلات الوزن والعمر والحمل أو عجز العضو.</p>
<p>قيّم التداخلات مع العلاج المنزلي والمكمّلات؛ واسأل بصياغة مفتوحة وتأكد من مصادر المؤسسة.</p>
<ul>
  <li>التحقق المستقل للأدوية عالية الخطورة.</li>
  <li>تثقيف المريض حول الآثار الشائعة وعلامات التحذير.</li>
  <li>المطابقة الدوائية عند القبول والنقل والخروج.</li>
</ul>
<p>في الاختبار، غالبًا ما تتماشى الإجابة الصحيحة مع سياسات السلامة وملخصات الأدلة.</p>`),
    sub(`<h2>تثقيف المريض والأسرة</h2>
<ol>
  <li>§T§: اشرح بلغة مبسطة ما ستستمر مراقبته في المنزل وكيفية قياس العلامات عند الحاجة.</li>
  <li>أكد الفهم بطريقة الإعادة التوضيحية عند وجود أجهزة أو ضمادات.</li>
  <li>قدّم مواد مكتوبة مناسبة ووقتًا للأسئلة؛ ودوّن الحواجز الحسية أو الإدراكية.</li>
  <li>فعّل الخدمة الاجتماعية أو الترجمة عند خطر اجتماعي أو فجوة لغوية كبيرة.</li>
  <li>أعد تأكيد معايير العودة المبكرة وقناة الاتصال المناسبة.</li>
</ol>`),
    sub(`<h2>الحكم السريري وتحديد الأولويات</h2>
<p>عند خيارين معقولين، اختر أولًا ما يلغي خطرًا حياتيًا أو يمنع ضررًا فوريًا. وتسهّل §T§ أسئلة الأولوية ببيانات غير متجانسة.</p>
<p>تجنب التثبيت المعرفي: أعد التقييم عند تغير الأعراض أو بعد تدخل.</p>
<p>ادمج الأخلاقيات: السرية والعدالة واحترام الاستقلالية ضمن حدود القانون المحلي.</p>`),
    sub(`<h2>نقاط مراجعة سريعة للامتحان</h2>
<ul>
  <li>علامات تدهور واضحة مرتبطة بـ §T§ ومسار التصعيد.</li>
  <li>الحد الأدنى من التوثيق الذي يثبت الاستمرارية والسلامة.</li>
  <li>تثقيف قابل للتحقق دون صور نمطية ثقافية.</li>
  <li>العمل الجماعي والتواصل المنظم.</li>
  <li>المطابقة الدوائية والمراقبة عند الانتقالات.</li>
</ul>`),
    sub(`<h2>تعميق: السلامة والاستمرارية</h2>
<p>تظهر الاستمرارية في ملاحظات يفهمها زميل في نوبة ليلية: ما الذي تغير ولماذا وماذا جرّبنا وما الخطة عند التفاقم. ولـ §T§، تجنب أوصافًا عامة بلا أرقام؛ فضّل اتجاهات العلامات الحيوية أو التوازن المائي أو المؤشرات ذات الصلة.</p>
<p>تشمل السلامة أيضًا الوقاية من السقوط وسلامة الجلد؛ وفي §E§ قد تعود كـ«الإجابة الثانية» بعد تغطية الخطر الأعاجل.</p>
<p>فكّر في العدالة في الوصول إلى مسكنات الألم والترجمة والدعم الاجتماعي؛ وثّق الملاحظات والتفضيلات بدقة.</p>`),
    sub(`<h2>تعميق: التواصل في الأزمة والحدود الأخلاقية</h2>
<p>في الأزمات، يقلل الهدوء والاختصار الفني من الأخطاء. تدرّب على صياغة واضحة للحاجة الفورية للمراجعة عند ارتباط §T§ باضطراب حادٍّ، وأعد التأكيد عند الاتصال الهاتفي.</p>
<p>تشمل الحدود الأخلاقية الامتناع عن تنفيذ أمر تراه ضارًا ضمن إطارك القانوني مع تصعيد مؤسسي مناسب.</p>
<p>أنهِ كل حالة بجملة تعلم: ماذا ستراقب بشكل مختلف غدًا، لتحويل §T§ إلى خبرة متراكمة لا حفظًا هشًا.</p>`),
  ];
}
