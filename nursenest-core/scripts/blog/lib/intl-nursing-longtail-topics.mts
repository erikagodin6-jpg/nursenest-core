export function translationGroupIdForIndex(i: number): string {
  return `intl-nursing-grp-${String(i + 1).padStart(3, "0")}`;
}

export function asciiSlugStem(i: number): string {
  const bases = [
    "sepsis-early-care",
    "electrolyte-k-safety",
    "hypoglycemia-falls",
    "neuro-deficit-abc",
    "acs-nursing-first-hour",
    "resp-failure-oxygen",
    "acid-base-arterial-blood-gas",
    "aki-fluid-balance",
    "hemorrhagic-shock-resuscitation",
    "pressure-injury-icu",
    "severe-pain-multimodal",
    "hospital-delirium-nonpharm",
    "clabsi-prevention-care",
    "cap-severity-nursing",
    "copd-exacerbation-education",
    "acute-asthma-airway",
    "dka-fluids-electrolytes",
    "nephrotic-edema-monitoring",
    "liver-encephalopathy-safety",
    "coagulation-procedure-bleeding",
    "pregnancy-preeclampsia-warnings",
    "early-postop-drain-pain-mobility",
    "anticoagulation-bleeding-teaching",
    "acute-heart-failure-decomp",
    "arrhythmia-syncope-monitoring",
    "hydroelectrolyte-na-ca-mg",
    "acute-intoxication-stabilization",
    "emergency-mental-health-safety",
  ];
  return `${bases[i % bases.length]}-intl-topic-${String(i + 1).padStart(3, "0")}`;
}

export function topicPhraseFor(lang: IntlNursingLangKey, i: number): string {
  const row = PICK[lang][i % PICK[lang].length];
  return `${row} · ${lang.toUpperCase()} pedagogy band ${i + 1}`;
}
