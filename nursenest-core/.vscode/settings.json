{
  "git.ignoreLimitWarning": true,
  "git.autorefresh": false,
  "git.decorations.enabled": false,
  "editor.minimap.enabled": false,
  "editor.stickyScroll.enabled": false,
  "typescript.tsserver.maxTsServerMemory": 8192,
  "typescript.disableAutomaticTypeAcquisition": true,
  "typescript.tsserver.experimental.enableProjectDiagnostics": false,
  "typescript.preferences.includePackageJsonAutoImports": "off",
  "typescript.suggest.autoImports": false,
  "typescript.tsdk": "node_modules/typescript/lib",
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/node_modules/**": true,
    "**/.next/**": true,
    "**/.turbo/**": true,
    "**/.cache/**": true,
    "**/.tmp/**": true,
    "**/tmp/**": true,
    "**/temp/**": true,
    "**/coverage/**": true,
    "**/test-results/**": true,
    "**/playwright-report/**": true,
    "**/playwright-report-full-regression/**": true,
    "**/blob-report/**": true,
    "**/logs/**": true,
    "**/*.log": true,
    "**/*.png": true,
    "**/*.jpg": true,
    "**/*.webp": true,
    "**/*.zip": true,
    "**/.prisma/**": true,
    "**/.vercel/**": true,
    "**/.digitalocean/**": true,
    "**/prisma/migrations/**": true,
    "**/public/i18n/**": true,
    "**/reports/**": true,
    "**/preview-screenshots/**": true,
    "**/rollback-snapshots/**": true,
    "**/output/**": true,
    "**/generated-indexes/**": true,
    "**/src/content/pathway-lessons/generated-indexes/**": true,
    "**/dist/**": true,
    "**/build/**": true,
    "**/playwright/.cache/**": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/.next": true,
    "**/.turbo": true,
    "**/.cache": true,
    "**/.tmp": true,
    "**/tmp": true,
    "**/temp": true,
    "**/dist": true,
    "**/coverage": true,
    "**/test-results": true,
    "**/playwright-report": true,
    "**/playwright-report-full-regression": true,
    "**/blob-report": true,
    "**/logs": true,
    "**/*.log": true,
    "**/.prisma": true,
    "**/.vercel": true,
    "**/.digitalocean": true,
    "**/prisma/migrations": true,
    "**/public/i18n": true,
    "**/reports": true,
    "**/preview-screenshots": true,
    "**/rollback-snapshots": true,
    "**/output": true,
    "**/generated-indexes": true,
    "**/src/content/pathway-lessons/generated-indexes": true,
    "**/build": true
  },
  "files.exclude": {
    "**/.next": true,
    "**/node_modules": true,
    "**/dist": true,
    "**/.tmp": true,
    "**/.turbo": true,
    "**/.cache": true,
    "**/coverage": true,
    "**/test-results": true,
    "**/playwright-report": true,
    "**/playwright-report-full-regression": true,
    "**/blob-report": true,
    "**/logs": true,
    "**/*.log": true,
    "**/.prisma": true,
    "**/.vercel": true,
    "**/.digitalocean": true,
    "**/prisma/migrations": true,
    "**/public/i18n": true,
    "**/reports": true,
    "**/preview-screenshots": true,
    "**/rollback-snapshots": true,
    "**/output": true,
    "**/generated-indexes": true,
    "**/src/content/pathway-lessons/generated-indexes": true,
    "**/build": true
  },
  "vibecheck.watchMode": true,
  "python.testing.unittestArgs": [
    "-v",
    "-s",
    "./apps",
    "-p",
    "*_test.py"
  ],
  "python.testing.pytestEnabled": false,
  "python.testing.unittestEnabled": true
}
