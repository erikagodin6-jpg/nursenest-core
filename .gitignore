# -----------------------------------------------------------------------------
# Canonical patterns (deploy hygiene — keep nursenest-core/.gitignore aligned)
# -----------------------------------------------------------------------------
node_modules/
.next/
.next/cache/
.env
.env.local
.env.*.local
*.log
external/
*.zip
*.tgz
*.tar
*.gz
.DS_Store
# -----------------------------------------------------------------------------
dist
build
server/public
vite.config.ts.*
*.tar.gz
/backups/
/exports/
.env
.env.local
.env.production
.env.*.local
scripts/i18n-scan-report.json
scripts/replit-import/nursing-audit-samples.json
migration-results.json
# Stale CJS/emit artifacts next to TS sources — shadow bundler resolution; never commit
client/src/**/*.js
i18n-violations-report.json

# Logs and local diagnostics
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Temp / cache
.push-tmp/
tmp/
temp/
.cache/
.turbo/
coverage/
.nyc_output/

# TypeScript / bundler caches (anywhere in repo)
*.tsbuildinfo
vite_stderr.txt

# Local tooling / IDE
.local/
.idea/
*.swp
*.swo
.worktrees/

# Keys and local auth artifacts (never commit secrets)
# Playwright E2E cached sessions (see nursenest-core/playwright.config.ts)
nursenest-core/tests/e2e/.auth/
*.pem
*.p12
.id_rsa
*.key

# Generated i18n diagnostics (large; regenerate with npm run i18n:status or dashboard refresh)
reports/i18n-status.json

# Large local DB dumps / Replit exports (use data/imports/ + REPLIT_IMPORT_DIR for checked-in samples)
data/replit-exports/
nursenest-core/data/replit-exports/

# Local Replit Object Storage extract (upload source; never commit)
/replit-export/

# Regenerate with npm run audit:replit-exports
scripts/replit-export-audit-report.json
scripts/replit-export-audit-report.md

# Local nursing import previews (never commit)
scripts/replit-import/*-local.json
scripts/replit-import/nursing-preview-output.json

# Next.js / Vite build output (also cleaned by npm run clean:generated)
.next/
out/
nursenest-core/.next/

# Optional local exports / scans (keep out of git)
artifacts/
scan.txt
hardcoded-strings-report.json
attached_assets/
*.mp4
*.psd

# Local scratch / accidental binaries (repo root)
/a.out
/XX0GPFNg
/sedBZsw0b
/free
/maingit

# Legacy extract + backup archives (never commit)
.legacy-extract/
external/
*.zip
*.tgz

# Local DB files and dumps (never commit — use managed backups)
*.sqlite
*.sqlite3
*.dump
pg_dump*.sql
*.backup

# Direnv / local shell env (may contain secrets)
.envrc

# Extra export / scratch output names
export-output/
exports/
backups/
*-export.jsonl
local-backup/

# Next app package — export/backup scratch (commits often run from repo root)
nursenest-core/admin-export/
nursenest-core/downloads/
nursenest-core/local-export/
nursenest-core/.replit-export-staging/
nursenest-core/nursing-import-quarantine.jsonl

# OS junk
Thumbs.db
Desktop.ini

# JetBrains (optional)
*.iml
