# Monorepo root — legacy/shared tooling only.
#
# For the production Next.js app, prefer:
#   nursenest-core/.env.example
#
# Copy this file to .env only when running root-level migration/shared scripts.
# Never commit real .env files.

# Google Cloud Storage — public object base URL.
# Required trailing slash.
GOOGLE_BUCKET_BASE_URL=https://storage.googleapis.com/YOUR_BUCKET_NAME/

# Image migration manifest.
# Accepts either:
# - JSON array of object paths
# - newline-separated text file
MIGRATION_MANIFEST=./scripts/migration-image-manifest.example.json

# DigitalOcean Spaces — S3-compatible credentials.
SPACES_KEY=
SPACES_SECRET=
SPACES_REGION=nyc3
SPACES_BUCKET=

# Optional: override Spaces endpoint.
# Example:
# SPACES_ENDPOINT=https://tor1.digitaloceanspaces.com
SPACES_ENDPOINT=

# Optional: prefix uploaded object keys.
# Example:
# SPACES_KEY_PREFIX=cdn/
SPACES_KEY_PREFIX=

# Set to 1 to log actions without uploading.
DRY_RUN=0