# Copy to .env and fill in real values. Never commit .env.
#
# Google Cloud Storage — public object base (trailing slash required)
GOOGLE_BUCKET_BASE_URL=https://storage.googleapis.com/YOUR_BUCKET_NAME/

# Path to manifest: JSON array of object paths, or newline-separated paths (see scripts/migrate-images.js)
MIGRATION_MANIFEST=./scripts/migration-image-manifest.example.json

# DigitalOcean Spaces (S3-compatible)
SPACES_KEY=
SPACES_SECRET=
SPACES_REGION=nyc3
SPACES_BUCKET=

# Optional: override API endpoint if your Space lives in a different region than SPACES_REGION
# Example: https://tor1.digitaloceanspaces.com
# SPACES_ENDPOINT=

# Optional: prefix keys in the Space (e.g. "cdn/")
SPACES_KEY_PREFIX=

# Optional: set to 1 to log actions without uploading
# DRY_RUN=0
