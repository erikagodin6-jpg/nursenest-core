# Copy to `.env` locally (never commit real values).
# Client-embeddable keys only — use EXPO_PUBLIC_*.

# Primary: Next.js origin (Auth.js + learner API)
EXPO_PUBLIC_NURSE_NEST_WEB_ORIGIN=https://www.example.com

# Aliases read by auth + env helpers (pick one consistent origin in prod)
# EXPO_PUBLIC_APP_ORIGIN=https://www.example.com
# EXPO_PUBLIC_API_ORIGIN=https://www.example.com

# PostHog (optional) — mirrors web NEXT_PUBLIC_POSTHOG_*
# EXPO_PUBLIC_POSTHOG_KEY=
# EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry (optional) — public DSN only; no auth token in the app
# EXPO_PUBLIC_SENTRY_DSN=

# Phase 2 React Query persistence gate
# EXPO_PUBLIC_ENABLE_QUERY_PERSISTENCE=0

# Dev-only: log stub feature-flag evaluations
# EXPO_PUBLIC_FEATURE_FLAGS_STUB=0
