    "**/blog-output/**": true,
    "**/blog-temp/**": true,
    "**/generated-indexes/**": true,
    "**/src/content/pathway-lessons/generated-indexes/**": true,
    "**/nursenest-core/src/content/pathway-lessons/generated-indexes/**": true,
    "**/dist/**": true,
    "**/nursenest-core/build/**": true,
    "**/client/build/**": true,
    "build/**": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/.next": true,
    "**/.turbo": true,
    "**/.cache": true,
    "**/.tmp": true,
    "**/tmp": true,
    "**/temp": true,
    "**/dist": true,
    "**/coverage": true,
    "**/test-results": true,
    "**/playwright-report": true,
    "**/blob-report": true,
    "**/logs": true,
    "**/*.log": true,
    "**/.prisma": true,
    "**/.vercel": true,
    "**/.digitalocean": true,
    "**/prisma/migrations": true,
    "**/public/i18n": true,
    "**/nursenest-core/public/i18n": true,
    "**/client/public/i18n": true,
    "**/reports": true,
    "**/replit-export": true,
    "**/nursenest-core/data": true,
    "**/data/replit-exports": true,
    "**/nursenest-core/data/replit-exports": true,
    "**/client/src/data/translations": true,
    "**/blog-output": true,
    "**/blog-temp": true,
    "**/generated-indexes": true,
    "**/src/content/pathway-lessons/generated-indexes": true,
    "**/nursenest-core/src/content/pathway-lessons/generated-indexes": true,
    "nursenest-core/build": true,
    "client/build": true,
    "build": true
  },
  "files.exclude": {
    "**/.next": true,
    "**/node_modules": true,
    "**/dist": true,
    "**/.tmp": true,
    "**/.turbo": true,
    "**/.cache": true,
    "**/coverage": true,
    "**/test-results": true,
