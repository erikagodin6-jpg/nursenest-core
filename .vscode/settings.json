{
  "git.ignoreLimitWarning": true,
  "git.autorefresh": false,
  "git.decorations.enabled": false,
  "editor.minimap.enabled": false,
  "editor.stickyScroll.enabled": false,
  "typescript.tsserver.maxTsServerMemory": 4096,
  "typescript.disableAutomaticTypeAcquisition": true,
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/node_modules/**": true,
    "**/.next/**": true,
    "**/.turbo/**": true,
    "**/.cache/**": true,
    "**/.tmp/**": true,
    "**/tmp/**": true,
    "**/temp/**": true,
    "**/coverage/**": true,
    "**/test-results/**": true,
    "**/playwright-report/**": true,
    "**/blob-report/**": true,
    "**/logs/**": true,
    "**/*.log": true,
    "**/.prisma/**": true,
    "**/.vercel/**": true,
    "**/.digitalocean/**": true,
    "**/prisma/migrations/**": true,
    "**/public/i18n/**": true,
    "**/nursenest-core/public/i18n/**": true,
    "**/client/public/i18n/**": true,
    "**/reports/**": true,
    "**/replit-export/**": true,
    "**/nursenest-core/data/**": true,
    "**/data/replit-exports/**": true,
    "**/nursenest-core/data/replit-exports/**": true,
    "**/client/src/data/translations/**": true,
