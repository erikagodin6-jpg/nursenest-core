# Git / IDE
# Keep `tools/` out of ignore — Docker builder needs `tools/i18n/source/*.ts` for `npm run i18n:compile`.
.git
.github
.cursor
**/.DS_Store

# Optional local monorepo checkouts / huge trees (not part of DO GitHub context; keep tar small)
external

# Mobile app — never referenced in Dockerfile, saves ~490 MB
apps/

# Legacy Vite client assets — 835 MB of PNGs not imported by Next.js build.
# Only client/src/{data,pages,components,lib,...} TS files are needed (@legacy-client/* alias).
client/src/assets
client/public
client/replit_integrations

# Docs, screenshots, and nested client public — not needed in production image
nursenest-core/docs
nursenest-core/client

# Dependencies & build outputs (reinstalled / rebuilt in image)
**/node_modules
**/.next
**/dist
**/build
!nursenest-core/src/build
!nursenest-core/src/build/**
!nursenest-core/src/lib/build
!nursenest-core/src/lib/build/**
**/.turbo

# Tests & Playwright (not needed for production image)
**/coverage
**/playwright-report
**/test-results
**/playwright/.cache
nursenest-core/tests

# Generated audits / reports (kept in git/workspace, not needed inside production image)
nursenest-core/output
nursenest-core/reports
nursenest-core/docs/reports
reports/ui-redesign-preview
preview-screenshots
**/preview-screenshots
docs/screenshots
docs/qa-reports
docs/verification-screenshots
**/docs/screenshots
**/test-results/**
**/playwright-report/**

# Logs & env (never bake secrets)
**/*.log
.env
.env.*
!.env.example

# Misc caches
**/.eslintcache
**/tsconfig.tsbuildinfo

# Large test artifacts and screenshots — never needed at runtime
nursenest-core/playwright/
nursenest-core/playwright-report-full-regression/
nursenest-core/playwright-report-full-regression/**
playwright-report-full-regression/
playwright-report-full-regression/**
