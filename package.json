{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev:client": "vite dev --port 5000",
    "dev": "NODE_ENV=development tsx server/index.ts",
    "prebuild": "node scripts/ensure-build-toolchain.mjs",
    "build": "NODE_OPTIONS=--max-old-space-size=4096 npx tsx script/build.ts && node scripts/verify-dist-artifacts.mjs",
    "build:server": "BUILD_TARGET=server NODE_OPTIONS=--max-old-space-size=4096 npx tsx script/build.ts && node scripts/verify-dist-artifacts.mjs",
    "build:client": "BUILD_TARGET=client NODE_OPTIONS=--max-old-space-size=4096 npx tsx script/build.ts && node scripts/verify-dist-artifacts.mjs",
    "build:heavy": "BUILD_TARGET=heavy RUN_HEAVY_BUILD_TASKS=1 NODE_OPTIONS=--max-old-space-size=4096 npx tsx script/build.ts && node scripts/verify-dist-artifacts.mjs",
    "content:export:question-banks": "tsx scripts/export-question-bank-json.ts",
    "start": "node scripts/start-production.mjs",
    "heroku:local": "node scripts/start-production.mjs",
    "verify:dist": "node scripts/verify-dist-artifacts.mjs",
    "production:build": "bash scripts/production-build.sh",
    "check": "tsc",
    "check:server": "tsc --noEmit -p tsconfig.server.json",
    "check:bundle-size": "node scripts/check-bundle-size.mjs",
    "migrate:flashcards": "tsx scripts/migrate-flashcards-to-postgres.ts",
    "check:storage": "tsx scripts/check-storage-sanity.ts",
    "check:server:isolation": "tsx scripts/check-server-isolation.ts",
    "check:server:guardrails": "npm run check:storage && npm run check:server:isolation && npm run check:server",
    "verify:api": "tsx scripts/verify-core-api.ts",
    "seed:local-verify": "node scripts/seed-local-verify-data.mjs",
    "seed:career-questions": "npx tsx scripts/seed-career-questions.ts",
    "seed:mlt-lessons": "npx tsx scripts/seed-mlt-structured-lessons.ts",
    "db:push": "drizzle-kit push",
    "backup:full": "tsx backup-system/backup-full.ts",
    "backup:db": "tsx backup-system/backup-db.ts",
    "backup:assets": "tsx backup-system/backup-assets.ts",
    "export:deployment": "tsx backup-system/export-deployment.ts",
    "backup:validate": "tsx backup-system/validate-backup.ts",
    "i18n:compile": "npx tsx script/compile-i18n.ts",
    "i18n:validate": "npx tsx script/i18n-validate.ts",
    "i18n:check-drift": "npx tsx script/i18n-check-drift.ts",
    "i18n:ci": "npm run i18n:compile && npm run i18n:validate && npm run i18n:check-drift",
    "i18n:status": "tsx scripts/generate-i18n-status.ts",
    "i18n:scan": "tsx scripts/i18n-scan.ts",
    "i18n:scan:ci": "tsx scripts/i18n-scan.ts --ci",
    "build:guard": "tsx scripts/i18n-scan.ts --build-guard",
    "precommit:i18n": "tsx scripts/i18n-scan.ts --ci --threshold=0",
    "migrate:images": "node scripts/migrate-images.js",
    "import:replit-exports": "npx tsx scripts/replit-export-import/cli.ts",
    "audit:replit-exports": "npx tsx scripts/audit-replit-exports.ts",
    "validate:replit-exports": "npx tsx scripts/import-replit-exports.ts",
    "nursing:preview": "npx tsx scripts/replit-import/nursing-dry-run-preview.ts",
    "nursing:preview:db": "npx tsx scripts/replit-import/nursing-dry-run-preview.ts --check-db-duplicates",
    "nursing:audit": "npx tsx scripts/replit-import/nursing-pre-import-audit.ts",
    "nursing:resolution-report": "npx tsx scripts/replit-import/nursing-export-resolution-report.ts",
    "nursing:audit:db": "npx tsx scripts/replit-import/nursing-pre-import-audit.ts --check-db",
    "clean:generated": "node scripts/clean-generated-artifacts.mjs",
    "backfill:question-bank-content-tier": "npx tsx scripts/backfill-question-bank-content-tier.ts"
  },
