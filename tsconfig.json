{
  "include": [
    "client/src/**/*",
    "shared/**/*",
    "server/**/*"
  ],
  "exclude": [
    "node_modules",
    "build",
    "dist",
    "coverage",
    ".next",
    ".worktrees",
    ".turbo",
    ".local",
    "data",
    "reports",
    "qa-reports",
    "playwright-report",
    "playwright-report-full-regression",
    "test-results",
    "preview-screenshots",
    "rollback-snapshots",
    "output",
    "tmp",
    "replit-export",
    "tools/i18n",
    "backup-system",
    "scripts",
    "nursenest-core",
    "client/src/data/translations",
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/*.test.tsx",
    "**/*.spec.tsx"
  ],
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "ESNext",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "noEmit": true,
    "incremental": true,
    "tsBuildInfoFile": "./node_modules/.cache/tsbuildinfo",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./client/src/*"
      ],
      "@shared/*": [
        "./shared/*"
      ],
      "@assets/*": [
        "./attached_assets/*"
      ],
      "@/probe-wrapper": [
        "./probe-wrapper"
      ]
    },
    "types": [
      "node",
      "vite/client"
    ]
  }
}